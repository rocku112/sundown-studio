        <a href="../../index.html" title="回 SunDown Studio 品牌頁" style="display:flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:6px;text-decoration:none;opacity:.4;transition:opacity .2s,background .2s;margin-left:2px;" onmouseover="this.style.opacity='.9';this.style.background='rgba(45,74,110,.08)';" onmouseout="this.style.opacity='.4';this.style.background='transparent';"><svg style="width:16px;height:16px;" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg"><defs><clipPath id="sd-tb2-clip"><circle cx="256" cy="256" r="240"/></clipPath></defs><circle cx="256" cy="256" r="256" fill="#1E3554"/><path d="M16 256 A240 240 0 0 1 496 256" fill="#E8B84B" clip-path="url(#sd-tb2-clip)"/><line x1="62" y1="295" x2="450" y2="295" stroke="#fff" stroke-width="26" stroke-linecap="round" opacity=".85"/><line x1="96" y1="338" x2="416" y2="338" stroke="#fff" stroke-width="22" stroke-linecap="round" opacity=".65"/><line x1="138" y1="378" x2="374" y2="378" stroke="#fff" stroke-width="18" stroke-linecap="round" opacity=".45"/></svg></a>
