      <h1 id="page-title"><span id="page-title-icon" style="display:inline-flex;width:22px;height:22px;flex-shrink:0;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V9.5z"/><polyline points="9 21 9 12 15 12 15 21"/></svg></span> <span id="page-title-text">首頁</span></h1>
    </div>
    <div id="topbar-right">
      <span id="topbar-stats" style="font-size:.8rem;color:var(--gray);"></span>
      <div id="topbar-auth">
        <!-- Logged out -->
        <button id="tb-login-btn" onclick="fbSignIn()">
          <svg width="14" height="14" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.2l6.8-6.8C35.8 2.4 30.2 0 24 0 14.6 0 6.6 5.4 2.6 13.2l7.9 6.1C12.4 13 17.8 9.5 24 9.5z"/><path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2l7.6 5.9c4.4-4.1 7-10.1 7-17.1z"/><path fill="#FBBC05" d="M10.5 28.7A14.5 14.5 0 0 1 9.5 24c0-1.6.3-3.2.8-4.7L2.4 13.2A23.9 23.9 0 0 0 0 24c0 3.8.9 7.4 2.5 10.6l8-5.9z"/><path fill="#34A853" d="M24 48c6.2 0 11.4-2 15.2-5.5l-7.6-5.9c-2 1.4-4.6 2.2-7.6 2.2-6.2 0-11.5-4.2-13.4-9.8l-8 5.9C6.5 42.5 14.6 48 24 48z"/></svg>
          <span class="tb-login-text">登入</span>
        </button>
        <!-- Logged in：點頭像展開 dropdown -->
        <div id="tb-user-wrap">
          <div id="tb-user" onclick="toggleUserDropdown()">
            <img id="tb-avatar" src="" alt="" onerror="this.style.display='none';document.getElementById('tb-avatar-fallback').style.display='flex'">
            <div id="tb-avatar-fallback" style="display:none;"></div>
            <div id="tb-name"></div>
            <span id="tb-chevron">▾</span>
          </div>
          <div id="tb-dropdown">
            <div class="tb-drop-info">
              <div class="tb-drop-name" id="tb-drop-name">—</div>
              <div class="tb-drop-email" id="tb-drop-email">—</div>
            </div>
            <button class="tb-drop-btn" onclick="goPage('progress');closeUserDropdown()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              學習進度
            </button>
            <button class="tb-drop-btn danger" onclick="fbSignOut()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              登出
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="content">

    <!-- ══ HOME PAGE ══════════════════════════ -->
    <div id="page-home" class="page active">
      <div class="welcome-banner">
        <div class="wb-left">
          <span class="wb-badge">永續發展基礎能力測驗</span>
          <div class="wb-icon-row">
            <div class="wb-icon">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
            </div>
            <div class="wb-icon">
              <svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 22"/><path d="M22 2s-5 2-8 7c-2.3 3.5-2 7-2 7s2-3.5 5-6c3.1-2.6 5-8 5-8z"/><path d="M2 16s3-1 6-3c3.5-2.3 4.5-5 4.5-5S10 13 8 15c-2.1 2.1-6 3-6 3z"/></svg>
            </div>
            <div class="wb-icon">
              <svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><path d="M17 6h6v6"/></svg>
            </div>
          </div>
          <h2>永續不永遠・<br>考試有終點</h2>
          <p>讓你一次過，永續的事你懂的比老闆多</p>
        </div>
        <div class="wb-right">
          <div class="wb-stat">
            <div class="wb-num">1,040 題</div>
            <div class="wb-label">道道都有解析</div>
          </div>
          <div class="wb-stat">
            <div class="wb-num">5 章</div>
            <div class="wb-label">濃縮到不能再縮</div>
          </div>
          <div class="wb-stat">
            <div class="wb-num">多模式</div>
            <div class="wb-label">反正就是要你過</div>
          </div>
        </div>
      </div>
      <div class="stats-grid" id="home-stats"></div>
      <div id="home-guide"></div>
      <div class="quick-grid">
        <div class="quick-card" onclick="goPage('reader')">
          <div class="q-icon" style="background:var(--gp);color:var(--green);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></div>
          <div>
            <h3>精華筆記</h3>
            <p>5 章 17 節濃縮筆記，左側目錄快速導航，考前快速複習用</p>
          </div>
        </div>
        
        <div class="quick-card" onclick="goPage('textbook2')">
          <div class="q-icon" style="background:#e8f2f9;color:#89b4d4;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg></div>
          <div><h3>永續課文</h3><p>官方課本完整原文，第一章頁1–90，錨點導航，深度理解用</p></div>
          <span class="q-arr">›</span>
        </div>
        <div class="quick-card" onclick="goPage('notes')">
          <div class="q-icon" style="background:#fdf4e3;color:#c88a50;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div>
          <div>
            <h3>考點卡片</h3>
            <p>精選必考考點，含對比表格與<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>常見錯誤提示，快速掌握高頻考題</p>
          </div>
        </div>
        <div class="quick-card" onclick="goPage('quiz')">
          <div class="q-icon" style="background:#fce4ec;color:#c62828;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg></div>
          <div>
            <h3>歷屆題庫</h3>
            <p>1040 題真實考古題，即時顯示答案，可依考試年次篩選</p>
          </div>
        </div>

        <div class="quick-card" onclick="goPage('textbook')">
          <div class="q-icon" style="background:#e2f5ec;color:#2e7a52;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="9" y1="12" x2="13" y2="12"/></svg></div>
          <div>
            <h3>永續題庫</h3>
            <p>永續發展相關規範與實務課本練習題，含詳細解析</p>
          </div>
        </div>
        <div class="quick-card" onclick="goPage('exam')">
          <div class="q-icon" style="background:#ede8f7;color:#8872b8;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="4" rx="1"/><path d="M5 4h-1a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2h-1"/><polyline points="9 12 11 14 15 10"/></svg></div>
          <div>
            <h3>模擬考試</h3>
            <p>90 分鐘倒數計時，80 題隨機出題，交卷後完整成績單</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ══ READER PAGE ════════════════════════ -->
    <div id="page-reader" class="page">
      
      <div class="reader-tabs">
        <button class="reader-tab active" onclick="switchReaderTab('read')"><span class='reader-tab-icon'><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span> 精華筆記</button>
        <button class="reader-tab" onclick="switchReaderTab('practice')"><span class='reader-tab-icon'><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></span> 隨堂練習 <span class="rq-badge" id="rq-badge"></span></button>
      </div>
      <div id="reader-read-view" style="flex:1;display:flex;flex-direction:column;min-height:0;">
        <div class="reader-layout" id="reader-layout">
          <div class="reader-toc" id="reader-toc"></div>
          <div class="reader-body" id="reader-body">
            <p style="color:var(--gray);text-align:center;padding:40px;">請從左側目錄選擇章節</p>
          </div>
        </div>
      </div>
      <div id="reader-practice-view" style="display:none;">
        <div class="quiz-controls">
          <label>章節：</label>
          <select id="rq-chapter-filter" onchange="updateRqSections()">
            <option value="all">全部章節</option>
          </select>
          <label>小節：</label>
          <select id="rq-section-filter">
            <option value="all">全部小節</option>
          </select>
          <button class="btn-go" onclick="startReaderQuiz()"><span class='btn-icon'><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3" fill="currentColor" stroke="none" opacity=".9"/></svg> 開始練習</span></button>
          <button class="btn-reset" onclick="resetReaderQuiz()"><span class='btn-icon'><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg> 重置</span></button>
          <span id="rq-stat" style="font-size:.8rem;color:var(--gray);margin-left:auto;"></span>
        </div>
        <div class="prog-bar-wrap" id="rq-prog-wrap" style="display:none;">
          <div class="prog-bar-outer"><div class="prog-bar-inner" id="rq-prog" style="width:0%"></div></div>
          <div class="prog-txt"><span id="rq-prog-txt">0 / 0 題</span><span id="rq-score-txt"></span></div>
        </div>
        <div id="rq-area">
          <p style="text-align:center;color:var(--gray);padding:40px;font-size:.9rem;">選擇章節後按「開始練習」進行隨堂測驗</p>
        </div>
      </div>
      <button id="mobile-toc-btn" onclick="toggleMobileToc()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg></button>
      <div id="mobile-toc-panel"></div>
    </div>

    <!-- ══ NOTES PAGE ════════════════════════ -->
    <div id="page-notes" class="page">
      <div class="filter-bar" id="notes-filters"></div>
      <div class="cards-grid" id="notes-cards"></div>
    </div>

    <!-- ══ QUIZ PAGE ═════════════════════════ -->
    <div id="page-quiz" class="page">
      <div class="quiz-controls">
        <label>年次篩選：</label>
        <select id="quiz-exam-filter">
          <option value="all">全部年次</option>
          <option value="113-1">113-1</option><option value="113-2">113-2</option>
          <option value="113-3">113-3</option><option value="113-4">113-4</option>
          <option value="113-5">113-5</option>
          <option value="114-1">114-1</option><option value="114-2">114-2</option>
          <option value="114-3">114-3</option><option value="114-4">114-4</option>
          <option value="114-4高雄">114-4高雄</option>
          <option value="114-5">114-5</option><option value="114-6">114-6</option>
          <option value="115-1">115-1</option>
        </select>
        <label>題數：</label>
        <select id="quiz-count">
          <option value="20">20 題</option>
          <option value="40">40 題</option>
          <option value="80">80 題</option>
          <option value="999">全部</option>
        </select>
        <label>順序：</label>
        <select id="quiz-order">
          <option value="rand">隨機</option>
          <option value="seq">依序</option>
        </select>
        <button class="btn-go" onclick="startQuiz()"><span class='btn-icon'><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3" fill="currentColor" stroke="none" opacity=".9"/></svg> 開始練習</span></button>
        <button class="btn-reset" onclick="resetQuiz()"><span class='btn-icon'><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg> 重置</span></button>
        <span id="quiz-stat" style="font-size:.8rem;color:var(--gray);margin-left:auto;"></span>
      </div>
      <div class="prog-bar-wrap" id="quiz-prog-wrap" style="display:none;">
        <div class="prog-bar-outer"><div class="prog-bar-inner" id="quiz-prog" style="width:0%"></div></div>
        <div class="prog-txt"><span id="quiz-prog-txt">0 / 0 題</span><span id="quiz-score-txt"></span></div>
      </div>
      <div id="quiz-area">
        <p style="text-align:center;color:var(--gray);padding:40px;font-size:.9rem;">選擇設定後按「開始練習」</p>
      </div>
    </div>

    <!-- ══ EXAM PAGE ══════════════════════════ -->
    <div id="page-exam" class="page">
      <div id="exam-setup">
        <div class="quiz-controls">
          <span style="font-weight:700;color:var(--green);display:inline-flex;align-items:center;gap:5px;"><span style="display:inline-flex;width:18px;height:18px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="4" rx="1"/><path d="M5 4h-1a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2h-1"/><polyline points="9 12 11 14 15 10"/></svg></span> 模擬考試</span>
          <label>題數：</label>
          <select id="exam-count">
            <option value="80">80 題（正式考試）</option>
            <option value="40">40 題（半場）</option>
            <option value="20">20 題（快速）</option>
          </select>
          <button class="btn-go" onclick="startExam()"><span class='btn-icon'><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3" fill="currentColor" stroke="none" opacity=".9"/></svg> 開始計時考試</span></button>
        </div>
        <div style="background:var(--op);border-radius:var(--radius);padding:16px 20px;margin-top:12px;font-size:.88rem;line-height:1.8;color:#5d4037;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> 考試時間：<strong>90 分鐘</strong> · 每題 1.25 分 · 滿分 100 分 · <strong>70 分</strong>合格<br>出題來源：歷屆1040 + 永續題庫1336 + 隨堂練習621，去重後約 2200 題 · 依官方比例 第一章27% · 第二章33% · 第三章14% · 第四章26%<br>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> 考試期間不顯示答案，交卷後才顯示完整成績單與解析
        </div>
        <div id="exam-history-summary" style="margin-top:12px;"></div>
      </div>
      <div id="exam-running" style="display:none;">
        <div class="exam-timer">
          <span>模擬考試 <span id="exam-q-count"></span></span>
          <span id="exam-timer" class="timer-display">90:00</span>
          <button onclick="submitExam()" style="padding:6px 16px;border-radius:8px;border:none;background:var(--red);color:#fff;cursor:pointer;font-weight:700;font-size:.85rem;">交卷</button>
        </div>
        <div class="prog-bar-wrap">
          <div class="prog-bar-outer"><div class="prog-bar-inner" id="exam-prog" style="width:0%"></div></div>
          <div class="prog-txt"><span id="exam-prog-txt"></span><span id="exam-answered-txt"></span></div>
        </div>
        <div id="exam-area"></div>
        <div class="q-nav" style="margin-top:8px;">
          <button class="btn-prev" onclick="examPrev()">← 上一題</button>
          <span id="exam-pos-txt" style="font-size:.83rem;color:var(--gray);"></span>
          <button class="btn-next" onclick="examNext()">下一題 →</button>
        </div>
      </div>
      <div id="exam-result" style="display:none;"></div>
    </div>

    <!-- ══ PROGRESS PAGE ═════════════════════ -->
    <div id="page-progress" class="page">
      <!-- 統計卡片列 -->
      <div id="prog-stats-row" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;"></div>

      <div class="progress-grid">
        <div class="prog-card">
          <h3>總體正確率</h3>
          <div class="donut-wrap" id="donut-overall"></div>
          <p id="overall-desc" style="text-align:center;font-size:.83rem;color:var(--gray);margin-top:8px;"></p>
          <p id="overall-desc-sub" style="text-align:center;font-size:.72rem;color:var(--gray);opacity:.7;margin-top:2px;"></p>
        </div>
        <div class="prog-card">
          <h3>練習紀錄</h3>
          <div id="history-list"></div>
        </div>
      </div>

      <!-- 趨勢折線圖 -->
      <div class="prog-card" style="margin-bottom:16px;">
        <h3><span style="display:inline-flex;width:18px;height:18px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></span> 正確率趨勢</h3>
        <div id="prog-trend-chart" style="position:relative;height:140px;"></div>
        <p id="prog-trend-note" style="font-size:.73rem;color:var(--gray);margin-top:4px;text-align:right;"></p>
      </div>

      <!-- 考點卡片瀏覽進度 -->
      <div class="prog-card" style="margin-bottom:16px;">
        <h3><span style="display:inline-flex;width:18px;height:18px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></span> 考點卡片進度</h3>
        <div id="prog-concepts"></div>
      </div>

      <!-- 章節弱點分析 -->
      <div class="prog-card" style="margin-bottom:16px;">
        <h3><span style="display:inline-flex;width:18px;height:18px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg></span> 章節弱點分析</h3>
        <div id="prog-ch-analysis"></div>
      </div>

      <!-- 備考建議 -->
      <div class="prog-card" style="margin-bottom:16px;">
        <h3><span style="display:inline-flex;width:18px;height:18px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></span> 備考建議</h3>
        <div id="prog-advice"></div>
      </div>

      <!-- 歷屆考題章節占比分析 -->
      <div class="prog-card" style="margin-bottom:16px;padding:0;overflow:hidden;">
        <div id="exam-analysis-header"
          onclick="(()=>{window._examAnalysisOpen=window._examAnalysisOpen===false?true:!window._examAnalysisOpen;const b=document.getElementById('exam-analysis-body');const ico=document.getElementById('exam-analysis-chevron');const lbl=document.getElementById('exam-analysis-lbl');const open=window._examAnalysisOpen!==false;b.style.display=open?'block':'none';ico.style.transform=open?'rotate(0deg)':'rotate(-90deg)';lbl.textContent=open?'收合':'展開';})()"
          style="display:flex;align-items:center;justify-content:space-between;cursor:pointer;padding:16px 20px;user-select:none;-webkit-user-select:none;border-bottom:1.5px solid var(--border);transition:background .15s;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span style="display:inline-flex;width:18px;height:18px;flex-shrink:0;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
              </svg>
            </span>
            <h3 style="margin:0;font-size:.9rem;font-weight:700;color:var(--gray);text-transform:uppercase;letter-spacing:.5px;">歷屆考題章節占比</h3>
          </div>
          <div style="display:flex;align-items:center;gap:5px;color:#999;">
            <span id="exam-analysis-lbl" style="font-size:.68rem;">收合</span>
            <span id="exam-analysis-chevron" style="display:inline-flex;transition:transform .2s;transform:rotate(0deg);">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </div>
        </div>
        <div id="exam-analysis-body" style="display:block;padding:20px;">
          <div id="prog-exam-analysis"></div>
        </div>
      </div>

      <!-- 成就徽章 -->
      <div class="prog-card" style="margin-bottom:16px;">
        <h3><span style="display:inline-flex;width:18px;height:18px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg></span> 成就徽章</h3>
        <div id="prog-badges" style="display:flex;flex-wrap:wrap;gap:10px;"></div>
      </div>

      <div style="text-align:center;margin-top:16px;padding-top:16px;border-top:1px solid var(--border);">
        <p style="font-size:.78rem;color:var(--gray);margin-bottom:8px;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 清除後無法復原，所有練習紀錄將永久刪除</p>
        <button onclick="clearProgress()" style="padding:6px 16px;border-radius:8px;border:1px solid #e0e0e0;background:#fff;color:var(--gray);cursor:pointer;font-size:.78rem;">清除所有進度</button>
      </div>
    </div>


    <!-- ══ CHEATSHEET PAGE ══════════════════════════ -->
    




    <!-- ══ PODCAST PAGE ════════════════════════ -->
    <div id="page-podcast" class="page">

      <!-- 頂部播放器（固定） -->
      <div id="pod-top">
        <div class="pod-top-main">
          <div class="pod-cover-art" id="pod-cover"><svg viewBox="0 0 60 60" fill="none"><defs><linearGradient id="pod-cd" x1="0" y1="0" x2="60" y2="60"><stop stop-color="#b8e4d0"/><stop offset="1" stop-color="#2e7a52"/></linearGradient></defs><rect width="60" height="60" rx="14" fill="url(#pod-cd)"/><path d="M22 38 L22 22 L40 30 Z" fill="white" opacity=".85"/></svg></div>
          <div class="pod-top-info">
            <div class="pod-top-label" id="pod-top-label">Podcast 聆聽</div>
            <div class="pod-top-title" id="pod-top-title">選擇一集開始聆聽</div>
            <div class="pod-top-sub" id="pod-top-sub"></div>
          </div>
          <div class="pod-top-ctrl">
            <button class="pod-ctrl-btn" onclick="podSkip(-15)" title="倒退15秒"><span class="pod-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="19 20 9 12 19 4 19 20"/><line x1="5" y1="4" x2="5" y2="20"/></svg></span><span class="pod-btn-label">15s</span></button>
            <button class="pod-ctrl-btn pod-play-main" id="pod-play-btn" onclick="podToggle()"><span id="pod-play-icon" class="pod-icon"><svg viewBox="0 0 24 24" fill="none"><polygon points="9,7 19,12 9,17" fill="currentColor"/></svg></span></button>
            <button class="pod-ctrl-btn" onclick="podSkip(30)" title="快進30秒"><span class="pod-btn-label">30s</span><span class="pod-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="4" x2="19" y2="20"/></svg></span></button>
          </div>
        </div>

        <!-- 進度列 -->
        <div class="pod-progress-wrap">
          <div class="pod-prog-bar" id="pod-bar" onclick="podSeekBar(event)">
            <div class="pod-prog-fill" id="pod-fill"></div>
          </div>
          <div class="pod-prog-times">
            <span id="pod-cur">0:00</span>
            <span id="pod-dur">0:00</span>
          </div>
        </div>

        <!-- 工具列：播放模式 + 倍速 + 背景播放 + 音量 -->
        <div class="pod-top-tools">
          <!-- 播放模式 -->
          <button class="pod-mode-btn on" id="pod-mode-btn" onclick="podCycleMode()" title="播放模式"><span id="pod-mode-icon" class="pod-icon pod-icon-sm"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="5 12 19 12"/><polyline points="15 8 20 12 15 16"/></svg></span><span id="pod-mode-txt">接續</span></button>

          <!-- 倍速 -->
          <div class="pod-speed-wrap-top" id="pod-sw">
            <button class="pod-speed-btn-top" id="pod-spd" onclick="podToggleSpeed()">1x</button>
            <div class="pod-speed-menu-top" id="pod-spm">
              <div class="pod-speed-opt" onclick="podSetSpeed(0.75)">0.75x</div>
              <div class="pod-speed-opt cur" onclick="podSetSpeed(1)">1x</div>
              <div class="pod-speed-opt" onclick="podSetSpeed(1.25)">1.25x</div>
              <div class="pod-speed-opt" onclick="podSetSpeed(1.5)">1.5x</div>
              <div class="pod-speed-opt" onclick="podSetSpeed(2)">2x</div>
            </div>
          </div>

          <!-- 音量（桌機） -->
          <div class="pod-vol-wrap">
            <span class="pod-vol-icon pod-icon pod-icon-sm" id="pod-vol-icon" onclick="podMuteToggle()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 010 7.07"/><path d="M19.07 4.93a10 10 0 010 14.14"/></svg></span>
            <input type="range" class="pod-vol-slider" id="pod-vol"
                   min="0" max="1" step="0.05" value="1"
                   oninput="podSetVol(this.value)">
          </div>

          <!-- 背景播放 -->
          <div class="pod-bg-wrap">
            <span class="pod-bg-label">背景播放</span>
            <button class="pod-toggle on" id="pod-bg-btn" onclick="podToggleBg()" title="背景播放（切換其他頁面繼續播放）"></button>
          </div>
        </div>
      </div>

      <!-- 集數列表 -->
      <div class="pod-list" id="pod-list">
        <div class="pod-list-header">
          <span class="pod-list-title">全部集數</span>
          <span class="pod-list-count" id="pod-count"></span>
        </div>
        <div id="pod-ep-list"></div>
      </div>

      <audio id="pod-audio" preload="metadata"></audio>
    </div>

    <!-- ══ TEXTBOOK PAGE ════════════════════════ -->
    <div id="page-textbook" class="page">
      <div class="tb-header">
        <h2><span style="display:inline-flex;width:22px;height:22px;margin-right:6px;color:var(--green);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="9" y1="12" x2="13" y2="12"/></svg></span>官方課本題庫</h2>
        <p>永續發展相關規範與實務 · 章節練習題，含解析</p>
      </div>

      <div class="tb-controls">
        <label>章節：</label>
        <select id="tb-chapter-filter" onchange="initTextbook()">
          <option value="all">全部章節</option>
          <option value="官方第一章">第一章 永續基本概念</option>
          <option value="官方第二章">第二章 永續資訊揭露</option>
          <option value="官方第三章">第三章 永續風險管理與治理</option>
          <option value="官方第四章">第四章 永續金融</option>
        </select>
        <label style="margin-left:8px">順序：</label>
        <select id="tb-order">
          <option value="seq">依序</option>
          <option value="rand">隨機</option>
        </select>
        <button class="tb-btn-start" onclick="startTextbook()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="12" height="12" fill="#89b4d4" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="5 3 19 12 5 21 5 3"/></svg> 開始練習</button>
        <span id="tb-count-label" style="font-size:.8rem;color:var(--gray);margin-left:auto;"></span>
      </div>

      <div id="tb-quiz-area" style="display:none;">
        <div class="tb-q-area">
          <div class="tb-progress">
            <span id="tb-prog-text"></span>
            <span id="tb-score-text" style="color:var(--green);font-weight:700;"></span>
          </div>
          <div class="tb-progress-bar"><div class="tb-progress-bar-fill" id="tb-prog-bar"></div></div>
          <div id="tb-dep-banner" style="display:none;align-items:flex-start;gap:10px;background:#fdf0e0;border-bottom:2px solid #c87848;padding:12px 16px;font-size:13px;color:#633806;line-height:1.5;border-radius:8px 8px 0 0;margin-bottom:0;"><svg style="width:16px;height:16px;flex-shrink:0;margin-top:1px;" viewBox="0 0 24 24" fill="none" stroke="#c87848" stroke-width="2" stroke-linecap="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><div><div style="font-weight:500;color:#412402;margin-bottom:2px;">此題已停用 <span style="display:inline-flex;align-items:center;background:#c87848;color:#fff;font-size:10px;font-weight:500;padding:2px 8px;border-radius:10px;margin-left:4px;">114年勘誤</span></div><div style="font-size:12px;color:#854F0B;">官方已刪除，考試不會出現，仍可練習參考。</div></div></div>
          <div class="tb-stem" id="tb-stem"></div>
          <div class="tb-opts" id="tb-opts"></div>
          <div id="tb-confirm-area"></div>
          <div class="tb-explanation" id="tb-explanation"></div>
        </div>
        <div class="tb-nav">
          <button class="tb-btn-prev" id="tb-prev-btn" onclick="tbPrev()" style="display:none;">← 上一題</button>
          <button class="tb-btn-next" id="tb-next-btn" onclick="tbNext()" style="display:none;">下一題 →</button>
        </div>
      </div>

      <div id="tb-result" class="tb-result" style="display:none;">
        <div class="tb-score-circle">
          <div class="score-num" id="tb-final-score"></div>
          <div class="score-label">答對率</div>
        </div>
        <h3 id="tb-final-title" style="font-size:1.1rem;margin-bottom:8px;"></h3>
        <div class="tb-stat-row">
          <div class="tb-stat"><div class="n" id="tb-stat-correct"></div><div class="l">答對</div></div>
          <div class="tb-stat"><div class="n" id="tb-stat-wrong" style="color:var(--red)"></div><div class="l">答錯</div></div>
          <div class="tb-stat"><div class="n" id="tb-stat-skip" style="color:var(--gray)"></div><div class="l">未作答</div></div>
          <div class="tb-stat"><div class="n" id="tb-stat-total" style="color:var(--gray)"></div><div class="l">總題數</div></div>
        </div>
        <button onclick="startTextbook()" style="background:var(--blue);color:#fff;border:none;padding:10px 28px;border-radius:10px;font-family:var(--font);font-weight:700;cursor:pointer;font-size:.9rem;">再練一次</button>
      </div>
    </div>

   
      

    <div class="page" id="page-charts">
  <div class="charts-page-wrap">
    <div class="charts-header">
      <h2><span style="display:inline-flex;width:22px;height:22px;margin-right:6px;color:var(--green);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg></span>圖表總覽</h2>
      <p>從課文內容萃取的 28 張學習圖表，幫助理解抽象概念與數字關係</p>
      <div class="chart-filters">
        <button class="chip active" onclick="filterCharts(this,'all')" data-ch="all">全部</button>
        <button class="chip" onclick="filterCharts(this,'ch1')" data-ch="ch1">第一章</button>
        <button class="chip" onclick="filterCharts(this,'ch2')" data-ch="ch2">第二章</button>
        <button class="chip" onclick="filterCharts(this,'ch3')" data-ch="ch3">第三章</button>
        <button class="chip" onclick="filterCharts(this,'ch4')" data-ch="ch4">第四章</button>
      </div>
    </div>
    <div class="charts-grid">
      <div class="chart-card" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>永續金融範疇 — 由小至大</h3></div><div class="chart-body">
<div class="fin-stack">
  <div class="fin-tier ft4">
    <span class="fin-tier-name"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#89b4d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> 永續金融</span>
    <span class="fin-tier-desc">環境＋社會＋<b style="color:#ffcc80">經濟</b>＋治理</span>
  </div>
  <div style="text-align:center;font-size:.65rem;color:#aaa;line-height:1.2;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="12" height="12" fill="#c88a50" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 22 22 2 22"/></svg> 包含</div>
  <div class="fin-tier ft3">
    <span class="fin-tier-name"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M17 8C8 10 5.9 16.17 3.82 22"/><path d="M2 16s3-1 6-3c3.5-2.3 4.5-5 4.5-5S10 13 8 15c-2.1 2.1-6 3-6 3z"/><path d="M22 2s-5 2-8 7c-2.3 3.5-2 7-2 7s2-3.5 5-6c3.1-2.6 5-8 5-8z"/></svg> 綠色金融</span>
    <span class="fin-tier-desc">降碳＋氣候調適＋其他環境議題</span>
  </div>
  <div style="text-align:center;font-size:.65rem;color:#aaa;line-height:1.2;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="12" height="12" fill="#c88a50" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 22 22 2 22"/></svg> 包含</div>
  <div class="fin-tier ft2">
    <span class="fin-tier-name"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg> 氣候金融</span>
    <span class="fin-tier-desc">降低碳排＋減少氣候衝擊</span>
  </div>
  <div style="text-align:center;font-size:.65rem;color:#aaa;line-height:1.2;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="12" height="12" fill="#c88a50" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 22 22 2 22"/></svg> 包含</div>
  <div class="fin-tier ft1">
    <span class="fin-tier-name"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><rect x="1" y="6" width="18" height="12" rx="2" ry="2"/><line x1="23" y1="13" x2="23" y2="11"/><line x1="5" y1="10" x2="5" y2="14"/><line x1="10" y1="10" x2="10" y2="14"/></svg> 低碳金融</span>
    <span class="fin-tier-desc">協助降低溫室氣體排放</span>
  </div>
</div>
<div class="fin-unep"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> <b>UNEP 永續金融四面向</b>：環境、社會、<b>經濟</b>、治理（考點：是「經濟」不是「氣候」）</div>
</div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg> 低碳金融 ⊂ 氣候金融 ⊂ 綠色金融 ⊂ 永續金融（由小至大）</div></div>
      <div class="chart-card" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>碳定價三大機制</h3></div><div class="chart-body"><div class="compare-bars"><div class="cb-axis">政府介入程度（高→低）</div><div class="cb-row"><div class="cb-name">課徵碳稅</div><div class="cb-bar-wrap"><div class="cb-bar" style="width:95%;background:#d04555"></div></div><div class="cb-end">最高</div></div><div class="cb-row"><div class="cb-name">碳交易</div><div class="cb-bar-wrap"><div class="cb-bar" style="width:55%;background:#c88a50"></div></div><div class="cb-end">中</div></div><div class="cb-row"><div class="cb-name">企業內部碳定價</div><div class="cb-bar-wrap"><div class="cb-bar" style="width:20%;background:#3fa068"></div></div><div class="cb-end">最低</div></div></div><div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;font-size:.78rem;"><div style="flex:1;min-width:120px;background:#fdf0e0;padding:8px 10px;border-radius:8px;border-left:3px solid #c87848;"><b>碳稅</b>：財政收支，用途不限</div><div style="flex:1;min-width:120px;background:#e2f5ec;padding:8px 10px;border-radius:8px;border-left:3px solid #2e7a52;"><b>碳費（台灣）</b>：特種基金，專款專用</div></div></div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 台灣採碳<b>費</b>（環境部）非碳<b>稅</b>（財政部）；碳費<b>專款專用</b>，碳稅用途不限；自願性碳交易不需政府設排放上限</div></div>
      <div class="chart-card chart-card-wide" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>SDGs 17項永續發展目標</h3></div><div class="chart-body">
<div style="overflow-x:auto;"><table class="sdg-table">
  <thead>
    <tr style="background:#37474f;">
      <th style="width:38px;">#</th>
      <th>目標名稱</th>
      <th>常考細項 / 陷阱</th>
    </tr>
  </thead>
  <tbody>
    <tr><td><span class="sdg-num" style="background:#e5243b">1</span></td><td><b>消除貧窮</b></td><td>微型保單、公益彩券、慈善活動</td></tr>
    <tr><td><span class="sdg-num" style="background:#dda63a">2</span></td><td><b>消除飢餓</b></td><td>永續農業、糧食安全</td></tr>
    <tr><td><span class="sdg-num" style="background:#4c9f38">3</span></td><td><b>健康福祉</b></td><td>減少傳染病、提供基本醫療；外溢保單</td></tr>
    <tr><td><span class="sdg-num" style="background:#c5192d">4</span></td><td><b>優質教育</b></td><td>產學合作（教育難以適性揚才）</td></tr>
    <tr><td><span class="sdg-num" style="background:#ff3a21">5</span></td><td><b>性別平等</b></td><td>消除暴力歧視、婦幼性生殖健康 <span class="sdg-tip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>「確保弱勢社會保障」非此目標</span></td></tr>
    <tr><td><span class="sdg-num" style="background:#26bde2">6</span></td><td><b>淨水衛生</b></td><td>安全飲用水、水資源管理、建立水基礎設施</td></tr>
    <tr><td><span class="sdg-num" style="background:#fcc30b;color:#333">7</span></td><td><b>可負擔能源</b></td><td>增電力供應、增再生能源 <span class="sdg-tip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>「加強科技創新」非此目標</span></td></tr>
    <tr class="sdg-star-row"><td><span class="sdg-num" style="background:#a21942">8</span></td><td><b>就業與經濟 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></b></td><td><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> <b>唯一提到「保險」的永續目標</b>（金融普及）</td></tr>
    <tr><td><span class="sdg-num" style="background:#fd6925">9</span></td><td><b>工業創新基礎</b></td><td>韌性基礎建設、工業永續化</td></tr>
    <tr><td><span class="sdg-num" style="background:#dd1367">10</span></td><td><b>減少不平等</b></td><td>提高弱勢收入、降低貧窮比率 <span class="sdg-tip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>「確保言論自由」非此目標</span></td></tr>
    <tr><td><span class="sdg-num" style="background:#fd9d24;color:#333">11</span></td><td><b>永續城市</b></td><td>可負擔住房、城市韌性；青年安心成家貸款</td></tr>
    <tr><td><span class="sdg-num" style="background:#bf8b2e">12</span></td><td><b>永續消費生產</b></td><td>促進綠色產品 <span class="sdg-tip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>「推動生態旅遊」非此目標</span></td></tr>
    <tr><td><span class="sdg-num" style="background:#3f7e44">13</span></td><td><b>氣候行動</b></td><td>推動氣候相關金融機制與投資</td></tr>
    <tr><td><span class="sdg-num" style="background:#0a97d9">14</span></td><td><b>海洋生態</b></td><td>減少海洋污染、恢復沿岸生態 <span class="sdg-tip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>「建立水基礎設施」屬SDG6</span></td></tr>
    <tr><td><span class="sdg-num" style="background:#56c02b;color:#333">15</span></td><td><b>陸域生態</b></td><td>保護瀕危物種、推動生態旅遊</td></tr>
    <tr><td><span class="sdg-num" style="background:#00689d">16</span></td><td><b>和平正義</b></td><td>防制洗錢、反貪腐</td></tr>
    <tr><td><span class="sdg-num" style="background:#19486a">17</span></td><td><b>全球夥伴關係</b></td><td>促進合作、資金技術援助 <span class="sdg-tip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>「提供可負擔住房」屬SDG11</span></td></tr>
  </tbody>
</table></div>
</div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg> 2015年SDGs（17項169細項）取代2000年MDGs（8項）｜ 紅字 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> 為常見錯誤選項</div></div>
      <div class="chart-card chart-card-wide" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>國際氣候協議里程碑</h3></div><div class="chart-body">
<div class="tl-wrap">
<svg class="tl-svg" viewBox="0 0 760 210" xmlns="http://www.w3.org/2000/svg" font-family="'Microsoft JhengHei','PingFang TC',Arial,sans-serif">

  <!-- 時間軸底線 -->
  <line x1="30" y1="100" x2="730" y2="100" stroke="#b8e4d0" stroke-width="3" stroke-linecap="round"/>

  <!-- 刻度年份 1970~2025，每5年一小刻 -->
  <!-- 比例：1972~2023 = 51年，總寬700px，1年 = 700/51 ≈ 13.73px，起點 x=30 -->
  <!-- x(year) = 30 + (year-1972) * (700/51) -->

  <!-- 小刻度線 1975,1980,1985,1990,1995,2000,2005,2010,2015,2020 -->
  <g stroke="#b0bec5" stroke-width="1">
    <line x1="71"  y1="95" x2="71"  y2="105"/> <!-- 1975 -->
    <line x1="139" y1="95" x2="139" y2="105"/> <!-- 1980 -->
    <line x1="207" y1="95" x2="207" y2="105"/> <!-- 1985 -->
    <line x1="275" y1="95" x2="275" y2="105"/> <!-- 1990 -->
    <line x1="344" y1="95" x2="344" y2="105"/> <!-- 1995 -->
    <line x1="412" y1="95" x2="412" y2="105"/> <!-- 2000 -->
    <line x1="480" y1="95" x2="480" y2="105"/> <!-- 2005 -->
    <line x1="548" y1="95" x2="548" y2="105"/> <!-- 2010 -->
    <line x1="617" y1="95" x2="617" y2="105"/> <!-- 2015 -->
    <line x1="685" y1="95" x2="685" y2="105"/> <!-- 2020 -->
  </g>
  <g fill="#607d8b" font-size="9" text-anchor="middle">
    <text x="71"  y="116">1975</text>
    <text x="139" y="116">1980</text>
    <text x="207" y="116">1985</text>
    <text x="275" y="116">1990</text>
    <text x="344" y="116">1995</text>
    <text x="412" y="116">2000</text>
    <text x="480" y="116">2005</text>
    <text x="548" y="116">2010</text>
    <text x="685" y="116">2020</text>
  </g>

  <!-- ── 事件 1：1972 斯德哥爾摩 x=30 上方 -->
  <line x1="30" y1="100" x2="30" y2="60" stroke="#3fa068" stroke-width="1.5" stroke-dasharray="3,2"/>
  <circle cx="30" cy="100" r="6" fill="#3fa068"/>
  <rect x="4" y="26" width="56" height="16" rx="8" fill="#3fa068"/>
  <text x="32" y="37" fill="white" font-size="9" font-weight="700" text-anchor="middle">1972</text>
  <text x="32" y="56" fill="#1b5c42" font-size="9" font-weight="700" text-anchor="middle">斯德哥爾摩宣言</text>
  <text x="32" y="67" fill="#546e7a" font-size="8" text-anchor="middle">設立 UNEP</text>

  <!-- ── 事件 2：1988 IPCC x=30+(16*13.73)=30+219.7≈250 下方 -->
  <line x1="250" y1="100" x2="250" y2="148" stroke="#3fa068" stroke-width="1.5" stroke-dasharray="3,2"/>
  <circle cx="250" cy="100" r="6" fill="#3fa068"/>
  <rect x="222" y="148" width="56" height="16" rx="8" fill="#3fa068"/>
  <text x="250" y="159" fill="white" font-size="9" font-weight="700" text-anchor="middle">1988</text>
  <text x="250" y="176" fill="#1b5c42" font-size="9" font-weight="700" text-anchor="middle">IPCC 成立</text>
  <text x="250" y="187" fill="#546e7a" font-size="8" text-anchor="middle">WMO × UNEP</text>

  <!-- ── 事件 3：1992 UNFCCC x=30+(20*13.73)=30+274.5≈305 上方 -->
  <line x1="305" y1="100" x2="305" y2="60" stroke="#3fa068" stroke-width="1.5" stroke-dasharray="3,2"/>
  <circle cx="305" cy="100" r="6" fill="#3fa068"/>
  <rect x="277" y="26" width="56" height="16" rx="8" fill="#3fa068"/>
  <text x="305" y="37" fill="white" font-size="9" font-weight="700" text-anchor="middle">1992</text>
  <text x="305" y="56" fill="#1b5c42" font-size="9" font-weight="700" text-anchor="middle">UNFCCC</text>
  <text x="305" y="67" fill="#546e7a" font-size="8" text-anchor="middle">里約地球高峰會</text>

  <!-- ── 事件 4：1997 京都 x=30+(25*13.73)=30+343.1≈373 下方 -->
  <line x1="373" y1="100" x2="373" y2="148" stroke="#3fa068" stroke-width="1.5" stroke-dasharray="3,2"/>
  <circle cx="373" cy="100" r="6" fill="#3fa068"/>
  <rect x="345" y="148" width="56" height="16" rx="8" fill="#3fa068"/>
  <text x="373" y="159" fill="white" font-size="9" font-weight="700" text-anchor="middle">1997</text>
  <text x="373" y="176" fill="#1b5c42" font-size="9" font-weight="700" text-anchor="middle">京都議定書</text>
  <text x="373" y="187" fill="#546e7a" font-size="8" text-anchor="middle">COP3，已開發國家減排</text>

  <!-- ── 事件 5：2015 巴黎協定 x=30+(43*13.73)=30+590.3≈620 上方 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> 重點 -->
  <line x1="620" y1="100" x2="620" y2="50" stroke="#c87848" stroke-width="2"/>
  <circle cx="620" cy="100" r="8" fill="#c87848"/>
  <text x="620" y="104" fill="white" font-size="9" font-weight="900" text-anchor="middle"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></text>
  <rect x="588" y="16" width="64" height="16" rx="8" fill="#c87848"/>
  <text x="620" y="27" fill="white" font-size="9" font-weight="700" text-anchor="middle">2015 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></text>
  <text x="620" y="44" fill="#b86840" font-size="9" font-weight="800" text-anchor="middle">巴黎協定</text>
  <text x="620" y="55" fill="#546e7a" font-size="8" text-anchor="middle">首涵蓋所有國家 &lt;2°C</text>

  <!-- ── 事件 6：2021 格拉斯哥 x=30+(49*13.73)=30+672.8≈703 下方 -->
  <line x1="703" y1="100" x2="703" y2="148" stroke="#3fa068" stroke-width="1.5" stroke-dasharray="3,2"/>
  <circle cx="703" cy="100" r="6" fill="#3fa068"/>
  <rect x="675" y="148" width="56" height="16" rx="8" fill="#3fa068"/>
  <text x="703" y="159" fill="white" font-size="9" font-weight="700" text-anchor="middle">2021</text>
  <text x="703" y="176" fill="#1b5c42" font-size="9" font-weight="700" text-anchor="middle">格拉斯哥協議</text>
  <text x="703" y="187" fill="#546e7a" font-size="8" text-anchor="middle">逐步減煤，甲烷承諾</text>

  <!-- ── 事件 7：2023 COP28 x=30+(51*13.73)=30+700=730 上方 -->
  <line x1="730" y1="100" x2="730" y2="60" stroke="#3fa068" stroke-width="1.5" stroke-dasharray="3,2"/>
  <circle cx="730" cy="100" r="6" fill="#3fa068"/>
  <rect x="702" y="26" width="56" height="16" rx="8" fill="#3fa068"/>
  <text x="730" y="37" fill="white" font-size="9" font-weight="700" text-anchor="middle">2023</text>
  <text x="730" y="56" fill="#1b5c42" font-size="9" font-weight="700" text-anchor="middle">COP28</text>
  <text x="730" y="67" fill="#546e7a" font-size="8" text-anchor="middle">再生能源 ×3倍</text>

  <!-- 間距標註：1972→1988 = 16年 -->
  <line x1="30" y1="128" x2="250" y2="128" stroke="#b0bec5" stroke-width="1" marker-end="url(#arr)" marker-start="url(#arr)"/>
  <text x="140" y="138" fill="#90a4ae" font-size="8" text-anchor="middle">16 年</text>

  <!-- 間距標註：1988→1992 = 4年 -->
  <line x1="250" y1="128" x2="305" y2="128" stroke="#b0bec5" stroke-width="1"/>
  <text x="277" y="138" fill="#90a4ae" font-size="8" text-anchor="middle">4年</text>

  <!-- 間距標註：1997→2015 = 18年 -->
  <line x1="373" y1="128" x2="620" y2="128" stroke="#b0bec5" stroke-width="1"/>
  <text x="496" y="138" fill="#90a4ae" font-size="8" text-anchor="middle">── 18 年的空白 ──</text>

</svg>
</div>
</div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> 巴黎協定首次涵蓋所有國家，NDCs每5年更新 ｜ 注意 1972→1988 間隔16年、1988→1992僅4年、1997→2015長達18年</div></div>
      <div class="chart-card" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>綠色金融行動方案演進</h3></div><div class="chart-body"><canvas id="chart-gfa" height="180"></canvas></div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg> 4.0新增「提升國際影響力」為第六大推動面向</div></div>
      <div class="chart-card" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>淨零排放 vs 碳中和</h3></div><div class="chart-body">
<div class="nz-grid">
  <div class="nz-box nz-zero">
    <div class="nz-head"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#89b4d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg> 淨零排放（Net Zero）</div>
    <div class="nz-body">
      <div class="nz-row"><span class="nz-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></span><div>涵蓋<b>所有溫室氣體</b>（CO₂、CH₄、N₂O等）</div></div>
      <div class="nz-row"><span class="nz-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 6l9-3 9 3"/><path d="M3 18l9-3 9 3"/><line x1="3" y1="12" x2="21" y2="12"/></svg></span><div>排放量最小化 ＋ 技術/自然碳匯移除<br>使排放量 <b>= 0</b></div></div>
      <div class="nz-row"><span class="nz-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></span><div>目標年：<b>2050年</b>（台灣/全球）</div></div>
      <span class="nz-trap"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 範圍更廣，不只 CO₂</span>
    </div>
  </div>
  <div class="nz-box nz-neutral">
    <div class="nz-head"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#4a9480" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2"/></svg> 碳中和（Carbon Neutral）</div>
    <div class="nz-body">
      <div class="nz-row"><span class="nz-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg></span><div>僅針對<b>二氧化碳（CO₂）</b></div></div>
      <div class="nz-row"><span class="nz-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 6l9-3 9 3"/><path d="M3 18l9-3 9 3"/><line x1="3" y1="12" x2="21" y2="12"/></svg></span><div>透過減量、移除、抵換<br>使 CO₂ 排放<b>正負抵銷</b></div></div>
      <div class="nz-row"><span class="nz-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#89b4d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><line x1="9" y1="22" x2="9" y2="17"/><line x1="15" y1="22" x2="15" y2="17"/><rect x="8" y="17" width="8" height="5"/><rect x="8" y="7" width="3" height="3"/><rect x="13" y="7" width="3" height="3"/><rect x="8" y="12" width="3" height="3"/><rect x="13" y="12" width="3" height="3"/></svg></span><div>企業常用，範圍較窄</div></div>
      <span class="nz-trap"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 碳中和 ⊂ 淨零排放</span>
    </div>
  </div>
</div>
</div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 考試陷阱：淨零排放包含所有溫室氣體；碳中和只針對CO₂。兩者不可混用</div></div>
      <div class="chart-card chart-card-wide" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>臺灣 2050 淨零排放路徑</h3></div><div class="chart-body">
<style>
.nzr-wrap{display:flex;flex-direction:column;gap:10px;}
.nzr-title{font-size:.75rem;font-weight:800;color:#666;letter-spacing:.05em;text-transform:uppercase;margin-bottom:2px;}
.nzr-row{display:grid;gap:8px;}
.nzr-4{grid-template-columns:repeat(4,1fr);}
.nzr-2{grid-template-columns:repeat(2,1fr);}
.nzr-12{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;}
.nzr-box{border-radius:9px;padding:9px 10px;font-size:.74rem;line-height:1.5;}
.nzr-box b{display:block;font-size:.78rem;margin-bottom:3px;}
.nzr-strat{background:#e2f5ec;border:1.5px solid #b8e4d0;}
.nzr-strat b{color:#1b5c42;}
.nzr-gov{background:#fdf0e0;border:1.5px solid #ffcc80;}
.nzr-gov b{color:#c87848;}
.nzr-key{background:#e8f2f9;border:1.5px solid #90caf9;font-size:.7rem;padding:6px 8px;}
.nzr-key b{color:#89b4d4;font-size:.72rem;}
</style>
<div class="nzr-wrap">
  <div>
    <div class="nzr-title">四大轉型策略</div>
    <div class="nzr-row nzr-4">
      <div class="nzr-box nzr-strat"><b><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><rect x="1" y="6" width="18" height="12" rx="2" ry="2"/><line x1="23" y1="13" x2="23" y2="11"/><line x1="5" y1="10" x2="5" y2="14"/><line x1="10" y1="10" x2="10" y2="14"/></svg> 能源轉型</b>最大化再生能源、逐步去煤、零碳化火力發電</div>
      <div class="nzr-box nzr-strat"><b><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#546e7a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M2 20V8l6 4V8l6 4V8l6 4v8H2z"/><line x1="2" y1="20" x2="22" y2="20"/></svg> 產業轉型</b>製程改善、能源轉換、循環經濟（三大面向）</div>
      <div class="nzr-box nzr-strat"><b><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#4e342e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/><path d="M22 20H2"/></svg> 生活轉型</b>使用取代擁有、淨零循環建築、零浪費低碳飲食</div>
      <div class="nzr-box nzr-strat"><b><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#4a9480" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 7.65l.88.89 7.54 7.56 7.54-7.56.89-.89a5.4 5.4 0 0 0 0-7.65z"/></svg> 社會轉型</b>兼顧公平性、建立支持體系、公私協力提高韌性</div>
    </div>
  </div>
  <div>
    <div class="nzr-title">兩大治理基礎</div>
    <div class="nzr-row nzr-2">
      <div class="nzr-box nzr-gov"><b><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#8872b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="2" y1="22" x2="22" y2="22"/><line x1="8" y1="22" x2="8" y2="16"/><line x1="12" y1="22" x2="12" y2="8"/><line x1="16" y1="22" x2="16" y2="14"/><path d="M8 16l4-4 4 4"/><path d="M14 3L6 11l2 2 8-8-2-2z"/></svg> 科技研發</b>碳捕捉、儲能、氫能等關鍵技術</div>
      <div class="nzr-box nzr-gov"><b><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><line x1="12" y1="3" x2="12" y2="21"/><path d="M3 6l9-3 9 3"/><path d="M3 18l9-3 9 3"/><line x1="3" y1="12" x2="21" y2="12"/></svg> 氣候法制</b>氣候變遷因應法、碳費等制度建構</div>
    </div>
  </div>
  <div>
    <div class="nzr-title">十二項關鍵戰略</div>
    <div class="nzr-12">
      <div class="nzr-box nzr-key"><b>風電/光電</b></div>
      <div class="nzr-box nzr-key"><b>氫能</b></div>
      <div class="nzr-box nzr-key"><b>前瞻能源</b></div>
      <div class="nzr-box nzr-key"><b>電力系統與儲能</b></div>
      <div class="nzr-box nzr-key"><b>節能</b></div>
      <div class="nzr-box nzr-key"><b>碳捕捉利用及封存</b></div>
      <div class="nzr-box nzr-key"><b>運具電動化及無碳化</b></div>
      <div class="nzr-box nzr-key"><b>資源循環零廢棄</b></div>
      <div class="nzr-box nzr-key"><b>自然碳匯</b></div>
      <div class="nzr-box nzr-key"><b>淨零綠生活</b></div>
      <div class="nzr-box nzr-key" style="background:#fdf0e0;border-color:#ffcc80;"><b style="color:#c87848;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><circle cx="12" cy="12" r="8" fill="#d4a56a" stroke="none"/></svg> 綠色金融</b></div>
      <div class="nzr-box nzr-key"><b>公正轉型</b></div>
    </div>
  </div>
</div>
</div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 考點：十二項關鍵戰略包含「綠色金融」（非數位/智慧金融）；產業轉型三大面向 = 製程改善、能源轉換、循環經濟</div></div>
      <div class="chart-card" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>京都議定書 vs 巴黎協定</h3></div><div class="chart-body">
<div style="overflow-x:auto;"><table class="kp-tbl">
  <thead><tr>
    <th class="kp-label" style="background:#455a64;width:90px;">比較項目</th>
    <th style="background:#89b4d4;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#4e342e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> 京都議定書（1997 COP3）</th>
    <th style="background:#1b5c42;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M17 8C8 10 5.9 16.17 3.82 22"/><path d="M2 16s3-1 6-3c3.5-2.3 4.5-5 4.5-5S10 13 8 15c-2.1 2.1-6 3-6 3z"/><path d="M22 2s-5 2-8 7c-2.3 3.5-2 7-2 7s2-3.5 5-6c3.1-2.6 5-8 5-8z"/></svg> 巴黎協定（2015 COP21）<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></th>
  </tr></thead>
  <tbody>
    <tr><td class="kp-label">約束力</td><td>具國際<b>約束力</b>（強制）</td><td>更具<b>約束力</b>，NDC每5年更新</td></tr>
    <tr><td class="kp-label">適用對象</td><td>僅<b>已開發國家</b>（附件一）</td><td><b>所有國家</b>（含開發中）</td></tr>
    <tr><td class="kp-label">治理模式</td><td>由上而下管制</td><td>由下而上（各國NDC自訂）</td></tr>
    <tr><td class="kp-label">溫度目標</td><td>無明確溫控目標</td><td>&lt;2°C，致力&lt;<b>1.5°C</b></td></tr>
    <tr><td class="kp-label">碳市場</td><td>清潔發展機制（CDM）</td><td>第六條碳市場規則</td></tr>
    <tr><td class="kp-label">責任原則</td><td colspan="2" style="text-align:center;">共同但有區別的責任（CBDR）</td></tr>
  </tbody>
</table></div>
</div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 巴黎協定 = 第一個涵蓋所有國家的氣候協定，比京都更具約束力</div></div>
      <div class="chart-card" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>CBAM 碳邊境調整機制時程</h3></div><div class="chart-body">
<style>
.cbam-wrap{display:flex;flex-direction:column;gap:10px;}
.cbam-tl{display:flex;flex-direction:column;gap:0;}
.cbam-item{display:flex;gap:12px;align-items:stretch;}
.cbam-dot-col{display:flex;flex-direction:column;align-items:center;width:36px;flex-shrink:0;}
.cbam-dot{width:14px;height:14px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.cbam-line{width:2px;flex:1;background:#cfd8dc;margin:2px 0;}
.cbam-body{padding:8px 0 14px;}
.cbam-year{font-size:.82rem;font-weight:800;}
.cbam-desc{font-size:.74rem;color:#546e7a;line-height:1.6;margin-top:2px;}
.cbam-badge{display:inline-block;padding:1px 8px;border-radius:10px;font-size:.68rem;font-weight:700;margin-left:6px;}
.cbam-ind{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-top:8px;}
.cbam-ind-box{background:#fdf0e0;border:1.5px solid #ffcc80;border-radius:8px;padding:6px 4px;text-align:center;font-size:.7rem;font-weight:700;color:#c87848;}
</style>
<div class="cbam-wrap">
  <div class="cbam-tl">
    <div class="cbam-item">
      <div class="cbam-dot-col"><div class="cbam-dot" style="background:#c8906a;"></div><div class="cbam-line"></div></div>
      <div class="cbam-body"><div class="cbam-year">2023.10 <span class="cbam-badge" style="background:#fdf0e0;color:#c87848;">試行期</span></div><div class="cbam-desc">過渡期開始。進口商每季提交CBAM報告，<b>不需採購憑證</b></div></div>
    </div>
    <div class="cbam-item">
      <div class="cbam-dot-col"><div class="cbam-dot" style="background:#fbc02d;"></div><div class="cbam-line"></div></div>
      <div class="cbam-body"><div class="cbam-year">2025.12 <span class="cbam-badge" style="background:#fffde7;color:#d4a56a;">過渡期結束</span></div><div class="cbam-desc">每年5/31前申報前一年進口資料</div></div>
    </div>
    <div class="cbam-item">
      <div class="cbam-dot-col"><div class="cbam-dot" style="background:#c62828;"></div></div>
      <div class="cbam-body"><div class="cbam-year">2026.1 <span class="cbam-badge" style="background:#ffebee;color:#c62828;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#c62828" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><circle cx="12" cy="12" r="8" fill="#c62828" stroke="none"/></svg> 正式收費</span></div><div class="cbam-desc">進口商須購買<b>CBAM憑證</b>，補足與EU ETS碳價的差額（碳關稅）</div></div>
    </div>
  </div>
  <div>
    <div style="font-size:.72rem;font-weight:700;color:#666;margin-bottom:6px;">納入CBAM的五大高碳排產業：</div>
    <div class="cbam-ind">
      <div class="cbam-ind-box"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#546e7a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M12 22v-4"/><path d="M12 6V2"/><circle cx="12" cy="12" r="4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/></svg> 鋼鐵</div>
      <div class="cbam-ind-box"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><rect x="2" y="6" width="20" height="8" rx="1"/><path d="M17 14v7"/><path d="M7 14v7"/><path d="M17 3h.01"/><path d="M7 3h.01"/></svg> 水泥</div>
      <div class="cbam-ind-box"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M17 8C8 10 5.9 16.17 3.82 22"/><path d="M2 16s3-1 6-3c3.5-2.3 4.5-5 4.5-5S10 13 8 15c-2.1 2.1-6 3-6 3z"/><path d="M22 2s-5 2-8 7c-2.3 3.5-2 7-2 7s2-3.5 5-6c3.1-2.6 5-8 5-8z"/></svg> 化肥</div>
      <div class="cbam-ind-box"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg> 鋁</div>
      <div class="cbam-ind-box"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#d4a56a" stroke="#d4a56a" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> 電力</div>
    </div>
  </div>
</div>
</div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 2026年才正式收費；台灣出口商須注意鋼鐵、水泥等產品的碳含量申報</div></div>
      <div class="chart-card" data-ch="ch1"><div class="chart-card-header"><span class="chart-tag ch1-tag">第一章</span><h3>EU Taxonomy 六大環境目標</h3></div><div class="chart-body">
<style>
.eut-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px;}
.eut-box{border-radius:10px;padding:10px 10px;font-size:.74rem;text-align:center;line-height:1.5;}
.eut-box b{display:block;font-size:.78rem;margin-bottom:3px;}
.eut-rule{background:#f5f5f5;border-radius:10px;padding:10px 14px;font-size:.74rem;line-height:1.7;}
.eut-rule b{color:#1b5c42;}
.eut-dnsh{display:inline-block;background:#ffebee;color:#c62828;border-radius:6px;padding:2px 8px;font-size:.7rem;font-weight:700;}
@media(max-width:480px){.eut-grid{grid-template-columns:repeat(2,1fr);}}
</style>
<div class="eut-grid">
  <div class="eut-box" style="background:#e2f5ec;border:1.5px solid #b8e4d0;"><b style="color:#1b5c42;">1️⃣ 氣候變遷減緩</b>減少溫室氣體排放</div>
  <div class="eut-box" style="background:#e1f5fe;border:1.5px solid #81d4fa;"><b style="color:#0277bd;">2️⃣ 氣候變遷調適</b>因應氣候衝擊風險</div>
  <div class="eut-box" style="background:#e8f2f9;border:1.5px solid #90caf9;"><b style="color:#89b4d4;">3️⃣ 水資源永續利用</b>保護水及海洋資源</div>
  <div class="eut-box" style="background:#ede8f7;border:1.5px solid #ce93d8;"><b style="color:#8872b8;">4️⃣ 轉型至循環經濟</b>廢棄物減量與再利用</div>
  <div class="eut-box" style="background:#fdf4e3;border:1.5px solid #ffcc02;"><b style="color:#c88a50;">5️⃣ 污染預防與控制</b>減少空氣、水土污染</div>
  <div class="eut-box" style="background:#f1f8e9;border:1.5px solid #aed581;"><b style="color:#33691e;">6️⃣ 生物多樣性保護</b>保護生態系統</div>
</div>
<div class="eut-rule">符合永續經濟活動須同時滿足：<br>
① 對以上六目標<b>至少一項</b>有重大貢獻<br>
② <span class="eut-dnsh">DNSH</span> 不對其他目標造成重大危害<br>
③ 符合最低社會保障（勞工人權等）</div>
</div><div class="chart-note"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 「政府保護」不屬於六大目標；DNSH = Do No Significant Harm；天然氣與核能在嚴格條件下可納入</div></div>
      <div class="chart-card chart-card-wide" data-ch="ch2"><div class="chart-card-header"><span class="chart-tag ch2-tag">第二章</span><h3>上市櫃溫室氣體盤查 × 確信時程</h3></div><div class="chart-body">
<style>
.timeline-matrix{width:100%;border-collapse:collapse;font-size:.78rem;table-layout:auto;}
.timeline-matrix th{background:#37474f;color:#fff;padding:6px 3px;text-align:center;font-weight:700;font-size:.72rem;white-space:nowrap;}
.timeline-matrix td{padding:4px 3px;border:1px solid #e0e0e0;text-align:center;vertical-align:middle;height:34px;}
.timeline-matrix .row-label{text-align:left;font-weight:600;font-size:.73rem;color:#37474f;padding:4px 6px;white-space:nowrap;background:#fafafa;min-width:80px;}
.timeline-matrix .row-group{background:#f5f5f5;font-weight:800;font-size:.73rem;color:#fff;padding:5px 6px;letter-spacing:.2px;}
@media(max-width:480px){
  .timeline-matrix{font-size:.68rem;}
  .timeline-matrix th{font-size:.65rem;padding:5px 2px;}
  .timeline-matrix td{padding:3px 2px;height:30px;}
  .timeline-matrix .row-label{font-size:.65rem;padding:3px 5px;min-width:68px;}
  .tm-scan,.tm-conf{font-size:.62rem;padding:2px 3px;}
}
.tm-scan{background:#b8e4d0;color:#1b5c42;font-weight:700;font-size:.7rem;border-radius:4px;padding:2px 4px;display:inline-block;line-height:1.3;}
.tm-conf{background:#bbdefb;color:#5a8ab8;font-weight:700;font-size:.7rem;border-radius:4px;padding:2px 4px;display:inline-block;line-height:1.3;}
.tm-both{background:linear-gradient(135deg,#b8e4d0 50%,#bbdefb 50%);color:#263238;font-weight:700;font-size:.66rem;border-radius:4px;padding:2px 3px;display:inline-block;line-height:1.4;}
.tm-legend{display:flex;gap:14px;margin-top:10px;font-size:.76rem;align-items:center;flex-wrap:wrap;}
.tm-legend span{display:flex;align-items:center;gap:5px;}
.col-grp1{background:#e2f5ec;}
.col-grp2{background:#e8f2f9;}
.col-grp3{background:#fdf0e0;}
</style>
<table class="timeline-matrix">
  <thead>
    <tr>
      <th style="text-align:left;padding-left:6px;">資本額 ／ 對象</th>
      <th style="background:#455a64;">2023</th>
      <th style="background:#455a64;">2024</th>
      <th style="background:#455a64;">2025</th>
      <th style="background:#455a64;">2026</th>
      <th style="background:#455a64;">2027</th>
      <th style="background:#455a64;">2028</th>
      <th style="background:#455a64;">2029</th>
    </tr>
  </thead>
  <tbody>
    <!-- 100億以上 + 鋼鐵水泥 -->
    <tr>
      <td class="row-group" style="background:#89b4d4;" colspan="8"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#89b4d4" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><circle cx="12" cy="12" r="8" fill="#89b4d4" stroke="none"/></svg> 100億以上 ＋ 鋼鐵、水泥業</td>
    </tr>
    <tr>
      <td class="row-label">個體公司</td>
      <td><span class="tm-scan">盤查</span></td>
      <td><span class="tm-conf">確信</span></td>
      <td></td><td></td><td></td><td></td><td></td>
    </tr>
    <tr>
      <td class="row-label">合併報表子公司</td>
      <td></td><td></td>
      <td><span class="tm-scan">盤查</span></td>
      <td></td>
      <td><span class="tm-conf">確信</span></td>
      <td></td><td></td>
    </tr>
    <!-- 50~100億 -->
    <tr>
      <td class="row-group" style="background:#4a9480;" colspan="8"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#2e7a52" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><circle cx="12" cy="12" r="8" fill="#2e7a52" stroke="none"/></svg> 50～100億</td>
    </tr>
    <tr>
      <td class="row-label">個體公司</td>
      <td></td><td></td>
      <td><span class="tm-scan">盤查</span></td>
      <td></td>
      <td><span class="tm-conf">確信</span></td>
      <td></td><td></td>
    </tr>
    <tr>
      <td class="row-label">合併報表子公司</td>
      <td></td><td></td><td></td>
      <td><span class="tm-scan">盤查</span></td>
      <td></td>
      <td><span class="tm-conf">確信</span></td>
      <td></td>
    </tr>
    <!-- 50億以下 -->
    <tr>
      <td class="row-group" style="background:#2e7a52;" colspan="8"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#2e7a52" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><rect x="2" y="2" width="20" height="20" rx="2" fill="#2e7a52" stroke="none"/></svg> 50億以下</td>
    </tr>
    <tr>
      <td class="row-label">個體公司</td>
      <td></td><td></td><td></td>
      <td><span class="tm-scan">盤查</span></td>
      <td></td>
      <td><span class="tm-conf">確信</span></td>
      <td></td>
    </tr>
    <tr>
      <td class="row-label">合併報表子公司</td>
      <td></td><td></td><td></td><td></td>
