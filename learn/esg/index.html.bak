    <div class="bnav-drawer-item" data-page="podcast" onclick="goPage('podcast');closeBnavDrawer()"><span class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="11" r="4"/><path d="M8 11a4 4 0 008 0"/><path d="M5 11a7 7 0 0014 0"/><line x1="12" y1="15" x2="12" y2="22"/><line x1="8" y1="22" x2="16" y2="22"/></svg></span>Podcast</div>
    <div class="bnav-drawer-item" data-page="textbook2" onclick="goPage('textbook2');closeBnavDrawer()"><span class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg></span>永續課文</div>
    <div class="bnav-drawer-item" data-page="charts" onclick="goPage('charts');closeBnavDrawer()"><span class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg></span>圖表總覽</div>
  </div>
</div>
<!-- 底部導航：5主要 + 更多 -->
<div id="bottom-nav">
  <div class="bnav-item active" data-page="home" onclick="goPage('home')"><span class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V9.5z"/><polyline points="9 21 9 12 15 12 15 21"/></svg></span><span>首頁</span></div>
  <div class="bnav-item" data-page="reader" onclick="goPage('reader')"><span class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span><span>精華筆記</span></div>
  <div class="bnav-item" data-page="notes" onclick="goPage('notes')"><span class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></span><span>考點</span></div>
  <div class="bnav-item" data-page="quiz" onclick="goPage('quiz')"><span class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg></span><span>題庫</span></div>
  <div class="bnav-item" data-page="exam" onclick="goPage('exam')"><span class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="4" rx="1"/><path d="M5 4h-1a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2h-1"/><polyline points="9 12 11 14 15 10"/></svg></span><span>考試</span></div>
  <div class="bnav-item bnav-more-btn" onclick="toggleBnavDrawer()"><span class="b-icon"><svg viewBox="0 0 24 24" fill="currentColor"><circle cx="5" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></svg></span><span>更多</span></div>
</div>

<div class="toast" id="toast"></div>
<script src="textbook-questions.js"></script>
<script src="quiz-questions.js"></script>
<script src="reader-questions.js"></script>
<script src="chapters.js"></script>
<script src="concepts.js"></script>

<script>
// ════════════════════════════════════════════════
//  DATA
// ════════════════════════════════════════════════






// ════════════════════════════════════════════════
//  CONSTANTS  ── 所有魔法數字集中管理
// ════════════════════════════════════════════════

const PAGES = Object.freeze({
  HOME: 'home', READER: 'reader', NOTES: 'notes', PODCAST: 'podcast',
  QUIZ: 'quiz', EXAM: 'exam', PROGRESS: 'progress',
  TEXTBOOK: 'textbook',
  CHARTS: 'charts', TEXTBOOK2: 'textbook2', MORE: 'more'
});

const FILTER_ALL    = 'all';
const MAX_HISTORY   = 200;   // localStorage 歷史上限
const PASS_PCT      = 70;    // 合格門檻 (統一單一來源)
const EXAM_SECS_PER_Q = 5400 / 80;  // 每題秒數基準 (≈67.5s)
const SVG_CIRCUMFERENCE = 276;       // SVG 環形 r=44 圓周 (2π×44≈276)
const SVG_RADIUS        = 44;

// ════════════════════════════════════════════════
//  STORAGE
// ════════════════════════════════════════════════
const STORE_KEY = 'susdev_progress';
const CONCEPTS_VIEWED_KEY = 'susdev_concepts_viewed';

function loadProgress(){
  try{ return JSON.parse(localStorage.getItem(STORE_KEY)) || {history:[], quizStats:{}}; }
  catch{ return {history:[], quizStats:{}}; }
}

function saveProgress(p){
  if(p.history.length > MAX_HISTORY) p.history = p.history.slice(0, MAX_HISTORY);
  try{
    localStorage.setItem(STORE_KEY, JSON.stringify(p));
    // 雲端同步（有登入時）
    if(typeof window._saveToFirebase === 'function') window._saveToFirebase(p);
  } catch(e){
    p.history = p.history.slice(0, 50);
    try{ localStorage.setItem(STORE_KEY, JSON.stringify(p)); }
    catch{ showToast('進度儲存失敗，請至「學習進度」頁面清除舊紀錄'); }
  }
}

// ════════════════════════════════════════════════
//  UTILITIES
// ════════════════════════════════════════════════

/** XSS 防護：將任意字串轉為安全的 HTML 文字 */
function _safeText(str){
  const d = document.createElement('div');
  d.textContent = String(str ?? '');
  return d.innerHTML;
}
function _safeTextNL(str){
  const d = document.createElement('div');
  d.textContent = String(str ?? '');
  return d.innerHTML.replace(/\n/g,'<br>');
}

/** Fisher-Yates 洗牌（純函式，不修改原陣列） */
function shuffle(a){
  const b = [...a];
  for(let i = b.length - 1; i > 0; i--){
    const j = Math.floor(Math.random() * (i + 1));
    [b[i], b[j]] = [b[j], b[i]];
  }
  return b;
}

/** 計算等第與對應顏色（統一 PASS_PCT 門檻） */
function _gradeInfo(pct){
  if(pct >= 90) return {grade:'非常優秀<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#d4a56a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg>', color:'var(--color-success)'};
  if(pct >= PASS_PCT) return {grade:'表現良好<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#89b4d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>', color:'var(--blue)'};
  if(pct >= 60) return {grade:'接近合格<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>', color:'var(--orange)'};
  return {grade:'需加強', color:'var(--color-danger)'};
}

/** 生成 SVG 圓環 HTML */
function _scoreRingHtml(pct, strokeColor){
  const offset = SVG_CIRCUMFERENCE * (1 - pct / 100);
  const color  = strokeColor || _gradeInfo(pct).color;
  return `
    <div class="score-ring">
      <svg viewBox="0 0 100 100">
        <circle class="bg-ring" cx="50" cy="50" r="${SVG_RADIUS}" stroke-dasharray="${SVG_CIRCUMFERENCE}" stroke-dashoffset="0"/>
        <circle class="fg-ring" cx="50" cy="50" r="${SVG_RADIUS}" stroke-dasharray="${SVG_CIRCUMFERENCE}" stroke-dashoffset="${offset.toFixed(1)}" style="stroke:${color}"/>
      </svg>
      <div class="score-pct" style="color:${color}">${pct}%</div>
    </div>`;
}

/** 結果面板 HTML（quiz / rq / textbook 共用） */
function _resultPanelHtml({ pct, correct, wrong, skipped, title, actions }){
  const { grade, color } = _gradeInfo(pct);
  return `
    <div class="result-panel">
      <h2>${title}</h2>
      ${_scoreRingHtml(pct)}
      <p style="font-size:1.1rem;font-weight:700;color:${color};">${grade}</p>
      <div class="result-stats">
        <div class="rs-box rs-correct"><div class="rs-num">${correct}</div>答對</div>
        <div class="rs-box rs-wrong"><div class="rs-num">${wrong}</div>答錯</div>
        <div class="rs-box rs-skip"><div class="rs-num">${skipped}</div>未作答</div>
      </div>
      <div class="result-actions">${actions}</div>
    </div>`;
}

/** 問題卡片共用 HTML（quiz / rq 共用） */
function _questionCardHtml({ q, current, total, answered, userAnswer, letters, tagLabel, tagStyle, onSelect, onPrev, onNext, onSubmit }){
  const L = letters || ['A','B','C','D'];
  const pending = onSelect==='quizSelect' ? qPending : onSelect==='rqSelect' ? rqPending : null;
  const _confirmFn = onSelect==='quizSelect' ? 'quizConfirm()' : onSelect==='rqSelect' ? 'rqConfirm()' : '';
  const _cancelFn  = onSelect==='quizSelect' ? 'qPending=null;renderQuizQ()' : onSelect==='rqSelect' ? 'rqPending=null;renderRq()' : '';
  const optsHtml = q.o.map((opt, i) => {
    let cls = 'opt' + (answered ? ' disabled' : '');
    if(answered){
      if(i === q.a)             cls += ' correct';
      else if(i === userAnswer) cls += ' wrong';
    } else if(pending === i){
      cls += ' pending';
    }
    return `<div class="${cls}" onclick="${onSelect}(${i})"><span class="letter">${L[i]}</span><span>${_safeText(opt)}</span></div>`;
  }).join('');
  const confirmHtml = (!answered && pending !== null)
    ? `<div class="confirm-row">
        <button type="button" class="btn-confirm-ans" onclick="${_confirmFn}"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> 確認答案</button>
        <button type="button" class="btn-change-ans" onclick="${_cancelFn}">↩ 重新選擇</button>
       </div>`
    : '';
  let expHtml = '';
  if(answered){
    const isCorrect = (userAnswer === q.a);
    if(!isCorrect && userAnswer !== undefined){
      expHtml += `<div style="color:var(--color-danger);margin-bottom:4px;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> 你的答案：${L[userAnswer]}. ${_safeText(q.o[userAnswer])}</div>`;
    }
    expHtml += `<strong style="color:var(--color-success)"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> 正確答案：${L[q.a]}. ${_safeText(q.o[q.a])}</strong>`;
    expHtml += q.x
      ? `<div style="margin-top:6px;font-size:.84rem;color:#37474f">【解析】${_safeTextNL(q.x)}</div>`
      : '<div style="margin-top:4px;font-size:.78rem;color:var(--gray)">（本題無詳細解析）</div>';
    expHtml += _relatedCourseBtn(q);
    if(typeof _textbookBtn === 'function') expHtml += _textbookBtn(q);

  }
  const navNext = current < total - 1
    ? `<button class="btn-next" onclick="${onNext}()">下一題 →</button>`
    : `<button class="btn-submit" onclick="${onSubmit}()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><rect x="18" y="3" width="4" height="18"/><rect x="10" y="8" width="4" height="13"/><rect x="2" y="13" width="4" height="8"/></svg> 查看成績</button>`;
  return `
    <div class="q-card" ${tagStyle ? `style="${tagStyle}"` : ''}>
      <div class="q-meta">
        ${tagLabel ? `<span class="q-tag" ${tagStyle ? `style="background:var(--tp);color:var(--teal);"` : 'class="q-tag tag-green"'}>${tagLabel}</span>` : ''}
        <span class="q-tag tag-blue">${_safeText(q.e || q.section || '')}</span>
        <span class="q-tag tag-gray">第 ${current+1} / ${total} 題</span>
      </div>
      <div class="q-stem">${_safeText(q.s)}</div>
      <div class="options">${optsHtml}</div>
      ${confirmHtml}
      <div class="exp-box${answered ? ' show' : ''}">${expHtml}</div>
    </div>
    <div class="q-nav">
      <button class="btn-prev" onclick="${onPrev}()" ${current===0?'disabled style="opacity:.4"':''}>← 上一題</button>
      <span style="font-size:.8rem;color:var(--gray);">${current+1} / ${total}</span>
      ${navNext}
    </div>`;
}


// ════════════════════════════════════════════════
//  回到題目：浮動按鈕邏輯
// ════════════════════════════════════════════════
let _returnState = null; // { page, label, restore }

function _setReturnState(page, label, restoreFn) {
  _returnState = { page, label, restore: restoreFn };
  const btn = document.getElementById('return-to-q-btn');
  const lbl = document.getElementById('return-to-q-label');
  if(btn) {
    btn.style.display = 'flex';
    if(lbl) lbl.textContent = label ? '(' + label + ')' : '';
  }
}


function _makeRestoreFn(pageId) {
  // 根據頁面記住當前狀態
  if(pageId === 'quiz') {
    var savedCurrent = qCurrent;
    var savedAnswers = JSON.parse(JSON.stringify(qAnswers));
    var savedPending = qPending;
    return function() {
      qCurrent = savedCurrent;
      qAnswers = savedAnswers;
      qPending = savedPending;
      if(typeof renderQuizQ === 'function') renderQuizQ();
      window.scrollTo(0,0);
    };
  }
  if(pageId === 'exam') {
    var savedExamCur = examCur;
    var savedExamPending = typeof _examPending !== 'undefined' ? _examPending : null;
    return function() {
      examCur = savedExamCur;
      if(typeof _examPending !== 'undefined') _examPending = savedExamPending;
      if(typeof renderExamQ === 'function') renderExamQ();
      window.scrollTo(0,0);
    };
  }
  if(pageId === 'notes') {
    var savedTbIdx = tbIdx;
    return function() {
      tbIdx = savedTbIdx;
      if(typeof renderTbQ === 'function') renderTbQ();
      window.scrollTo(0,0);
    };
  }
  if(pageId === 'reader') {
    // 隨堂練習在 reader 頁的 practice tab
    var savedRqCur = typeof rqCurrent !== 'undefined' ? rqCurrent : 0;
    return function() {
      switchReaderTab('practice');
      if(typeof rqCurrent !== 'undefined') rqCurrent = savedRqCur;
      window.scrollTo(0,0);
    };
  }
  return function(){ window.scrollTo(0,0); };
}


function _captureAndGo(fn) {
  var rawId = ((document.querySelector('.page.active')||{}).id || '');
  var pageId = rawId.replace(/^page-/, '');
  _setReturnState(pageId, null, _makeRestoreFn(pageId));
  // ── 功能跳轉埋點 ──
  window._logEvent && window._logEvent('feature_click', { from_page: pageId, action: 'view_reference' });
  fn();
}

function _rcBtnClick(btn) {
  var b64 = btn.getAttribute('data-loc');
  var loc = b64 ? JSON.parse(decodeURIComponent(escape(atob(b64)))) : null;
  _captureAndGo(function(){ openRelatedCourse(loc); });
}
function _clearReturnState() {
  _returnState = null;
  const btn = document.getElementById('return-to-q-btn');
  if(btn) btn.style.display = 'none';
}

function returnToQuestion() {
  if(!_returnState) return;
  var page = _returnState.page;
  var restore = _returnState.restore;
  _clearReturnState(); // 先清除，避免 goPage 觸發的 handler 干擾
  goPage(page);
  if(typeof restore === 'function') {
    setTimeout(restore, 150); // 延長至150ms 確保頁面完全切換
  }
}

/** toast 顯示 */
function showToast(msg){
  const t = document.getElementById('toast');
  t.innerHTML = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ════════════════════════════════════════════════
//  NAVIGATION
// ════════════════════════════════════════════════
const PAGE_TITLES = {
  [PAGES.HOME]:       '首頁',
  [PAGES.READER]:     '精華筆記',
  [PAGES.NOTES]:      '考點卡片',
  [PAGES.QUIZ]:       '歷屆題庫',
  [PAGES.EXAM]:       '模擬考試',
  [PAGES.PROGRESS]:   '學習進度',
  [PAGES.CHEATSHEET]: '考前速覽',
  [PAGES.TEXTBOOK]:   '永續題庫',
  [PAGES.PODCAST]:   'Podcast 聆聽',
  [PAGES.CHARTS]:     '圖表總覽',
  [PAGES.TEXTBOOK2]:  '永續課文'
};

// ── Page title SVG icons ──
const PAGE_ICONS = {
  home:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V9.5z"/><polyline points="9 21 9 12 15 12 15 21"/></svg>`,
  reader:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  notes:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  quiz:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>`,
  exam:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="2" width="6" height="4" rx="1"/><path d="M5 4h-1a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V6a2 2 0 00-2-2h-1"/><polyline points="9 12 11 14 15 10"/></svg>`,
  progress:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  textbook:  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="9" y1="12" x2="13" y2="12"/></svg>`,
  podcast:   `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="11" r="4"/><path d="M8 11a4 4 0 008 0"/><path d="M5 11a7 7 0 0014 0"/><line x1="12" y1="15" x2="12" y2="22"/><line x1="8" y1="22" x2="16" y2="22"/></svg>`,
  charts:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>`,
  textbook2: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>`,
};


function goPage(id){
  // 離開考試頁面時暫停計時器
  if(id !== PAGES.EXAM && examTimer) clearInterval(examTimer);
  if(id !== 'quiz') _clearReturnBar?.();
  // 離開課文頁時清除返回條（如果有定義）
  if(id !== 'textbook2' && typeof _clearReturnState === 'function') {
    // 保持返回按鈕：只有離開課文頁時才需要清除（由 returnToQuestion 負責）
  }

  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.querySelectorAll('.bnav-item').forEach(n => n.classList.remove('active'));
  document.querySelectorAll('.bnav-drawer-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  document.querySelectorAll(`.nav-item[data-page="${id}"]`).forEach(n => n.classList.add('active'));
  document.querySelectorAll(`.bnav-item[data-page="${id}"]`).forEach(n => n.classList.add('active'));
  document.querySelectorAll(`.bnav-drawer-item[data-page="${id}"]`).forEach(n => n.classList.add('active'));
  // 若切換到抽屜項目，更多按鈕也高亮
  const _morePgs=['notes','progress','textbook','charts','textbook2','exam','more'];
  if(_morePgs.includes(id)){document.querySelectorAll('.bnav-item[data-page="more"]').forEach(n=>n.classList.add('active'));}
  const _titleEl = document.getElementById('page-title');
  if(_titleEl){
    const _iconEl = document.getElementById('page-title-icon');
    const _textEl = document.getElementById('page-title-text');
    if(_iconEl && _textEl){
      _iconEl.innerHTML = PAGE_ICONS[id] || '';
      _textEl.textContent = (PAGE_TITLES[id] || id).replace(/^[^\s]+ /, '');
    } else {
      _titleEl.textContent = PAGE_TITLES[id] || id;
    }
  }
  closeSidebar();
  // podcast 背景播放控制（離開 podcast 頁時依設定決定是否暫停）
  if(typeof _podHandlePageChange==="function") _podHandlePageChange(id !== (typeof PAGES!=="undefined"&&PAGES.PODCAST));
  // 完整課文頁面：全螢幕閱讀模式（隱藏 sidebar / topbar / bottom-nav）
  if(id === 'textbook2'){
    document.body.classList.add('tx2-mode');
  } else {
    document.body.classList.remove('tx2-mode');
  }

  const handlers = {
    [PAGES.READER]:    initReader,
    [PAGES.NOTES]:     initNotes,
    [PAGES.PROGRESS]:  renderProgress,
    [PAGES.HOME]:      renderHome,
    [PAGES.TEXTBOOK]:  initTextbook,
    [PAGES.TEXTBOOK2]: function(){
    _txEnsureChapter(0); // 第一章立即載入，使用者馬上看到內容
    // 其餘章節分幀載入，避免阻塞主執行緒
    requestAnimationFrame(()=>{
      _txEnsureChapter(1);
      requestAnimationFrame(()=>{
        _txEnsureChapter(2);
        requestAnimationFrame(()=>{ _txEnsureChapter(3); });
      });
    });
  },
    [PAGES.EXAM]:      renderExamHistory,
    [PAGES.PODCAST]:   initPodcast,
    [PAGES.CHARTS]:    _initChartsPage,
  };
  handlers[id]?.();

  const sCtx = document.getElementById('sidebar-reading-ctx');
  if(sCtx) sCtx.style.display = (id === PAGES.READER ? 'block' : 'none');
  window.scrollTo(0, 0);

  // ── 頁面切換埋點 ──
  const _pageNames = {
    home:'首頁', reader:'精華筆記', textbook2:'永續課文',
    notes:'考點卡片', charts:'圖表總覽', podcast:'Podcast',
    textbook:'永續題庫', quiz:'歷屆題庫', exam:'模擬考試', progress:'學習進度'
  };
  window._logEvent && window._logEvent('page_view', { page: id, page_name: _pageNames[id] || id });
}

document.querySelectorAll('.nav-item').forEach(el =>
  el.addEventListener('click', () => goPage(el.dataset.page)));

function toggleSidebar(){
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('overlay').classList.toggle('show');
}
function closeSidebar(){
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('overlay').classList.remove('show');
}



// ════════════════════════════════════════════════
//  折疊式課文功能 + 四項加強功能
// ════════════════════════════════════════════════

/* 功能一：滑順折疊開關（含進度記憶） */
function toggleFullText(uid){
  const body = document.getElementById(uid);
  const btn  = body ? body.previousElementSibling : null;
  if(!body) return;
  const isOpen = body.classList.toggle('open');
  if(btn) btn.classList.toggle('open', isOpen);
  // 功能三：記憶折疊狀態
  _saveFoldState(uid, isOpen);
}

/* 功能二：全部展開/收合 已移除 */

/* 功能三：進度記憶（localStorage） */
const FOLD_STORE = 'susdev_fold_v1';
function _saveFoldState(uid, isOpen){
  try{
    const st = JSON.parse(localStorage.getItem(FOLD_STORE) || '{}');
    st[uid] = isOpen;
    localStorage.setItem(FOLD_STORE, JSON.stringify(st));
  } catch{}
}
function _restoreFoldStates(){
  try{
    const st = JSON.parse(localStorage.getItem(FOLD_STORE) || '{}');
    Object.entries(st).forEach(([uid, isOpen]) => {
      if(!isOpen) return; // 預設收合，只需恢復展開的
      const body = document.getElementById(uid);
      const btn  = body ? body.previousElementSibling : null;
      if(body){ body.classList.add('open'); }
      if(btn)  { btn.classList.add('open'); }
    });
  } catch{}
}

/* 功能四：答錯時跳轉課文（真實有效版）
   用法：openRelatedCourse('ch1')  → 跳到第一章課文
   ─────────────────────────────────────────────
   e 欄位對應表：
   官方第一章/第一章 永續基本概念  → ch1
   官方第二章/第二章 永續資訊揭露  → ch2
   官方第三章/第三章 永續風險管理  → ch3
   官方第四章/第四章 永續金融      → ch4
   考古題(113-x, 114-x...)         → 依年次無法判斷章節，跳課文首頁
*/
const _E_TO_CH = {
  '官方第一章': 'ch1', '第一章 永續基本概念': 'ch1', '第一章': 'ch1',
  '官方第二章': 'ch2', '第二章 永續資訊揭露': 'ch2', '第二章': 'ch2',
  '官方第三章': 'ch3', '第三章 永續風險管理與治理': 'ch3', '第三章': 'ch3',
  '官方第四章': 'ch4', '第四章 永續金融': 'ch4', '第四章': 'ch4',
};


// ── 精準章節對應（section → ci, si）──────────────────────────
const _SEC_MAP = {
  '第一節 永續介紹與發展目標':       {ci:0,si:0},
  '第二節 國內永續發展政策':         {ci:0,si:1},
  '第三節 國際永續發展政策':         {ci:0,si:2},
  '第一節 國際永續資訊公開規範':     {ci:1,si:0},
  '第二節 國內永續資訊公開規範':     {ci:1,si:1},
  '第三節 第三方確信':               {ci:1,si:2},
  '第一節 整體 ESG 風險概述':        {ci:2,si:0},
  '第二節 環境風險':                 {ci:2,si:1},
  '第三節 社會風險':                 {ci:2,si:2},
  '第四節 治理風險':                 {ci:2,si:3},
  '第一節 永續評比與指數':           {ci:3,si:0},
  '第二節 永續投資':                 {ci:3,si:1},
  '第三節 永續融資':                 {ci:3,si:2},
  '第四節 永續授信':                 {ci:3,si:3},
  '第五節 永續保險':                 {ci:3,si:4},
  '第六節 永續金融應注意的漂綠問題': {ci:3,si:5},
};
const _CH_TO_CI = {'ch1':0,'ch2':1,'ch3':2,'ch4':3};

function _getLocation(q){
  if(!q) return null;
  if(q.section && _SEC_MAP[q.section]) return _SEC_MAP[q.section];
  let chKey = null;
  if(q.ch)           chKey = q.ch;
  else if(q.e)       chKey = _E_TO_CH[q.e] || null;
  else if(q.chapter) chKey = _E_TO_CH[q.chapter] || null;
  if(!chKey) return null;
  const ci = _CH_TO_CI[chKey];
  return (ci !== undefined) ? {ci, si:0} : null;
}

function _getChKeyFromQ(q){
  if(!q) return null;
  // Q（考古題）：有 ch 欄位（自動分類）
  if(q.ch) return q.ch;
  // TEXTBOOK_Q：e 欄位（官方第X章）
  // READER_Q：chapter 欄位
  const raw = q.e || q.chapter || '';
  return _E_TO_CH[raw] || null;
}

function openRelatedCourse(arg){
  if(!arg) return;
  let ci, si;
  if(typeof arg === 'object'){ ci = arg.ci; si = arg.si ?? 0; }
  else {
    ci = CHAPTERS.findIndex(ch => ch.key === arg);
    si = 0;
  }
  if(ci < 0 || ci === undefined){ goPage('reader'); return; }
  goPage('reader');
  switchReaderTab('read');
  showSection(ci, si);
  window.scrollTo(0,0);
}


// 顯示「<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> 精華筆記複習」按鈕的 HTML 產生器
function _relatedCourseBtn(q){
  var loc = _getLocation(q);
  var chLabels = {0:'第一章',1:'第二章',2:'第三章',3:'第四章'};
  if(loc){
    var chLabel  = chLabels[loc.ci] || '';
    var secArr   = ((CHAPTERS[loc.ci]||{}).sections||[]);
    var secTitle = secArr[loc.si] ? secArr[loc.si].title : '';
    var secLabel = (loc.si > 0 || q.section) ? ' › ' + secTitle : '';
    // 用 data 屬性儲存 JSON，避免引號嵌套問題
    var locB64 = btoa(unescape(encodeURIComponent(JSON.stringify(loc))));
    return '<button type="button" class="related-course-btn" data-loc="' + locB64 + '" onclick="_rcBtnClick(this)"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> ' + chLabel + secLabel + ' 精華筆記復習</button>';
  }
  return '<button type="button" class="related-course-btn" onclick="_captureAndGo(function(){openRelatedCourse(null);})"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> 精菪筆記復習</button>';
}


// 頁面載入時恢復折疊狀態
document.addEventListener('DOMContentLoaded', _restoreFoldStates);

// ════════════════════════════════════════════════

