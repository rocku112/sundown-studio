// ── 圖表頁面功能 ────────────────────────────────────────
function filterCharts(btn, ch){
  // 更新按鈕 active 狀態
  document.querySelectorAll('.chart-filters .chip, .chart-filters .cf-btn').forEach(b => {
    b.classList.toggle('active', b === btn);
  });
  // 顯示/隱藏圖表
  document.querySelectorAll('.chart-card').forEach(c => {
    c.classList.toggle('hidden', ch !== 'all' && c.dataset.ch !== ch);
  });
}

function _initChartsPage(canvasId){
  if(typeof Chart === 'undefined') return;
  const targetId = canvasId || 'chart-gfa';
  const ctx = document.getElementById(targetId);
  if(!ctx || ctx._chartsInited) return;
  ctx._chartsInited = true;
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['1.0\n環境面向','2.0\nESG面向','3.0\n淨零轉型','4.0\n轉型金融'],
      datasets:[{label:'推動面向數',data:[3,4,5,6],
        backgroundColor:['#b8e4d0','#72c49a','#3fa068','#2e7a52'],borderRadius:8}]
    },
    options:{
      responsive:true,
      plugins:{legend:{display:false},
        title:{display:true,text:'綠色金融行動方案推動面向數',font:{size:12}}},
      scales:{y:{beginAtZero:true,max:8,ticks:{stepSize:1}}}
    }
  });
}


// ── 底部導航抽屜 ──────────────────────────
function toggleBnavDrawer(){
  const drawer = document.getElementById('bnav-more-drawer');
  const overlay = document.getElementById('bnav-overlay');
  const isOpen = drawer.classList.contains('open');
  if(isOpen){ closeBnavDrawer(); }
  else {
    drawer.classList.add('open');
    overlay.classList.add('show');
    document.querySelector('.bnav-more-btn')?.classList.add('drawer-open');
  }
}
function closeBnavDrawer(){
  document.getElementById('bnav-more-drawer')?.classList.remove('open');
  document.getElementById('bnav-overlay')?.classList.remove('show');
  // 若當前頁不是抽屜頁，移除更多按鈕高亮
  const drawerPages = ['progress','textbook','charts'];
  const activePage = document.querySelector('.bnav-item.active')?.dataset.page;
  if(!drawerPages.includes(activePage)){
    document.querySelector('.bnav-more-btn')?.classList.remove('drawer-open','active');
  }
}
renderHome();
