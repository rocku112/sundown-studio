<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>永續知幾 · SunDown Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800;900&family=Noto+Sans+TC:wght@400;500;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════
   CSS VARIABLES & RESET
═══════════════════════════════════════════ */
:root{
  --green:#1b5c42;--gl:#3fa068;--gp:#e2f5ec;--gll:#72c49a;
  --blue:#89b4d4;--bl:#89b4d4;--bp:#e8f2f9;
  --orange:#c87848;--op:#fdf0e0;
  --red:#b71c1c;--rp:#ffebee;
  --purple:#8872b8;--pp:#ede8f7;
  --teal:#4a9480;--tp:#e0f0ec;
  /* 暖色中性系（新版升級） */
  --gray:#7a6e65;--lgray:#f0ece4;--border:#e5ddd2;
  /* Semantic aliases – use these in JS/HTML for clarity */
  --color-success:var(--green);
  --color-danger:var(--red);
  --color-info:var(--blue);
  --color-warn:var(--orange);
  --bg:#faf8f4;--card:#fefcf9;--sidebar:#faf7f2;--sidebar-w:240px;
  --header-h:56px;--bottom-nav-h:60px;
  --shadow:0 2px 12px rgba(0,0,0,.1);--shadow-lg:0 4px 24px rgba(0,0,0,.15);
  --radius:12px;--radius-sm:8px;
  --font:'Outfit','Noto Sans TC','Microsoft JhengHei','PingFang TC',sans-serif;
  --mono:'DM Mono','Consolas',monospace;
  /* SunDown Studio brand */
  --sd-navy:#2D4A6E; --sd-gold:#E8B84B; --sd-navy-muted:rgba(45,74,110,.10);
}
:root_placeholder{
  --transition:.2s ease;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--font);background:var(--bg);color:#263238;overflow-x:hidden;}

/* ═══════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════ */
#app{display:flex;min-height:100vh;}

/* Sidebar */
#sidebar{
  width:var(--sidebar-w);min-width:var(--sidebar-w);
  background:var(--sidebar);color:#2a221a;border-right:1px solid #ede8e0;
  position:fixed;top:0;left:0;bottom:0;z-index:200;
  display:flex;flex-direction:column;
  transition:transform var(--transition);overflow-y:auto;
  padding-bottom:env(safe-area-inset-bottom,0);
}
#sidebar-header{padding:20px 18px 14px;border-bottom:1px solid #ede8e0;}

#sidebar nav{flex:1;padding:10px 0;}
.nav-item{
  display:flex;align-items:center;gap:12px;
  padding:13px 18px;cursor:pointer;
  font-size:.88rem;font-weight:500;
  color:#2a221a;
  white-space:nowrap;overflow:hidden;transition:background var(--transition),color var(--transition);
  border-left:3px solid transparent;
}
.nav-item:hover{background:rgba(0,0,0,.06);color:#2a221a;}
.nav-item.active{background:#eef6ec;color:#3a7d44;border-left-color:#5a9e6a;font-weight:700;}
.nav-item .icon{font-size:1.1rem;width:22px;text-align:center;}
#sidebar-footer{padding:10px 18px;border-top:1px solid #ede8e0;font-size:.72rem;color:#b0a898;display:flex;align-items:center;gap:8px;}

/* Main area */
#main{margin-left:var(--sidebar-w);flex:1;display:flex;flex-direction:column;min-height:100vh;}

/* Top header */
#topbar{
  background:#fff;border-bottom:1px solid var(--border);
  padding:0 24px;height:var(--header-h);
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;box-shadow:0 1px 4px rgba(0,0,0,.06);
}
#topbar h1{font-size:1.05rem;font-weight:700;color:var(--green);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;min-width:0;}
#topbar-right{display:flex;align-items:center;gap:12px;flex-shrink:0;}
#menu-btn{display:none;background:none;border:none;cursor:pointer;font-size:1.4rem;padding:4px;flex-shrink:0;}

/* Content area */
#content{padding:24px;flex:1;width:100%;display:flex;flex-direction:column;min-height:0;}

/* Overlay for drawer */
#overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:190;}
#overlay.show{display:block;}

/* Bottom nav (mobile) */
#bottom-nav{
  display:none;position:fixed;bottom:0;left:0;right:0;
  background:#fff;border-top:1px solid var(--border);
  height:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom, 0px));
  padding-bottom:env(safe-area-inset-bottom, 0px);
  z-index:200;
  justify-content:space-around;align-items:center;
}
.bnav-item{
  display:flex;flex-direction:column;align-items:center;gap:2px;
  cursor:pointer;padding:6px 4px;border-radius:8px;flex:1;
  font-size:.62rem;color:var(--gray);transition:all var(--transition);
  min-width:0;
}
.bnav-item .b-icon{font-size:1.2rem;line-height:1;}
.bnav-item span:last-child{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;}
.bnav-item.active{color:var(--green);font-weight:700;}
.bnav-item.active .b-icon{transform:scale(1.1);}
/* 更多抽屜 */
#bnav-more-drawer{
  display:none;position:fixed;bottom:var(--bottom-nav-h);left:0;right:0;
  background:#fff;border-top:2px solid var(--border);z-index:199;
  padding:12px 16px 16px;box-shadow:0 -4px 20px rgba(0,0,0,.12);
}
#bnav-more-drawer.open{display:block;}
.bnav-drawer-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:8px;
}
@media(max-width:380px){
  .bnav-drawer-grid{grid-template-columns:repeat(3,1fr);}
}
.bnav-drawer-item{
  display:flex;flex-direction:column;align-items:center;gap:4px;
  cursor:pointer;padding:10px 6px;border-radius:10px;
  font-size:.72rem;color:var(--gray);
  background:#f8f9fa;border:1px solid var(--border);
  transition:all var(--transition);
}
.bnav-drawer-item:active{background:var(--gp);}
.bnav-drawer-item.active{color:var(--green);font-weight:700;background:var(--gp);border-color:var(--gll);}
.bnav-drawer-item .b-icon{font-size:1.4rem;}
.bnav-more-btn.drawer-open{color:var(--green);font-weight:700;}
#bnav-overlay{
  display:none;position:fixed;inset:0 0 var(--bottom-nav-h) 0;
  background:rgba(0,0,0,.3);z-index:198;
}
#bnav-overlay.show{display:block;}

/* ═══════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════ */

/* ── iPad Pro 13" 橫向(≥1300px)：sidebar 可見 ── */
/* ── iPad Pro 13" 橫向(≥1300px)：sidebar 可見 ── */
@media(min-width:1300px){
  #sidebar{transform:none;}
  #main{margin-left:var(--sidebar-w);}
  #menu-btn{display:none;}
  #bottom-nav{display:none;}
  #main{padding-bottom:0;}
}

/* ── 4K / 超寬螢幕 (≥2000px)：內容區最大寬度拉大，保留合理空白 ── */
@media(min-width:2000px){
  :root{--sidebar-w:260px;}
  #content{padding:32px 40px;}
  .page.active:not(#page-textbook2){max-width:1400px;}
  #topbar{padding:0 40px;}
}

/* ── iPad Pro 13" 直向 / iPad Air 橫向 (1025~1299px) ── */
@media(max-width:1299px) and (min-width:1025px){
  #sidebar{transform:translateX(-100%);box-shadow:var(--shadow-lg);}
  #sidebar.open{transform:translateX(0);}
  #main{margin-left:0;padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}
  #sidebar{padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}
  #menu-btn{display:block;}
  #bottom-nav{display:flex;}
  .reader-body{padding:22px 24px;max-width:100%;}
  .stats-grid{grid-template-columns:repeat(4,1fr);}
}

/* ── 一般平板 (821~1024px)：iPad mini/Air 直向 ── */
@media(max-width:1024px) and (min-width:821px){
  #sidebar{transform:translateX(-100%);box-shadow:var(--shadow-lg);}
  #sidebar.open{transform:translateX(0);}
  #main{margin-left:0;padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}
  #sidebar{padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}
  #menu-btn{display:block;}
  #bottom-nav{display:flex;}
  .stats-grid{grid-template-columns:repeat(4,1fr);}
  .kc-table table{font-size:.82rem;}
}

/* ── iPad mini 7 直向 (744px) / 一般平板小尺寸 (641~820px) ── */
@media(max-width:820px) and (min-width:641px){
  #sidebar{transform:translateX(-100%);box-shadow:var(--shadow-lg);}
  #sidebar.open{transform:translateX(0);}
  #main{margin-left:0;padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}
  #sidebar{padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}
  #menu-btn{display:block;}
  #bottom-nav{display:flex;}
  #content{padding:16px 14px;}
  .reader-body{padding:18px 16px;max-width:100%;}
  .reader-toc{width:180px;min-width:180px;}
  .stats-grid{grid-template-columns:repeat(2,1fr);}
  .kc-4cards{grid-template-columns:repeat(2,1fr);}
  .kc-3cards{grid-template-columns:repeat(2,1fr);}
  .kc-table table{font-size:.8rem;}
  .kc-table{overflow-x:auto;-webkit-overflow-scrolling:touch;}
}

/* ── 手機(≤640px) ── */
@media(max-width:640px){
  /* sidebar 用 transform 隱藏（而非 display:none），才能滑入顯示 */
  #sidebar{transform:translateX(-100%);box-shadow:var(--shadow-lg);}
  #sidebar.open{transform:translateX(0);}
  #bottom-nav{display:flex;}
  #main{margin-left:0;padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}
  #content{padding:12px;padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}
  #topbar{padding:0 12px;}
  #topbar h1{font-size:.9rem;}
  /* 手機也要顯示漢堡按鈕（sidebar 可滑入） */
  #menu-btn{display:block;}
  .kc-table{overflow-x:auto;-webkit-overflow-scrolling:touch;display:block;}
  .kc-table table{font-size:.78rem;}
  .rich-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;}
  .rich-table{font-size:.76rem;}
  /* 多欄表格才需要橫滑 */
  .kc-table table:has(td:nth-child(4)){min-width:420px;}
  .kc-table table:has(td:nth-child(3)){min-width:300px;}
}

/* ── 超窄手機(≤390px) iPhone SE 等 ── */
@media(max-width:390px){
  #content{padding:10px;padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}
  #topbar h1{font-size:.82rem;}
  .stats-grid{gap:8px;}
  .stat-card{padding:12px 8px;}
  .stat-card .stat-num{font-size:1.3rem;}
}

/* mobile-toc: 桌面預設隱藏 */
#mobile-toc-btn{display:none;}
.tx-toc-toggle-btn{display:none;}

/* ═══════════════════════════════════════════
   PAGE SECTIONS (hidden by default)
═══════════════════════════════════════════ */
.page{display:none;}
.page.active{display:block;}
/* 各頁面內容最大寬度，讓頁面在寬螢幕不過度拉伸，4K置中 */
.page.active:not(#page-textbook2){max-width:1200px;margin-left:auto;margin-right:auto;width:100%;}
/* reader/textbook2 需要全寬 */
#page-reader.active{display:flex;flex-direction:column;flex:1;min-height:0;max-width:unset;margin-left:0;margin-right:0;}
#page-textbook2.active{max-width:unset;margin-left:0;margin-right:0;}

/* ═══════════════════════════════════════════
   HOME PAGE
═══════════════════════════════════════════ */
.welcome-banner{
  display:grid;grid-template-columns:1fr 1fr;
  border-radius:16px;overflow:hidden;margin-bottom:20px;
  border:1px solid rgba(0,0,0,.08);
}
.wb-left{
  background:linear-gradient(145deg,#2d5a1b,#4a8a2a);
  color:#fff;padding:28px 26px;display:flex;flex-direction:column;gap:14px;
}
.wb-badge{
  display:inline-block;font-size:.72rem;font-weight:600;letter-spacing:.05em;
  background:rgba(255,255,255,.2);color:#d4f0a0;
  padding:4px 12px;border-radius:20px;width:fit-content;
}
.wb-icon-row{display:flex;gap:10px;align-items:center;}
.wb-icon{
  width:48px;height:48px;flex-shrink:0;
  background:rgba(255,255,255,.15);border-radius:12px;
  display:flex;align-items:center;justify-content:center;
}
.wb-icon svg{width:28px;height:28px;stroke:#a8e06a;fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;}
.wb-left h2{font-size:1.55rem;font-weight:800;line-height:1.3;margin:0;}
.wb-left p{font-size:.9rem;opacity:.88;line-height:1.65;margin:0;}
.wb-right{
  background:#f0f7e8;padding:22px 24px;
  display:flex;flex-direction:column;justify-content:center;gap:0;
}
.wb-stat{display:flex;flex-direction:column;padding:10px 0;}
.wb-stat+.wb-stat{border-top:1px solid #c8e6a0;}
.wb-num{font-size:1.55rem;font-weight:800;color:#2d5a1b;line-height:1.1;}
.wb-label{font-size:.72rem;color:#5a8a30;margin-top:3px;}
/* welcome-banner mobile: handled in ≤640px block below */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
.stat-card{background:var(--card);border-radius:var(--radius);padding:18px;box-shadow:var(--shadow);text-align:center;}
.stat-card .stat-num{font-size:1.8rem;font-weight:800;color:var(--green);}
.stat-card .stat-label{font-size:.78rem;color:var(--gray);margin-top:4px;}
.quick-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
.quick-card{
  background:var(--card);border-radius:var(--radius);padding:20px;
  box-shadow:var(--shadow);cursor:pointer;
  border-left:4px solid var(--green);transition:all var(--transition);
  display:flex;align-items:flex-start;gap:14px;
}
.quick-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-lg);}
.quick-card .q-icon{font-size:1.8rem;}
.quick-card h3{font-size:.95rem;font-weight:700;margin-bottom:4px;}
.quick-card p{font-size:.8rem;color:var(--gray);line-height:1.5;}

/* ═══════════════════════════════════════════
   READER PAGE
═══════════════════════════════════════════ */
#reader-read-view{flex:1;display:flex;flex-direction:column;}
.reader-tabs{display:flex;gap:0;margin-bottom:16px;background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;flex-shrink:0;}
.reader-tab{flex:1;padding:14px 20px;border:none;background:transparent;font-size:.9rem;font-weight:600;cursor:pointer;font-family:var(--font);color:var(--gray);transition:all var(--transition);border-bottom:3px solid transparent;display:flex;align-items:center;justify-content:center;gap:6px;}
.reader-tab:hover{background:var(--gp);color:var(--green);}
.reader-tab.active{color:var(--green);border-bottom-color:var(--green);background:var(--gp);}
.rq-badge{font-size:.7rem;background:var(--green);color:#fff;padding:1px 7px;border-radius:10px;font-weight:700;}
.reader-layout{display:flex;gap:0;flex:1;min-height:0;}
.reader-toc{
  width:220px;min-width:220px;background:var(--card);border-radius:var(--radius);
  border-right:1px solid var(--border);overflow-y:auto;padding:12px 0;
  box-shadow:var(--shadow);min-height:0;
}
.toc-ch{font-size:.78rem;font-weight:700;color:var(--green);padding:10px 14px 4px;text-transform:uppercase;letter-spacing:.5px;}
.toc-sec{
  font-size:.82rem;color:#455a64;padding:8px 14px 8px 20px;cursor:pointer;
  border-left:3px solid transparent;transition:all var(--transition);
  line-height:1.4;
}
.toc-sec:hover{background:var(--gp);color:var(--green);}
.toc-sec.active{background:var(--gp);color:var(--green);border-left-color:var(--gl);font-weight:600;}
.reader-body{flex:1;background:var(--card);border-radius:var(--radius);overflow-y:auto;padding:28px 32px;box-shadow:var(--shadow);margin-left:14px;max-width:860px;}
.reader-body h3{font-size:1.15rem;color:var(--green);margin-bottom:16px;padding-bottom:8px;border-bottom:2px solid var(--gp);}
.topic-head{font-size:.95rem;font-weight:700;color:#2e7a52;margin:18px 0 8px;padding:8px 12px;background:var(--gp);border-radius:6px;border-left:3px solid var(--gl);}
.note-p{font-size:.88rem;line-height:1.8;color:#37474f;margin-bottom:8px;}
.key-term{font-size:.88rem;line-height:1.7;margin-bottom:6px;}
.key-term .term{font-weight:700;color:var(--green);}
.note-list{padding-left:20px;margin-bottom:8px;}
.note-list li{font-size:.86rem;line-height:1.7;color:#455a64;margin-bottom:4px;}
.note-list.sub{padding-left:32px;}
.note-list li.sub-item{list-style-type:circle;}

@media(max-width:768px){
  .reader-layout{flex-direction:column;}
  .reader-body{padding:16px 14px;margin-left:0;max-width:100%;}
  .reader-toc{display:none;}
  .reader-body{margin-left:0;margin-top:0;padding:16px 14px;}
  #mobile-toc-btn{display:flex!important;position:fixed;bottom:calc(var(--bottom-nav-h,60px) + 16px);right:16px;width:50px;height:50px;border-radius:50%;background:var(--green);color:#fff;font-size:1.1rem;align-items:center;justify-content:center;border:none;cursor:pointer;box-shadow:0 4px 16px rgba(27,94,32,.35);z-index:120;touch-action:manipulation;}
  #mobile-toc-panel{display:none;position:fixed;bottom:var(--bottom-nav-h,60px);left:0;right:0;background:#fff;border-top:2px solid var(--gp);z-index:150;max-height:55vh;overflow-y:auto;box-shadow:0 -4px 24px rgba(0,0,0,.18);}
  #mobile-toc-panel.show{display:block;}
  .reader-sec-nav{display:flex;align-items:center;gap:8px;padding:10px 12px;background:var(--ch1-light,#e2f5ec);border-radius:10px;margin-bottom:12px;border:1px solid var(--gp);}
  .reader-sec-nav-title{flex:1;font-size:.82rem;font-weight:700;color:var(--green);text-align:center;line-height:1.3;}
  .reader-sec-nav-btn{width:38px;height:38px;flex-shrink:0;border:none;background:none;color:var(--green);font-size:1.4rem;cursor:pointer;border-radius:8px;display:flex;align-items:center;justify-content:center;touch-action:manipulation;}
  .reader-sec-nav-btn:disabled{opacity:.25;pointer-events:none;}
  .reader-sec-nav-btn:active{background:var(--lgray);}
}

/* iPad mini 7 直向(744px)：reader-toc 可顯示但縮小 */
@media(max-width:820px) and (min-width:641px){
  .reader-layout{flex-direction:row;}
  .reader-toc{display:block;width:170px;min-width:170px;}
  .reader-body{padding:16px 18px;margin-left:10px;max-width:100%;}
  #mobile-toc-btn{display:none!important;}
  .kc-card{padding:10px 12px;}
  .kc-card-title{font-size:.83rem;}
  .kc-card p{font-size:.81rem;}
  .kc-table table{font-size:.79rem;}
  .kc-table th,.kc-table td{padding:7px 8px;}
  .quick-grid{grid-template-columns:1fr 1fr;}
  .stats-grid{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:640px){
  #mobile-toc-panel{
    position:fixed;bottom:var(--bottom-nav-h);left:0;right:0;
    background:#fff;border-top:1px solid var(--border);z-index:150;
    max-height:50vh;overflow-y:auto;box-shadow:0 -4px 20px rgba(0,0,0,.15);
    display:none;
  }
  #mobile-toc-panel.show{display:block;}
  .reader-toc{display:none;}
  .reader-body{-webkit-tap-highlight-color:transparent;margin:0;border-radius:var(--radius);}
  #mobile-toc-btn{display:block;}
}

/* ═══════════════════════════════════════════
   CONCEPT NOTES - 考點卡片
═══════════════════════════════════════════ */
.filter-bar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;overflow-x:auto;padding-bottom:4px;}
.chip{padding:5px 14px;border-radius:20px;font-size:.78rem;font-weight:600;cursor:pointer;border:1.5px solid var(--border);background:#fff;color:var(--gray);white-space:nowrap;transition:all var(--transition);}
.chip.active{background:var(--green);color:#fff;border-color:var(--green);}
.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:8px;}
.concept-card{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;cursor:pointer;transition:box-shadow var(--transition);display:flex;}
.concept-card:hover{box-shadow:var(--shadow-lg);}
.concept-card:hover .cc-stripe{opacity:.85;}
.cc-stripe{width:4px;flex-shrink:0;background:var(--green);transition:opacity var(--transition);}
.concept-card.expanded .cc-stripe{background:var(--blue);}
.cc-main{flex:1;min-width:0;padding:11px 14px;}
.concept-card-head{display:flex;align-items:center;gap:7px;}
.concept-card-head .ch-tag{font-size:.68rem;font-weight:700;color:var(--green);background:var(--gp);padding:2px 8px;border-radius:12px;white-space:nowrap;flex-shrink:0;}
.concept-card-head .badge{font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:10px;flex-shrink:0;}
.badge-必考{background:#fff3cd;color:#856404;}
.badge-重要{background:#d1ecf1;color:#0c5460;}
.concept-card-head h4{font-size:.88rem;font-weight:600;line-height:1.35;flex:1;}
.concept-card-head .expand-icon{color:var(--gray);transition:transform var(--transition);margin-left:4px;flex-shrink:0;font-size:.85rem;}
.concept-card.expanded .expand-icon{transform:rotate(90deg);}
.cc-preview{font-size:.77rem;color:var(--text-muted,#6b7280);line-height:1.45;margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%;}
.concept-card.expanded .cc-preview{display:none;}
.concept-card-body{padding:8px 0 4px;font-size:.82rem;display:none;}
.concept-card.expanded .concept-card-body{display:block;}
/* 考點卡片內部樣式 */
.kc-def{background:var(--gp);border-radius:7px;padding:8px 12px;margin-bottom:8px;line-height:1.65;color:#2d4a2d;}
.kc-table{overflow-x:auto;margin-bottom:8px;}
.kc-table table{width:100%;border-collapse:collapse;font-size:.79rem;}
.kc-table th{background:var(--green);color:#fff;padding:5px 8px;text-align:left;font-weight:600;}
.kc-table td{padding:5px 8px;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.5;}
.kc-table tr:last-child td{border-bottom:none;}

/* ── kc-extra 課文補充折疊區 ── */
.kc-extra{margin-top:8px;border-top:1px dashed #b8e4d0;}
.kc-extra-head{cursor:pointer;font-size:.78rem;color:#558b2f;padding:5px 0 2px;user-select:none;display:flex;align-items:center;gap:4px;font-weight:600;}
.kc-extra-head:hover{color:#2e7a52;}
.kx-arrow{font-size:.7rem;transition:transform .2s;}
.kc-extra.kx-open .kx-arrow{transform:rotate(90deg);}
.kc-extra-body{display:none;padding:6px 0 2px;font-size:.79rem;line-height:1.65;color:#37474f;}
.kc-extra.kx-open .kc-extra-body{display:block;}
.kc-extra-body b{color:#2e7a52;}
.kc-extra-body .xr{display:flex;gap:5px;margin-bottom:3px;}
.kc-extra-body .xl{background:#e2f5ec;color:#2e7a52;border-radius:4px;padding:1px 5px;font-size:.7rem;font-weight:700;white-space:nowrap;align-self:flex-start;margin-top:2px;}

/* ══ 永續課文頁面：全螢幕閱讀模式 ══ */
/* 當 textbook2 active，隱藏 sidebar 與 topbar */
/* tx2-mode：只隱藏左側 sidebar（由 tx-toc 取代），topbar 和 bottom-nav 保留一致性 */
body.tx2-mode #sidebar {display:none!important;}
.tx2-mode #sidebar.open{display:flex!important;}
body.tx2-mode #main {margin-left:0!important;padding-bottom:0!important;width:100%!important;}
body.tx2-mode #content {padding:0!important;max-width:unset!important;display:flex!important;flex-direction:column!important;width:100%!important;overflow-x:hidden!important;}
/* 高度由原有規則處理（含 header-h / bottom-nav-h），不需額外覆蓋 */
@media(max-width:1024px){
  body.tx2-mode #page-textbook2.active{
    height:calc(100vh - var(--header-h) - var(--bottom-nav-h) - env(safe-area-inset-bottom,0px))!important;
  }
}

#page-textbook2{display:none;flex-direction:column;overflow:hidden;}
#page-textbook2.active{
  display:flex;
  height:calc(100vh - var(--header-h));
  max-width:unset;
}
/* 有 bottom-nav 的情境（平板/手機）需要扣掉 bottom-nav 高度 */
@media(max-width:1299px){
  #page-textbook2.active{
    height:calc(100vh - var(--header-h) - var(--bottom-nav-h) - env(safe-area-inset-bottom,0px));
  }
}

/* ── TOC 側邊欄 ── */
.tx-toc{
  width:220px;min-width:200px;flex-shrink:0;
  background:#fff;
  border-right:1px solid #e2ede2;
  overflow-y:auto;
  display:flex;flex-direction:column;
  -webkit-overflow-scrolling:touch;
  box-shadow:2px 0 8px rgba(27,94,32,.06);
}

/* TOC 頂部標題列（含返回按鈕） */
.tx-toc-header{
  background:linear-gradient(135deg,#1b5c42 0%,#2e7a52 100%);
  padding:0;flex-shrink:0;
}
.tx-toc-back{
  display:flex;align-items:center;gap:8px;
  padding:10px 14px;cursor:pointer;
  font-size:.78rem;font-weight:700;color:rgba(255,255,255,.9);
  border-bottom:1px solid rgba(255,255,255,.15);
  transition:background .15s;
  background:none;border-left:none;border-right:none;border-top:none;
  width:100%;text-align:left;font-family:var(--font);
}
.tx-toc-back:hover{background:rgba(255,255,255,.1);}
.tx-toc-back-arrow{font-size:1rem;line-height:1;}
.tx-toc-title{
  font-size:.62rem;font-weight:800;color:rgba(255,255,255,.7);
  padding:8px 14px 9px;letter-spacing:.12em;text-transform:uppercase;
}

/* TOC 捲動區 */
.tx-toc-scroll{flex:1;overflow-y:auto;padding:6px 0 24px;}

/* 節標題（第X節） */
.tx-toc-item{
  display:block;padding:8px 14px 8px 12px;
  font-size:.78rem;font-weight:700;color:#1a2e1a;
  cursor:pointer;
  border-left:3px solid transparent;
  transition:all .15s cubic-bezier(.4,0,.2,1);
  line-height:1.35;margin-top:2px;
}
.tx-toc-item:hover{background:#edf6ed;color:#1b5c42;border-left-color:#b8e4d0;}
.tx-toc-item.tx-active{
  background:linear-gradient(90deg,#dff0df,#f0faf0);
  border-left-color:#2e7a52;color:#1b5c42;
}

/* 子項目 */
.tx-toc-sub{
  display:block;padding:4px 14px 4px 22px;
  font-size:.71rem;color:#5a7a5a;
  cursor:pointer;transition:all .12s;line-height:1.5;
  border-left:3px solid transparent;
}
.tx-toc-sub:hover{background:#f3faf3;color:#2e7a52;border-left-color:#b8e4d0;}
.tx-toc-sub.tx-active{background:#e2f5ec;color:#2e7a52;font-weight:600;border-left-color:#72c49a;}

/* TOC 章節分隔 */
.tx-toc-ch-label{
  font-size:.65rem;font-weight:800;color:#fff;letter-spacing:.1em;
  text-transform:uppercase;padding:8px 14px 5px;
  background:linear-gradient(135deg,#1b5c42,#2e7a52);
  margin-top:6px;
}
.tx-toc-divider{height:1px;background:#e8f0e8;margin:5px 12px 3px;}

.tx-row{display:flex;flex-direction:row;flex:1;min-height:0;overflow:hidden;}
/* 主內容區 */
.tx-body{
  flex:1;overflow-y:auto;padding:20px 28px 80px;
  -webkit-overflow-scrolling:touch;background:#fafcfa;
}

/* ── 課文內 inline font-size 補正（確保可讀性）── */
.tx-body div[style*="font-size:.74rem"],
.tx-body div[style*="font-size:.75rem"],
.tx-body div[style*="font-size:.76rem"],
.tx-body div[style*="font-size:.77rem"],
.tx-body div[style*="font-size:.78rem"],
.tx-body span[style*="font-size:.74rem"],
.tx-body span[style*="font-size:.75rem"],
.tx-body span[style*="font-size:.76rem"],
.tx-body span[style*="font-size:.77rem"],
.tx-body span[style*="font-size:.78rem"]
{ font-size:.84rem !important; }

.tx-body div[style*="font-size:.69rem"],
.tx-body div[style*="font-size:.7rem"],
.tx-body div[style*="font-size:.71rem"],
.tx-body div[style*="font-size:.72rem"],
.tx-body span[style*="font-size:.69rem"],
.tx-body span[style*="font-size:.7rem"],
.tx-body span[style*="font-size:.71rem"],
.tx-body span[style*="font-size:.72rem"],
.tx-body td[style*="font-size:.71rem"],
.tx-body td[style*="font-size:.72rem"]
{ font-size:.78rem !important; line-height:1.65 !important; }

.tx-body div[style*="font-size:.65rem"],
.tx-body div[style*="font-size:.68rem"],
.tx-body span[style*="font-size:.65rem"],
.tx-body span[style*="font-size:.68rem"]
{ font-size:.76rem !important; }

/* 章首 */
.tx-chapter-header{
  text-align:center;padding:28px 0 32px;
  border-bottom:3px solid #b8e4d0;margin-bottom:32px;
}
.tx-chapter-badge{
  display:inline-block;background:linear-gradient(135deg,#2e7a52,#3fa068);
  color:#fff;font-size:.75rem;font-weight:800;padding:5px 16px;
  border-radius:20px;margin-bottom:12px;letter-spacing:.05em;
}
.tx-chapter-title{font-size:1.6rem;font-weight:800;color:#1a1a1a;margin:4px 0 8px;}
.tx-chapter-sub{font-size:.82rem;color:#888;margin:0;}

/* 大節標題 h2 */
.tx-h2{
  font-size:1.08rem;font-weight:800;color:#1b5c42;
  margin:36px 0 14px;padding:11px 18px;
  background:linear-gradient(135deg,#e2f5ec,#f1f8f1);
  border-left:5px solid #2e7a52;border-radius:0 8px 8px 0;
  display:flex;align-items:center;gap:10px;
  box-shadow:0 1px 4px rgba(46,125,50,.1);
}
.tx-sec-num{
  background:#2e7a52;color:#fff;border-radius:50%;
  width:26px;height:26px;display:inline-flex;align-items:center;justify-content:center;
  font-size:.8rem;font-weight:800;flex-shrink:0;
}

/* 小節標題 h3 */
.tx-h3{
  font-size:.95rem;font-weight:700;color:#2e7a52;
  margin:24px 0 10px;padding:7px 0 7px 14px;
  border-left:3px solid #72c49a;
  display:flex;align-items:center;gap:6px;
}

/* 子標題 h4 */
.tx-h4{
  font-size:.9rem;font-weight:700;color:#2e7a52;margin:16px 0 6px;
  padding:0 0 0 10px;border-left:2px solid #b8e4d0;
}

/* h5 */
.tx-h5{font-size:.88rem;font-weight:700;color:#37474f;margin:14px 0 6px;padding-left:12px;border-left:2px solid #b0bec5;}
/* ── 課文圖表樣式 ─────────────────────────────── */
.tx-fig-wrap{margin:16px 0 20px;border:1px solid #e0e0e0;border-radius:10px;overflow:hidden;background:#fff;}
.tx-fig-label{background:linear-gradient(135deg,#e2f5ec,#f1f8f1);padding:8px 14px;font-size:.78rem;font-weight:700;color:#1b5c42;border-bottom:1px solid #b8e4d0;}

.tx-fig-from-chart .tx-fig-chart-body{padding:12px 14px;}
.tx-fig-note{padding:6px 14px;font-size:.72rem;color:#b71c1c;background:#fdf4e3;border-top:1px solid #f5d49a;}
.tx-fig-src{padding:6px 14px;font-size:.7rem;color:#888;border-top:1px solid #f0f0f0;background:#fafafa;}

/* 概念圖 */
.tx-concept-diagram{padding:16px;}
.tx-3col{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:10px;}
.tx-col-box{border:2px solid;border-radius:10px;padding:12px;text-align:center;}
.tx-col-icon{font-size:1.4rem;margin-bottom:6px;}
.tx-col-title{font-weight:800;font-size:.82rem;margin-bottom:4px;}
.tx-col-desc{font-size:.72rem;color:#555;line-height:1.5;}
.tx-center-badge{text-align:center;background:#1b5c42;color:#fff;border-radius:20px;padding:5px 16px;font-size:.75rem;font-weight:700;display:inline-block;margin:8px auto;display:flex;justify-content:center;}

/* 趨勢/柱狀 */
.tx-trend-chart,.tx-stacked-bars{padding:4px;}
.tx-trend-title,.tx-stacked-title{font-size:.78rem;font-weight:700;color:#333;margin-bottom:10px;text-align:center;}
.tx-trend-bars{display:flex;align-items:flex-end;gap:8px;height:80px;padding:0 8px;}
.tx-trend-item{display:flex;flex-direction:column;align-items:center;flex:1;}
.tx-trend-bar{width:100%;background:linear-gradient(180deg,#3fa068,#1b5c42);border-radius:3px 3px 0 0;}
.tx-trend-year{font-size:.65rem;color:#888;margin-top:3px;}
.tx-trend-note{font-size:.74rem;color:#555;text-align:center;margin-top:8px;padding:6px;background:#f5f5f5;border-radius:6px;}
.tx-stacked-legend{display:flex;gap:12px;font-size:.72rem;margin-bottom:8px;flex-wrap:wrap;}
.tx-legend-dot{display:inline-block;width:10px;height:10px;border-radius:2px;margin-right:3px;}
.tx-bar-row{display:flex;align-items:center;gap:6px;margin-bottom:4px;}
.tx-bar-year{font-size:.7rem;color:#555;width:30px;flex-shrink:0;}
.tx-bar-seg{height:18px;border-radius:2px;}

/* 巢狀圖框 */
.tx-nested-boxes{padding:4px;}
.tx-nest-box{margin:0;}
.tx-nest-label{font-weight:700;font-size:.8rem;margin-bottom:4px;}

/* 公式 */
.tx-formula-box{background:#f8fff8;border:2px solid #72c49a;border-radius:10px;padding:16px;text-align:center;}
.tx-formula-title{font-size:.8rem;font-weight:700;color:#1b5c42;margin-bottom:12px;}
.tx-formula{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:8px;margin-bottom:10px;}
.tx-f-pos{background:#ffebee;color:#c62828;border-radius:6px;padding:4px 10px;font-weight:700;font-size:.82rem;}
.tx-f-neg{background:#e2f5ec;color:#1b5c42;border-radius:6px;padding:4px 10px;font-weight:700;font-size:.82rem;}
.tx-f-op{color:#555;font-size:1rem;font-weight:700;}
.tx-f-zero{background:#1b5c42;color:#fff;border-radius:6px;padding:4px 14px;font-weight:800;font-size:1rem;}
.tx-formula-note{font-size:.74rem;color:#555;}

/* GRI樹 */
.tx-gri-tree{padding:4px;}
.tx-tree-root{text-align:center;background:#1b5c42;color:#fff;border-radius:20px;padding:6px 20px;font-weight:800;font-size:.82rem;margin-bottom:10px;display:inline-block;width:100%;box-sizing:border-box;}
.tx-tree-branches{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.tx-tree-branch{border:2px solid;border-radius:8px;padding:10px;overflow:hidden;}
.tx-tree-branch-title{font-weight:800;font-size:.78rem;margin-bottom:6px;}
.tx-tree-items{display:flex;flex-direction:column;gap:3px;}
.tx-tree-item{font-size:.7rem;color:#555;background:#fff;padding:3px 6px;border-radius:4px;}

/* 範疇圖 */
.tx-scope-diagram{padding:4px;}
.tx-scope-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.tx-scope-box{border-radius:8px;padding:10px;}
.tx-scope-num{font-size:.75rem;font-weight:800;margin-bottom:2px;}
.tx-scope-name{font-size:.78rem;font-weight:700;margin-bottom:4px;}
.tx-scope-desc{font-size:.71rem;color:#555;line-height:1.5;}
.tx-scope-items{display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;}
.tx-scope-tag{font-size:.7rem;background:#fff;border:1px solid #72c49a;border-radius:12px;padding:2px 8px;color:#2e7a52;}
.s3-full{display:block;}

/* 流程圖 */
.tx-flow{display:flex;flex-direction:column;align-items:center;padding:8px;}
.tx-flow-item{display:flex;align-items:flex-start;gap:10px;background:#f5f5f5;border-radius:8px;padding:10px 14px;width:100%;box-sizing:border-box;}
.tx-flow-num{background:#2e7a52;color:#fff;border-radius:50%;width:24px;height:24px;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;flex-shrink:0;}
.tx-flow-text{font-size:.78rem;color:#333;line-height:1.6;}
.tx-flow-arrow{color:#2e7a52;font-size:1rem;margin:2px 0;}

/* 描述框 */
.tx-desc-box{display:flex;gap:12px;align-items:flex-start;padding:12px;background:#f9fdf9;}
.tx-desc-icon{font-size:1.4rem;flex-shrink:0;}
.tx-desc-content{font-size:.78rem;color:#444;line-height:1.7;}

@media(max-width:599px){
  .tx-3col,.tx-tree-branches{grid-template-columns:1fr;}
  .tx-scope-row{grid-template-columns:1fr;}
  .tx-trend-bars{height:60px;}
}

.tx-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin:10px 0 16px;}
.tx-table{width:100%;border-collapse:collapse;font-size:.84rem;min-width:320px;}
.tx-table caption{font-size:.74rem;font-weight:700;color:#546e7a;text-align:left;padding:4px 0 6px;caption-side:top;}
.tx-table th{background:#e2f5ec;color:#1b5c42;font-weight:700;padding:8px 12px;border:1px solid #b8e4d0;text-align:left;font-size:.82rem;}
.tx-table td{padding:7px 12px;border:1px solid #e0e0e0;vertical-align:top;line-height:1.7;color:#37474f;}
.tx-table tr:nth-child(even) td{background:#fafafa;}


/* 正文段落 */
.tx-p{font-size:.88rem;line-height:1.9;color:#37474f;margin:0 0 12px;}
.tx-body p{font-size:.88rem;line-height:1.9;color:#37474f;margin:0 0 10px;}

/* JS清理後保留的有意義段落標籤（pill 樣式） */
.tx-p-label{
  display:inline-block;
  background:#e8f5ee;color:#2e7a52;
  font-weight:700;font-size:.74rem;
  padding:0 8px;border-radius:10px;
  margin-right:6px;vertical-align:baseline;
  white-space:nowrap;line-height:1.9;
}

/* 清單 */
.tx-ul{margin:6px 0 14px 0;padding:0;list-style:none;}
.tx-ul li{
  font-size:.87rem;line-height:1.75;color:#37474f;
  margin-bottom:6px;padding:5px 12px 5px 30px;
  position:relative;border-radius:4px;background:#f8fdf8;
}
.tx-ul li::before{
  content:'▸';position:absolute;left:11px;color:#72c49a;font-size:.76rem;top:6px;
}
.tx-ul li b{color:#1b5c42;}

/* 編號要點 ①② */
.tx-point{
  font-size:.83rem;line-height:1.7;color:#333;
  margin:4px 0 4px 4px;padding:4px 10px 4px 30px;
  position:relative;
}
.tx-point::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
  background:#b8e4d0;border-radius:2px;
}

/* (1)(2) 子項目 */
.tx-sub{
  font-size:.82rem;line-height:1.7;color:#444;
  margin:3px 0 3px 8px;padding:3px 8px 3px 12px;
  border-left:2px solid #dcedc8;
}

/* 縮寫高亮 */
.tx-abbr{
  color:#89b4d4;font-weight:700;font-size:.82rem;
  background:#e8f2f9;padding:0 3px;border-radius:3px;
}

/* 考點框 */
.tx-tip{
  background:#fdf4e3;border-left:4px solid #d4a56a;
  padding:8px 12px;border-radius:0 6px 6px 0;
  font-size:.81rem;line-height:1.65;color:#5d4037;margin:8px 0 12px;
}
.tx-tip::before{content:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> 考點：';font-weight:700;}

/* 數據表格風格 */
.tx-num{
  font-size:.83rem;line-height:1.7;color:#333;margin:5px 0 6px;
  display:flex;align-items:flex-start;gap:8px;
}
.tx-num-badge{
  display:inline-flex;align-items:center;justify-content:center;
  min-width:20px;height:20px;background:#2e7a52;color:#fff;
  border-radius:50%;font-size:.7rem;font-weight:800;flex-shrink:0;margin-top:2px;
}

/* 結尾 */
.tx-section{margin-bottom:36px;}
.tx-end-note{
  text-align:center;color:#aaa;font-size:.77rem;
  padding:32px 0;border-top:1px dashed #ccc;margin-top:32px;
}

/* ══════════════════════════════════════
   課文內嵌圖表樣式
══════════════════════════════════════ */
.tx-chart{
  background:#fff;border:1px solid #e0ede0;border-radius:12px;
  margin:16px 0 20px;overflow:hidden;
  box-shadow:0 2px 10px rgba(27,94,32,.07);
}
.tx-chart-title{
  background:linear-gradient(135deg,#e2f5ec,#f1f8f1);
  padding:10px 16px;display:flex;align-items:center;gap:8px;
  border-bottom:1px solid #d4e8d4;
  font-size:.8rem;font-weight:800;color:#1b5c42;
  letter-spacing:.02em;
}
.tx-chart-title .chart-icon{font-size:1rem;}
.tx-chart-body{padding:16px;}

/* 巢狀圓圈圖（永續金融涵蓋範圍）*/
.nest-chart{display:flex;flex-direction:column;gap:0;padding:4px 0;}
.nest-ring{
  border-radius:10px;padding:10px 14px;
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:3px;position:relative;
}
.nest-ring::before{
  content:'▸';position:absolute;left:-2px;top:50%;transform:translateY(-50%);
  font-size:.7rem;color:#72c49a;opacity:0;
}
.nr4{background:#1b5c42;color:#fff;}
.nr3{background:#2e7a52;color:#fff;}
.nr2{background:#72c49a;color:#1b2e1b;}
.nr1{background:#e2f5ec;color:#1b5c42;border:1.5px solid #b8e4d0;}
.nest-ring-label{font-weight:800;font-size:.82rem;}
.nest-ring-desc{font-size:.72rem;opacity:.85;text-align:right;}
.nest-arrow{text-align:center;font-size:.65rem;color:#999;line-height:1.2;margin:1px 0;}

/* 碳定價機制橫條圖 */
.carbon-bars{padding:4px 0;}
.carbon-bar-row{
  display:flex;align-items:center;gap:10px;margin-bottom:10px;
}
.carbon-bar-label{width:110px;font-size:.75rem;font-weight:700;color:#263238;flex-shrink:0;}
.carbon-bar-track{flex:1;background:#f0f4f0;border-radius:6px;height:28px;overflow:hidden;position:relative;}
.carbon-bar-fill{
  height:100%;border-radius:6px;
  display:flex;align-items:center;padding-left:10px;
  font-size:.7rem;font-weight:700;color:#fff;
  transition:width .8s ease;
}
.carbon-bar-tag{width:36px;font-size:.7rem;font-weight:700;color:#546e7a;text-align:right;flex-shrink:0;}
.cbf-high{background:linear-gradient(90deg,#c62828,#d04555);}
.cbf-mid{background:linear-gradient(90deg,#c87848,#c8906a);}
.cbf-low{background:linear-gradient(90deg,#2e7a52,#3fa068);}
.carbon-note{
  display:flex;gap:10px;margin-top:12px;
}
.carbon-note-box{
  flex:1;border-radius:8px;padding:9px 12px;font-size:.75rem;line-height:1.6;
}
.cnb-fee{background:#e2f5ec;border-left:3px solid #2e7a52;}
.cnb-tax{background:#fdf0e0;border-left:3px solid #c87848;}
.cnb-title{font-weight:800;margin-bottom:3px;}

/* SDGs 彩色格子 */
.sdgs-grid{
  display:grid;grid-template-columns:repeat(6,1fr);gap:5px;
  padding:4px 0;
}
.sdg-cell{
  border-radius:6px;padding:6px 4px;text-align:center;cursor:default;
  transition:transform .15s;
}
.sdg-cell:hover{transform:scale(1.08);}
.sdg-num{font-size:.78rem;font-weight:800;color:#fff;line-height:1;}
.sdg-name{font-size:.6rem;color:rgba(255,255,255,.9);line-height:1.3;margin-top:2px;}
.sdg-star-badge{
  display:inline-block;background:#fff;color:#a21942;
  font-size:.55rem;font-weight:800;border-radius:3px;padding:0 3px;margin-top:2px;
}

/* 國際協議時間軸 */
.intl-timeline{padding:8px 0;}
.itl-item{
  display:flex;align-items:flex-start;gap:12px;
  padding:6px 0 6px 2px;
  position:relative;
}
.itl-item:not(:last-child)::after{
  content:'';position:absolute;left:28px;top:32px;bottom:-6px;width:2px;
  background:linear-gradient(180deg,#b8e4d0,#e0eae0);
}
.itl-dot{
  width:18px;height:18px;border-radius:50%;flex-shrink:0;margin-top:2px;
  display:flex;align-items:center;justify-content:center;
  font-size:.6rem;font-weight:800;color:#fff;
  box-shadow:0 1px 4px rgba(0,0,0,.15);
}
.itl-year{font-size:.72rem;font-weight:800;color:#546e7a;width:38px;flex-shrink:0;margin-top:3px;}
.itl-content{flex:1;}
.itl-title{font-size:.79rem;font-weight:700;color:#1a2e1a;line-height:1.3;}
.itl-desc{font-size:.7rem;color:#546e7a;margin-top:2px;line-height:1.5;}
.itl-tag{
  display:inline-block;font-size:.62rem;font-weight:700;padding:1px 7px;
  border-radius:10px;margin-top:3px;
}

/* 淨零路徑四大轉型 */
.net0-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:8px;
}
.net0-card{
  border-radius:9px;padding:11px 13px;
  border-left:4px solid;
}
.net0-card-title{font-size:.79rem;font-weight:800;margin-bottom:5px;display:flex;align-items:center;gap:6px;}
.net0-card-body{font-size:.71rem;line-height:1.6;color:#546e7a;}
.n0c-energy{background:#e2f5ec;border-color:#2e7a52;}
.n0c-industry{background:#e8f2f9;border-color:#89b4d4;}
.n0c-life{background:#fdf0e0;border-color:#c87848;}
.n0c-society{background:#ede8f7;border-color:#8872b8;}
.net0-base{
  display:flex;gap:8px;margin-top:8px;
}
.net0-base-card{
  flex:1;border-radius:8px;padding:9px 12px;
  background:#37474f;color:#fff;text-align:center;
}
.net0-base-title{font-size:.72rem;font-weight:800;margin-bottom:4px;}
.net0-base-body{font-size:.68rem;opacity:.8;line-height:1.5;}

/* 盤查時程表 */
.roadmap-table{width:100%;border-collapse:collapse;font-size:.72rem;}
.roadmap-table th{
  background:#1b5c42;color:#fff;padding:7px 8px;
  text-align:center;font-weight:700;font-size:.69rem;
}
.roadmap-table td{
  padding:6px 8px;border:1px solid #e0ede0;
  text-align:center;line-height:1.4;vertical-align:middle;
}
.roadmap-table tr:nth-child(even) td{background:#f7fbf7;}
.rm-scan{background:#e8f2f9;color:#89b4d4;border-radius:4px;padding:1px 5px;font-weight:700;font-size:.67rem;white-space:nowrap;}
.rm-conf{background:#fdf0e0;color:#c87848;border-radius:4px;padding:1px 5px;font-weight:700;font-size:.67rem;white-space:nowrap;}
.rm-year{font-weight:800;color:#1b5c42;}

/* 京都 vs 巴黎比較 */
.compare-2col{display:flex;gap:10px;}
.cmp-col{flex:1;border-radius:9px;overflow:hidden;}
.cmp-head{padding:9px 13px;font-size:.77rem;font-weight:800;color:#fff;}
.cmp-body{padding:10px 13px;}
.cmp-row{
  display:flex;align-items:flex-start;gap:7px;
  padding:5px 0;border-bottom:1px solid rgba(0,0,0,.06);
  font-size:.72rem;line-height:1.5;
}
.cmp-row:last-child{border-bottom:none;}
.cmp-icon{flex-shrink:0;font-size:.8rem;margin-top:1px;}
.cmp-kyoto .cmp-head{background:#89b4d4;}
.cmp-kyoto .cmp-body{background:#e8f0fb;}
.cmp-paris .cmp-head{background:#2e7a52;}
.cmp-paris .cmp-body{background:#e2f5ec;}

/* 歐盟框架 */
.eu-framework{display:flex;flex-direction:column;gap:7px;}
.eu-card{
  display:flex;align-items:flex-start;gap:10px;
  border-radius:8px;padding:10px 13px;border-left:4px solid;
}
.eu-card-badge{
  font-size:.65rem;font-weight:800;padding:3px 9px;border-radius:10px;
  color:#fff;flex-shrink:0;white-space:nowrap;margin-top:1px;
}
.eu-card-content{flex:1;}
.eu-card-title{font-size:.78rem;font-weight:700;margin-bottom:3px;}
.eu-card-desc{font-size:.7rem;color:#546e7a;line-height:1.55;}
.eu-taxonomy{background:#e2f5ec;border-color:#2e7a52;}
.eu-taxonomy .eu-card-badge{background:#2e7a52;}
.eu-sfdr{background:#e8f2f9;border-color:#89b4d4;}
.eu-sfdr .eu-card-badge{background:#89b4d4;}
.eu-csrd{background:#fdf0e0;border-color:#c87848;}
.eu-csrd .eu-card-badge{background:#c87848;}
.eu-cbam{background:#fce4ec;border-color:#c62828;}
.eu-cbam .eu-card-badge{background:#c62828;}

/* 綠色金融行動方案演進 */
.gfa-timeline{display:flex;gap:0;align-items:stretch;margin:4px 0;}
.gfa-item{
  flex:1;text-align:center;padding:12px 8px;position:relative;
  border-top:3px solid;
}
.gfa-item::after{
  content:'→';position:absolute;right:-8px;top:50%;transform:translateY(-50%);
  font-size:.8rem;color:#999;z-index:1;
}
.gfa-item:last-child::after{display:none;}
.gfa-ver{font-size:.72rem;font-weight:800;margin-bottom:4px;}
.gfa-year{font-size:.65rem;color:#888;margin-bottom:5px;}
.gfa-theme{font-size:.73rem;font-weight:700;margin-bottom:4px;}
.gfa-desc{font-size:.62rem;color:#546e7a;line-height:1.5;}
.gfa1{border-color:#72c49a;background:#f1f8f1;}
.gfa1 .gfa-ver{color:#2e7a52;}
.gfa2{border-color:#42a5f5;background:#e8f4fe;}
.gfa2 .gfa-ver{color:#89b4d4;}
.gfa3{border-color:#26a69a;background:#e0f2f1;}
.gfa3 .gfa-ver{color:#4a9480;}
.gfa4{border-color:#ff7043;background:#fdf0e0;}
.gfa4 .gfa-ver{color:#b86840;}

@media(max-width:599px){
  .sdgs-grid{grid-template-columns:repeat(4,1fr);}
  .net0-grid{grid-template-columns:1fr;}
  .compare-2col{flex-direction:column;}
  .gfa-timeline{flex-direction:column;gap:6px;}
  .gfa-item::after{display:none;}
  .carbon-note{flex-direction:column;}
}

/* 捲動進度條 */
/* ── 閱讀進度條 ── */
.tx-progress-bar{
  flex-shrink:0;
  background:#fff;
  border-bottom:2px solid #e0ede0;
  padding:7px 20px;
  display:flex; align-items:center; gap:8px;
  box-shadow:0 2px 6px rgba(27,94,32,.07);
  position:relative; overflow:hidden;
}
/* 章節 pill 按鈕 */
.tx-ch-pill{
  padding:4px 14px; border-radius:20px; border:1.5px solid #b8e4d0;
  font-size:.76rem; font-weight:600; color:#2e7a52;
  cursor:pointer; background:#fff;
  transition:all .15s; white-space:nowrap; flex-shrink:0;
}
.tx-ch-pill:hover{ background:#e2f5ec; border-color:#72c49a; }
.tx-ch-pill.active{ background:var(--green); color:#fff; border-color:var(--green); }
/* 右側進度標籤 */
.tx-prog-label{
  margin-left:auto; flex-shrink:0;
  font-size:.7rem; font-weight:700; color:var(--green);
  white-space:nowrap; opacity:.75;
}
/* 底部極細進度線 */
.tx-prog-track{
  position:absolute; bottom:0; left:0; right:0;
  height:2px; background:#e8f0e8; pointer-events:none;
}
.tx-progress-fill{
  height:100%;
  background:linear-gradient(90deg,#2e7a52,#72c49a);
  width:0%; transition:width .12s ease;
}
.tx-prog-icon{ display:none; }

/* ── 手機版 ── */
@media(max-width:768px){
  #page-textbook2.active{
    flex-direction:column !important;
    height:calc(100vh - var(--header-h) - var(--bottom-nav-h) - env(safe-area-inset-bottom,0px));
  }
  /* tx-row：寬度鏈確保，clip 裁剪橫向溢出（不影響 overflow-y） */
  .tx-row{flex-direction:column;min-width:0;width:100%;overflow-x:clip;}
  .tx-toc{
    width:100%;min-width:unset;flex-shrink:0;
    height:auto;max-height:36px;
    border-right:none;border-bottom:1px solid #dce8dc;
    overflow:hidden;transition:max-height .3s ease;
    box-shadow:none;
  }
  .tx-toc-scroll{
    overflow-x:auto;overflow-y:hidden;
    display:flex;flex-direction:row;
    white-space:nowrap;padding:6px 8px;
    gap:0;
  }
  .tx-toc-ch-label{display:none;}
  .tx-toc-divider{display:none;}
  .tx-toc-item{
    display:inline-block;padding:4px 12px;font-size:.74rem;
    border-left:none;border-bottom:2px solid transparent;
    border-radius:16px;margin:0 4px 0 0;
    white-space:nowrap;background:#f0f6f0;
  }
  .tx-toc-item.tx-active{background:var(--gp);color:var(--green);border-bottom:none;}
  .tx-toc-sub{display:none;}
  .tx-toc.toc-open{max-height:60vh;overflow-y:auto;}
  .tx-toc.toc-open .tx-toc-sub{display:block;}
  .tx-toc-toggle-btn{display:inline-flex;}

  /* tx-body：min-width:0 + overflow-x:clip（可與 overflow-y:auto 並存，不會互相覆蓋）*/
  .tx-body{padding:14px 14px 80px;min-width:0;width:100%;overflow-x:clip;}

  .tx-progress-bar{margin:0 -14px 12px;}
  .tx-h2{font-size:.98rem;padding:9px 12px;margin:24px 0 10px;}
  .tx-h3{font-size:.9rem;margin:18px 0 8px;}
  .tx-p{font-size:.85rem;}
  .tx-ul li{font-size:.84rem;}

  /* ── 課文內容：防止橫向溢出 ── */
  .tx-body *{max-width:100%;box-sizing:border-box;min-width:0;}

  /* 多欄 grid → 單欄 */
  .tx-body .kc-3cards,.tx-body .kc-4cards,
  .tx-body .kc-5grid,.tx-body .kc-6grid,
  .tx-body .kc-3col,.tx-body .kc-4grid,
  .tx-body .kc-row-2,.tx-body .kc-2col,
  .tx-body .tx-3col,.tx-body .tx-tree-branches,
  .tx-body .tx-scope-row,.tx-body .sfdr-grid,
  .tx-body .risk-grid,.tx-body .im-grid,
  .tx-body .net0-grid,.tx-body .fw-col-wrap{
    grid-template-columns:1fr !important;
    display:grid;
  }

  /* 比較卡 → 單欄 */
  .tx-body .kc-compare{flex-direction:column;gap:8px;}
  .tx-body .kc-compare-col{width:100%;min-width:0;}

  /* SDGs grid → 2欄 */
  .tx-body .sdgs-grid{grid-template-columns:repeat(2,1fr) !important;}

  /* 表格與圖表容器：允許橫向捲動 */
  .tx-body .kc-table,.tx-body .tx-table-wrap,
  .tx-body .rich-table-wrap,.tx-body .kc-chart-embed,
  .tx-body .timeline-wrap,.tx-body .tl-wrap{
    overflow-x:auto;-webkit-overflow-scrolling:touch;max-width:100%;
  }
  /* SVG 時間軸：縮放到適合寬度 */
  .tx-body .tl-wrap svg,.tx-body .tl-svg{max-width:100%;height:auto;}

  /* Canvas 圖表：強制 100% 寬 */
  .tx-body canvas{max-width:100%!important;width:100%!important;}

  /* 範疇一二三圖 → 直排 */
  .tx-body .scope-boxes{flex-direction:column;align-items:stretch;}
  .tx-body .scope-arrow{transform:rotate(90deg);text-align:center;}

  /* inline style grid 兩欄 → 單欄 */
  .tx-body [style*="grid-template-columns:1fr 1fr"],
  .tx-body [style*="grid-template-columns: 1fr 1fr"]{
    grid-template-columns:1fr !important;
  }

  /* 卡片不設 min-width */
  .tx-body .kc-card,.tx-body .sfdr-col,
  .tx-body .im-item{min-width:0!important;width:100%;}

  /* 段落和行內內容不換行設定清除 */
  .tx-body p,.tx-body .tx-p{word-break:break-word;overflow-wrap:break-word;}
}


/* 回到頂部 */
.tx-back-top{
  position:fixed;right:16px;bottom:80px;z-index:300;
  width:36px;height:36px;border-radius:50%;
  background:var(--green);color:#fff;border:none;
  font-size:1rem;cursor:pointer;display:none;
  align-items:center;justify-content:center;
  box-shadow:0 2px 8px rgba(46,125,50,.4);
  transition:all .2s;
}
.tx-back-top.visible{display:flex;}
.kc-tip{background:#fdf4e3;border-left:3px solid #d4a56a;padding:7px 10px;border-radius:0 6px 6px 0;font-size:.79rem;line-height:1.6;color:#5d4037;}


/* ═══════════════════════════════════════════
   QUIZ & EXAM
═══════════════════════════════════════════ */
.quiz-controls{background:var(--card);border-radius:var(--radius);padding:18px 20px;margin-bottom:16px;box-shadow:var(--shadow);display:flex;flex-wrap:wrap;gap:10px;align-items:center;}
.quiz-controls label{font-size:.82rem;color:var(--gray);font-weight:600;}
.quiz-controls select,.quiz-controls button{padding:8px 14px;border-radius:8px;border:1px solid var(--border);font-size:.87rem;cursor:pointer;font-family:var(--font);}
.quiz-controls select{background:#fff;}
.btn-go{background:var(--green);color:#fff;border:none!important;font-weight:700;}
.btn-go:hover{background:#1b5c42;}
.btn-reset{background:#fff;color:var(--gray);}
.btn-reset:hover{background:var(--lgray);}
.prog-bar-wrap{background:var(--card);border-radius:var(--radius);padding:10px 16px;margin-bottom:16px;box-shadow:var(--shadow);}
.prog-bar-outer{background:var(--lgray);border-radius:8px;height:10px;overflow:hidden;margin-bottom:6px;}
.prog-bar-inner{height:100%;background:var(--gl);border-radius:8px;transition:width .4s;}
.prog-txt{font-size:.78rem;color:var(--gray);display:flex;justify-content:space-between;}
.q-card{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);padding:24px 26px;margin-bottom:16px;border-left:5px solid var(--green);animation:fadeUp .3s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.q-meta{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:12px;}
.q-tag{font-size:.7rem;font-weight:700;padding:2px 9px;border-radius:12px;}
.tag-green{background:var(--gp);color:var(--green);}
.tag-blue{background:var(--bp);color:var(--blue);}
.tag-gray{background:var(--lgray);color:var(--gray);}
.q-stem{font-size:.97rem;line-height:1.75;font-weight:500;margin-bottom:16px;}
.options{display:grid;gap:9px;}
.opt{display:flex;align-items:flex-start;gap:10px;padding:13px 14px;min-height:48px;border-radius:10px;border:2px solid var(--border);cursor:pointer;transition:all .18s;background:#fff;font-size:.9rem;line-height:1.5;-webkit-user-select:none;user-select:none;touch-action:manipulation;}
.opt:hover:not(.disabled){border-color:var(--gl);background:var(--gp);}
.opt .letter{width:24px;height:24px;min-width:24px;border-radius:50%;background:var(--lgray);color:var(--gray);font-weight:700;font-size:.78rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.opt.selected{border-color:var(--blue);background:var(--bp);}
.opt.selected .letter{background:var(--blue);color:#fff;}
.opt.correct{border-color:var(--green);background:var(--gp);}
.opt.correct .letter{background:var(--green);color:#fff;}
.opt.answered-sel{border:2px solid var(--blue)!important;background:rgba(45,74,110,.07)!important;font-weight:600;}
.opt.wrong{border-color:var(--red);background:var(--rp);}
.opt.wrong .letter{background:var(--red);color:#fff;}
.opt.disabled{pointer-events:none;opacity:.85;cursor:not-allowed;}
.exp-box{margin-top:14px;padding:12px 16px;border-radius:10px;background:var(--gp);border-left:4px solid var(--green);font-size:.86rem;line-height:1.7;display:none;}
.exp-box.show{display:block;}
.exp-box strong{color:var(--green);}
.q-nav{display:flex;justify-content:space-between;align-items:center;margin-top:4px;}
.q-nav button{padding:9px 20px;border-radius:8px;border:none;cursor:pointer;font-family:var(--font);font-size:.87rem;font-weight:600;transition:background .2s;}
.btn-prev{background:var(--lgray);color:var(--gray);}
.btn-next{background:var(--green);color:#fff;}
.btn-submit{background:var(--orange);color:#fff;}
.q-nav button.btn-prev:hover{background:var(--border);}
.q-nav button.btn-next:hover{background:#1b5c42;}

/* Exam timer */
.exam-timer{
  position:sticky;top:var(--header-h);z-index:50;
  background:#fff;border-bottom:1px solid var(--border);
  padding:8px 16px;display:flex;align-items:center;justify-content:space-between;
  margin:-24px -24px 20px;
}
.timer-display{font-size:1.1rem;font-weight:700;color:var(--green);font-variant-numeric:tabular-nums;}
.timer-display.warn{color:var(--orange);}
.timer-display.critical{color:var(--red);animation:pulse .5s infinite alternate;}
@keyframes pulse{from{opacity:1}to{opacity:.5}}

/* ═══════════════════════════════════════════
   RESULT PANEL
═══════════════════════════════════════════ */
.result-panel{background:var(--card);border-radius:16px;box-shadow:var(--shadow-lg);padding:32px;text-align:center;animation:fadeUp .4s ease;}
.result-panel h2{font-size:1.6rem;color:var(--green);margin-bottom:8px;}
.score-ring{width:130px;height:130px;position:relative;margin:20px auto;}
.score-ring svg{width:100%;height:100%;transform:rotate(-90deg);}
.score-ring circle{fill:none;stroke-width:12;}
.score-ring .bg-ring{stroke:var(--lgray);}
.score-ring .fg-ring{stroke:var(--gl);stroke-linecap:round;transition:stroke-dashoffset 1s ease;}
.score-pct{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:1.7rem;font-weight:900;color:var(--green);}
.result-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:20px 0;}
.rs-box{padding:14px;border-radius:10px;}
.rs-box .rs-num{font-size:1.5rem;font-weight:800;}
.rs-correct{background:var(--gp);color:var(--green);}
.rs-wrong{background:var(--rp);color:var(--red);}
.rs-skip{background:var(--lgray);color:var(--gray);}
.result-actions{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:10px;}
.result-actions button{padding:10px 22px;border-radius:10px;border:none;cursor:pointer;font-family:var(--font);font-size:.9rem;font-weight:700;}

/* ═══════════════════════════════════════════
   PROGRESS PAGE
═══════════════════════════════════════════ */
.progress-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;}
.prog-card{background:var(--card);border-radius:var(--radius);padding:20px;box-shadow:var(--shadow);}
.prog-card h3{font-size:.9rem;font-weight:700;color:var(--gray);margin-bottom:16px;text-transform:uppercase;letter-spacing:.5px;}
#exam-analysis-header:hover{background:#f0f5fc!important;}
#exam-analysis-header:active{background:#e6eef8!important;}
#year-dist-toggle:hover{filter:brightness(.97);}
.donut-wrap{width:140px;height:140px;position:relative;margin:0 auto 12px;}
.donut-wrap svg{width:100%;height:100%;transform:rotate(-90deg);}
.donut-label{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:1.3rem;font-weight:900;}
.donut-sublabel{font-size:.7rem;color:var(--gray);margin-top:2px;}
.history-list{max-height:300px;overflow-y:auto;}
.history-item{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);font-size:.83rem;}
.history-item:last-child{border-bottom:none;}
.history-badge{padding:3px 10px;border-radius:12px;font-weight:700;font-size:.75rem;}







/* Toast */
.toast{
  position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);
  background:#263238;color:#fff;padding:10px 20px;border-radius:8px;
  font-size:.85rem;z-index:999;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

@media(max-width:640px){
  .stats-grid{grid-template-columns:repeat(2,1fr);gap:10px;}
  .stat-card{padding:14px 10px;}
  .stat-card .stat-num{font-size:1.45rem;}
  .quick-grid{grid-template-columns:1fr;}
  .progress-grid{grid-template-columns:1fr;}
  .exam-timer{margin:-12px -12px 14px;padding:8px 12px;}
  .result-stats{grid-template-columns:repeat(3,1fr);}
  .q-card{padding:16px 12px;}
  .welcome-banner{grid-template-columns:1fr;}
  .wb-left h2{font-size:1.2rem;}
  .wb-left{padding:20px 18px;}
  .wb-right{padding:16px 18px;}
}

/* ═══════════════════════════════════════════
   CHEATSHEET PAGE
═══════════════════════════════════════════ */
.cs-section{margin-bottom:24px;}
.cs-section-title{display:flex;align-items:center;gap:8px;font-size:1rem;font-weight:800;color:var(--green);margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid var(--gp);}
.cs-section-title span{font-size:1.2rem;}
.cs-table{width:100%;border-collapse:collapse;background:var(--card);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);}
.cs-table th{background:var(--green);color:#fff;padding:8px 14px;text-align:left;font-size:.8rem;font-weight:700;}
.cs-table td{padding:9px 14px;border-bottom:1px solid var(--border);font-size:.85rem;line-height:1.7;vertical-align:top;}
.cs-table tr:last-child td{border-bottom:none;}
.cs-table tr:nth-child(even) td{background:#f8fdf8;}
.cs-key{font-weight:800;color:var(--green);white-space:nowrap;font-size:.92rem;}
.cs-key-blue{font-weight:800;color:var(--blue);white-space:nowrap;}
.cs-note{font-size:.75rem;color:var(--gray);margin-top:3px;}
.cs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:20px;}
@media(max-width:640px){.cs-grid{grid-template-columns:1fr;}}


/* ═══════════════════════════════════════════
   TEXTBOOK PAGE
═══════════════════════════════════════════ */
.tb-header{background:linear-gradient(135deg,#89b4d4,#89b4d4);color:#fff;border-radius:16px;padding:20px 24px;margin-bottom:18px;}
.tb-header h2{font-size:1.2rem;margin-bottom:4px;}
.tb-header p{font-size:.84rem;opacity:.88;}
.tb-controls{display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin-bottom:16px;background:var(--card);padding:14px 16px;border-radius:var(--radius);box-shadow:var(--shadow);}
.tb-controls label{font-size:.82rem;color:var(--gray);font-weight:600;}
.tb-controls select{padding:5px 10px;border-radius:8px;border:1.5px solid var(--border);font-size:.82rem;font-family:var(--font);background:#fff;}
.tb-controls button{padding:6px 16px;border-radius:8px;border:none;font-family:var(--font);font-size:.82rem;font-weight:700;cursor:pointer;transition:all var(--transition);}
.tb-btn-start{background:var(--blue);color:#fff;}
.tb-btn-start:hover{background:#89b4d4;}
.tb-q-area{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);padding:24px;margin-bottom:12px;}
.tb-progress{font-size:.8rem;color:var(--gray);margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;}
.tb-progress-bar{height:4px;background:var(--border);border-radius:2px;margin-bottom:16px;}
.tb-progress-bar-fill{height:4px;background:var(--blue);border-radius:2px;transition:width .3s;}
.tb-stem{font-size:.95rem;font-weight:600;line-height:1.7;margin-bottom:18px;color:#1a2a1a;}
.tb-opts{display:flex;flex-direction:column;gap:9px;}
.tb-opt{padding:11px 16px;border-radius:10px;border:1.5px solid var(--border);background:#fff;cursor:pointer;font-size:.87rem;line-height:1.5;transition:all var(--transition);text-align:left;}
.tb-opt:hover:not(:disabled){border-color:var(--blue);background:#e8f2f9;}
.tb-opt.correct{border-color:#2e7a52;background:#e2f5ec;color:#1b5c42;font-weight:700;}
.tb-opt.wrong{border-color:#c62828;background:#ffebee;color:#b71c1c;}
.tb-opt:disabled{cursor:default;}
.tb-explanation{margin-top:14px;padding:12px 14px;background:#f0f4ff;border-left:3px solid var(--blue);border-radius:0 8px 8px 0;font-size:.83rem;line-height:1.7;color:#37474f;display:none;}
.tb-explanation.show{display:block;}
.tb-nav{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;}
.tb-nav button{padding:8px 20px;border-radius:10px;border:none;font-family:var(--font);font-weight:700;font-size:.85rem;cursor:pointer;transition:all var(--transition);}
.tb-btn-next{background:var(--green);color:#fff;}
.tb-btn-next:hover{background:#1b5c42;}
.tb-btn-prev{background:var(--gp);color:var(--green);border:1.5px solid var(--green);}
.tb-result{background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);padding:28px;text-align:center;}
.tb-score-circle{width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,#89b4d4,#42a5f5);color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 16px;box-shadow:0 4px 20px rgba(21,101,192,.3);}
.tb-score-circle .score-num{font-size:1.8rem;font-weight:800;line-height:1;}
.tb-score-circle .score-label{font-size:.68rem;opacity:.88;}
.tb-stat-row{display:flex;justify-content:center;gap:24px;margin:12px 0 20px;}
.tb-stat{text-align:center;}
.tb-stat .n{font-size:1.3rem;font-weight:800;color:var(--blue);}
.tb-stat .l{font-size:.75rem;color:var(--gray);}





/* ═══════════════════════════════════════════
   精華筆記 — 富文本視覺化元件
═══════════════════════════════════════════ */

/* ── 通用 tags ──────────────────────────── */
.tag{
  display:inline-block; padding:2px 8px; border-radius:10px;
  font-size:.72rem; font-weight:700; white-space:nowrap;
}
.tag-green{ background:var(--gp); color:var(--green); }
.tag-blue { background:#e8f2f9; color:#89b4d4; }
.tag-orange{ background:#fdf0e0; color:#c87848; }
.tag-gray { background:var(--lgray); color:var(--gray); }
.row-highlight{ background:#f1f8e9; }
.row-na td{ color:var(--gray); text-decoration:line-through; }
.kc-num{ font-size:1.1em; font-weight:800; color:var(--green); }

/* ── 表格 ───────────────────────────────── */
.rich-table-wrap{ overflow-x:auto; margin:10px 0 14px; border-radius:10px; }
.rich-table{
  width:100%; min-width:320px; border-collapse:collapse; font-size:.82rem;
  border:1.5px solid var(--border); border-radius:10px; overflow:hidden;
}
.rich-table th{
  background:#2e7a52; color:#fff; padding:8px 10px;
  text-align:left; font-weight:700; font-size:.78rem;
}
.rich-table td{
  padding:8px 10px; border-bottom:1px solid var(--border);
  vertical-align:top; line-height:1.5; word-break:break-word;
}
.rich-table tbody tr:last-child td{ border-bottom:none; }
.rich-table tbody tr:hover{ background:var(--gp); }

/* ── 卡片 ───────────────────────────────── */
.kc-card{
  background:#fff; border:1.5px solid var(--border);
  border-radius:10px; padding:12px 14px; margin:8px 0 12px;
}
.kc-card-title{ font-weight:700; font-size:.85rem; margin-bottom:6px; color:#263238; }
.kc-card.kc-green{ background:var(--gp); border-color:var(--gll); }
.kc-card.kc-blue { background:#e8f2f9; border-color:#90caf9; }
.kc-card.kc-info { background:#e2f5ec; border-color:var(--gll); }
.kc-card.kc-warn { background:#fdf4e3; border-color:#d4a56a; }
.kc-card.kc-orange{ background:#fdf0e0; border-color:#ffcc80; }
.kc-ul{ margin:4px 0 0 0; padding-left:18px; font-size:.82rem; line-height:1.7; }

/* ── 對照欄 ─────────────────────────────── */
.kc-compare{
  display:grid; grid-template-columns:1fr 1fr; gap:10px; margin:10px 0 14px;
}
.kc-compare-col{
  background:#fff; border:1.5px solid var(--border); border-radius:10px; padding:12px 14px;
}
.kc-compare-head{
  font-weight:700; font-size:.82rem; padding:5px 10px; border-radius:7px;
  margin-bottom:8px; text-align:center;
}
.kc-compare-head.ok   { background:var(--gp);  color:var(--green); }
.kc-compare-head.info { background:#e8f2f9; color:#89b4d4; }
.kc-compare-head.warn { background:#fdf0e0; color:#c87848; }

/* ── 多卡片橫排 ─────────────────────────── */
.kc-3cards, .kc-4cards{
  display:grid; gap:10px; margin:10px 0 14px;
}
.kc-3cards{ grid-template-columns:repeat(3,1fr); }
.kc-4cards{ grid-template-columns:repeat(4,1fr); }
.kc-blue.kc-card{ background:#e8f2f9; border-color:#90caf9; }

/* ── 網格 ───────────────────────────────── */
.kc-3col, .kc-4grid, .kc-5grid, .kc-6grid{
  display:grid; gap:8px; margin:8px 0; text-align:center;
  font-size:.78rem; font-weight:600;
}
.kc-3col{ grid-template-columns:repeat(3,1fr); }
.kc-4grid{ grid-template-columns:repeat(4,1fr); }
.kc-5grid{ grid-template-columns:repeat(5,1fr); }
.kc-6grid{ grid-template-columns:repeat(6,1fr); }
.kc-6grid > div, .kc-5grid > div, .kc-4grid > div, .kc-3col > div{
  background:var(--gp); border-radius:8px; padding:8px 6px;
  color:var(--green); border:1.5px solid var(--gll);
  font-size:.74rem; line-height:1.4;
}
.kc-grid-item{
  background:var(--gp); border-radius:8px; padding:10px 8px;
  color:var(--green); border:1.5px solid var(--gll);
  font-weight:600; font-size:.8rem;
}
.kc-row-2{ display:grid; grid-template-columns:1fr 1fr; gap:10px; margin:10px 0 14px; }

/* ── 水平時間軸 ─────────────────────────── */
.h-timeline{
  display:flex; flex-wrap:wrap; gap:0;
  margin:12px 0; position:relative;
}
.h-timeline::before{
  content:''; position:absolute; top:18px; left:0; right:0;
  height:2px; background:var(--gll); z-index:0;
}
.ht-item{
  flex:1; min-width:100px; position:relative; z-index:1;
  padding:0 4px 10px; text-align:center;
}
.ht-year{
  background:var(--green); color:#fff; font-size:.68rem; font-weight:700;
  padding:3px 8px; border-radius:10px; display:inline-block; margin-bottom:8px;
  position:relative; z-index:2;
}
.ht-body{
  font-size:.74rem; line-height:1.5; color:#37474f;
  background:#fff; border:1px solid var(--border);
  border-radius:8px; padding:6px 8px; text-align:left;
}

/* ── 巢狀圖（永續金融範疇）───────────────── */
.kc-nest-chart{ margin:10px 0 14px; overflow-x:auto; }
.kc-nest{
  border-radius:10px; padding:10px 12px; margin:0;
  display:flex; flex-direction:column; align-items:flex-start;
  overflow:hidden;
}
.kc-nest > span{
  font-size:.8rem; font-weight:700; margin-bottom:8px; padding:3px 10px;
  border-radius:20px;
}
.kc-nest.n4{ background:#e2f5ec; border:2px solid #b8e4d0; }
.kc-nest.n4 > span{ background:#2e7a52; color:#fff; }
.kc-nest.n3{ background:#f1f8e9; border:2px solid #b8e4d0; margin-top:0; }
.kc-nest.n3 > span{ background:#2e7a52; color:#fff; }
.kc-nest.n2{ background:#f9fbe7; border:2px solid #dcedc8; }
.kc-nest.n2 > span{ background:#558b2f; color:#fff; }
.kc-nest.n1{ background:#fff; border:2px solid #e2f5ec; }
.kc-nest.n1 > span{ background:#8bc34a; color:#fff; }

/* ── Chart 容器 ─────────────────────────── */
.timeline-chart{ margin:12px 0; background:#fff; border-radius:10px; padding:14px; border:1.5px solid var(--border); }

/* ── RWD ── 三種裝置適配 ────────────────── */

/* 桌機：reader-body 寬約 500-600px，TOC 在左側 */
/* 平板(641-1024)：TOC 收合，reader-body 全寬 - padding */
/* 手機(≤640)：TOC 抽屜，reader-body 全寬 */

/* ── reader-body padding 手機縮減 ── */
@media(max-width:768px){
  .reader-body{ padding:16px 14px; margin-left:0; }
}

/* ── 平板(641-1024)：3欄→2欄，避免太擠 ── */
@media(max-width:1024px) and (min-width:641px){
  .kc-3cards{ grid-template-columns:repeat(2,1fr); }
  .kc-4cards{ grid-template-columns:repeat(2,1fr); }
  .kc-6grid{ grid-template-columns:repeat(3,1fr); }
  .kc-5grid{ grid-template-columns:repeat(3,1fr); }
  .rich-table{ font-size:.79rem; }
  .rich-table th{ font-size:.74rem; padding:7px 8px; }
  .rich-table td{ padding:7px 8px; }
  .ht-item{ min-width:80px; }
}

/* ── 手機(≤640)：全部單欄，字體調整 ── */
@media(max-width:640px){
  .kc-compare{ grid-template-columns:1fr; }
  .kc-3cards{ grid-template-columns:repeat(2,1fr); }
  .kc-4cards{ grid-template-columns:repeat(2,1fr); }
  .kc-6grid{ grid-template-columns:repeat(2,1fr); }
  .kc-5grid{ grid-template-columns:repeat(2,1fr); }
  .kc-4grid{ grid-template-columns:repeat(2,1fr); }
  .kc-row-2{ grid-template-columns:1fr; }
  .h-timeline{ flex-direction:column; gap:6px; }
  .h-timeline::before{ display:none; }
  .ht-item{ min-width:unset; padding:0 0 6px; }
  .ht-year{ font-size:.7rem; }
  .ht-body{ font-size:.76rem; }
  .rich-table{ font-size:.76rem; }
  .rich-table th{ font-size:.72rem; padding:6px 8px; }
  .rich-table td{ padding:6px 8px; }
  .kc-card{ padding:10px 12px; }
  .kc-card-title{ font-size:.82rem; }
  .kc-ul{ font-size:.79rem; }
  .tag{ font-size:.68rem; padding:2px 6px; }
  .kc-num{ font-size:1em; }
  /* 巢狀圖手機縮排 */
  .kc-nest{ padding:8px 10px; }
  .kc-nest > span{ font-size:.74rem; }
}

/* ── 超窄手機(≤380px) ── */
@media(max-width:380px){
  .kc-4cards{ grid-template-columns:1fr; }
  .kc-6grid{ grid-template-columns:repeat(2,1fr); }
  .rich-table{ font-size:.72rem; }
  .rich-table th, .rich-table td{ padding:5px 6px; }
}

@media(max-width:900px){
  /* 平板：4欄→2欄，避免太擠 */
  .kc-4cards{ grid-template-columns:repeat(2,1fr); }
}
@media(max-width:768px){
  /* 窄平板：比較欄維持2欄但縮小字體 */
  .kc-compare-col{ padding:10px 12px; }
  .kc-compare-head{ font-size:.78rem; }
  /* 時間軸：節點縮小 */
  .ht-item{ min-width:80px; }
  .ht-year{ font-size:.66rem; padding:2px 6px; }
  .ht-body{ font-size:.72rem; padding:5px 6px; }
  /* 巢狀圖縮排 */
  .kc-nest > span{ font-size:.76rem; }
  /* 表格 */
  .rich-table{ font-size:.78rem; }
  .rich-table th{ font-size:.72rem; padding:6px 8px; }
  .rich-table td{ padding:6px 8px; }
}
@media(max-width:480px){
  .kc-4cards{ grid-template-columns:1fr; }
  /* 超小手機：3cards也改1欄 */
  .kc-3cards{ grid-template-columns:1fr; }
  /* 時間軸在超小手機完全縱向 */
  .ht-item{ padding:0 0 8px; }
}

/* ── 原始課文分隔線 ─────────────────────── */
.original-content-divider{
  display:flex; align-items:center; gap:10px;
  margin:20px 0 14px; color:var(--gray);
}
.original-content-divider::before,
.original-content-divider::after{
  content:''; flex:1; height:1px; background:var(--border);
}
.original-content-divider span{
  font-size:.75rem; font-weight:600; white-space:nowrap;
  background:var(--lgray); padding:3px 10px; border-radius:10px;
}

/* ═══════════════════════════════════════════
   精華筆記 — 視覺化元件 CSS
═══════════════════════════════════════════ */

/* ── 定義卡片 (key-term 升級) ──────────── */
.def-card{
  display:flex; align-items:baseline; gap:10px; flex-wrap:wrap;
  background:var(--gp); border-left:3px solid var(--green);
  border-radius:0 8px 8px 0; padding:8px 12px;
  margin:6px 0;
}
.def-term{
  font-weight:800; color:var(--green); font-size:.85rem;
  white-space:nowrap; flex-shrink:0;
}
.def-term::after{ content:''; }
.def-desc{
  font-size:.83rem; color:#37474f; line-height:1.6; flex:1;
}

/* ── 條列式清單 (note-list 升級) ─────── */
.s-list{
  margin:8px 0 12px 0; padding-left:0; list-style:none;
}
.s-list > li{
  position:relative; padding:6px 10px 6px 26px;
  margin-bottom:4px; font-size:.83rem; line-height:1.65;
  color:#37474f; border-radius:6px;
  transition:background .15s;
}
.s-list > li::before{
  content:counter(li);
  counter-increment:li;
  position:absolute; left:4px; top:7px;
  width:18px; height:18px; border-radius:50%;
  background:var(--green); color:#fff;
  font-size:.65rem; font-weight:800;
  display:flex; align-items:center; justify-content:center;
  line-height:1;
}
.s-list{ counter-reset:li; }
.s-list > li:hover{ background:var(--gp); }

/* ul 版本用圓點 */
ul.s-list > li::before{
  content:''; width:7px; height:7px;
  background:var(--green); border-radius:50%;
  top:10px; left:8px;
}

/* ── 段落 ───────────────────────────────── */
.n-p{
  font-size:.83rem; line-height:1.75; color:#37474f;
  margin:6px 0 10px;
}

/* ── 升級表格（沿用 rich-table）────────── */
/* rich-table CSS 已在上方定義，此處補充 */
.rich-table-wrap + .rich-table-wrap{ margin-top:-6px; }

/* ── topic-head 升級 ────────────────────── */
.topic-head{
  font-size:.92rem !important; font-weight:800 !important;
  color:#fff !important; background:var(--green) !important;
  padding:5px 12px !important; border-radius:6px !important;
  margin:18px 0 10px !important; display:inline-block !important;
}

/* ── reader-body 內間距調整 ─────────────── */
.reader-body .topic-head:first-child{ margin-top:0 !important; }


/* ════════════════════════════════════════
   折疊式永續課文（每主題各自折疊）
════════════════════════════════════════ */
.full-text-toggle{
  display:flex; align-items:center; gap:8px;
  width:100%; margin:10px 0 0; padding:8px 14px;
  border-radius:8px; background:var(--lgray);
  border:1.5px solid var(--border);
  cursor:pointer; font-size:.8rem; font-weight:600;
  color:var(--gray); transition:all .2s; text-align:left;
}
.full-text-toggle:hover,
.full-text-toggle.open{
  background:var(--gp); border-color:var(--gll); color:var(--green);
}
.full-text-toggle .ftt-icon{ font-size:.9rem; flex-shrink:0; }
.full-text-toggle .ftt-label{ flex:1; }
.full-text-toggle.open .ftt-label::after{ content:' ▴'; }
.full-text-toggle:not(.open) .ftt-label::after{ content:' ▾'; }

.full-text-body{
  display:none; padding:14px 16px 4px;
  border:1.5px solid var(--gll); border-top:none;
  border-radius:0 0 8px 8px; background:#fafff8;
  margin-bottom:14px;
  /* 滑順動畫：max-height 過渡 */
  overflow:hidden;
}
.full-text-body.open{ display:block; }

/* ── 答錯後「回到課文」按鈕 ──────────────── */
.related-course-btn{
  display:inline-flex; align-items:center; gap:6px;
  margin-top:10px; padding:7px 14px;
  background:var(--gp); border:1.5px solid var(--gll);
  border-radius:8px; font-size:.8rem; font-weight:600;
  color:var(--green); cursor:pointer;
  transition:all .2s;
}
.related-course-btn:hover{
  background:var(--gll); color:#fff;
}

/* ── 暫選答案 + 確認按鈕 ────────────────── */
.opt.pending{
  border-color: var(--green) !important;
  background: var(--gp) !important;
  color: var(--green) !important;
}
.tb-opt.pending{
  border-color: var(--green) !important;
  background: var(--gp) !important;
  color: var(--green) !important;
}
.confirm-row{
  display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap;
}
.btn-confirm-ans{
  flex: 1; min-width: 120px; padding: 10px 16px;
  background: var(--green); color: #fff;
  border: none; border-radius: 10px;
  font-size: .88rem; font-weight: 700;
  cursor: pointer; transition: opacity .15s;
}
.btn-confirm-ans:hover{ opacity: .88; }
.btn-change-ans{
  flex: 1; min-width: 100px; padding: 10px 16px;
  background: var(--lgray); color: var(--gray);
  border: 1.5px solid var(--border); border-radius: 10px;
  font-size: .88rem; font-weight: 600;
  cursor: pointer; transition: background .15s;
}
.btn-change-ans:hover{ background: var(--border); }

/* ── 圖表頁面 ───────────────────────── */
.charts-page-wrap{padding:20px;max-width:1100px;margin:0 auto;}
.charts-header{margin-bottom:20px;}
.charts-header h2{font-size:1.3rem;color:var(--green);margin-bottom:6px;}
.charts-header p{font-size:.85rem;color:var(--gray);margin-bottom:12px;}
.chart-filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:4px;}
.cf-btn{padding:5px 12px;border-radius:20px;border:1.5px solid var(--border);background:#fff;font-size:.8rem;font-weight:600;color:var(--gray);cursor:pointer;transition:all .2s;}
.cf-btn.active{background:var(--green);color:#fff;border-color:var(--green);}
.charts-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;}
.chart-card{background:#fff;border-radius:14px;border:1.5px solid var(--border);padding:16px;box-shadow:0 2px 8px rgba(0,0,0,.06);display:flex;flex-direction:column;gap:10px;}
.chart-card.hidden{display:none;}
.chart-card-wide{grid-column:span 2;}
.chart-card-header{display:flex;align-items:center;gap:10px;}
.chart-card-header h3{font-size:.9rem;font-weight:700;color:#1a2e1a;margin:0;}
.chart-tag{padding:3px 8px;border-radius:10px;font-size:.7rem;font-weight:700;white-space:nowrap;}
.ch1-tag{background:#e2f5ec;color:#2e7a52;}
.ch2-tag{background:#e8f2f9;color:#89b4d4;}
.ch3-tag{background:#fdf0e0;color:#c87848;}
.ch4-tag{background:#ede8f7;color:#8872b8;}
.chart-body{flex:1;}
.chart-note{font-size:.75rem;color:var(--gray);background:var(--lgray);padding:7px 10px;border-radius:8px;line-height:1.5;}
/* 巢狀圓 */
.nested-scope{display:flex;justify-content:center;padding:8px 0;}
.ns-ring{border-radius:10px;padding:10px;display:flex;flex-direction:column;align-items:center;}
.ns4{background:#e2f5ec;border:2px solid #b8e4d0;width:100%;}
.ns3{background:#b8e4d0;border:2px solid #72c49a;width:90%;margin-top:4px;}
.ns2{background:#b8e4d0;border:2px solid #3fa068;width:85%;margin-top:4px;}
.ns1{background:#3fa068;border:2px solid #2e7a52;width:80%;margin-top:4px;}
.ns-label{font-size:.72rem;font-weight:700;text-align:center;color:#1b5c42;padding:2px 0;}
.ns1 .ns-label{color:#fff;}
/* 橫條 */
.compare-bars{display:flex;flex-direction:column;gap:8px;}
.cb-axis{font-size:.7rem;color:var(--gray);}
.cb-row{display:flex;align-items:center;gap:8px;}
.cb-name{width:90px;font-size:.75rem;font-weight:600;flex-shrink:0;}
.cb-bar-wrap{flex:1;background:#f5f5f5;border-radius:20px;height:18px;overflow:hidden;}
.cb-bar{height:100%;border-radius:20px;}
.cb-end{font-size:.7rem;font-weight:700;width:28px;flex-shrink:0;}
/* SDGs */
.sdg-grid{display:grid;grid-template-columns:repeat(9,1fr);gap:3px;}
.sdg-item{border-radius:6px;padding:5px 2px;display:flex;flex-direction:column;align-items:center;color:#fff;font-size:.85rem;font-weight:800;cursor:default;}
.sdg-item small{font-size:.52rem;font-weight:600;text-align:center;line-height:1.2;margin-top:1px;}
.sdg-star{box-shadow:0 0 0 2px gold;}
/* 里程碑 */
.milestones{display:flex;overflow-x:auto;padding-bottom:6px;position:relative;}
.milestones::before{content:'';position:absolute;top:16px;left:0;right:0;height:2px;background:#b8e4d0;}
.ms-item{flex:1;min-width:80px;display:flex;flex-direction:column;align-items:center;position:relative;padding:0 2px;}
.ms-year{background:var(--green);color:#fff;font-size:.65rem;font-weight:700;padding:2px 5px;border-radius:8px;margin-bottom:6px;z-index:1;}
.ms-dot{width:9px;height:9px;border-radius:50%;background:#fff;border:2px solid var(--green);margin-bottom:6px;z-index:1;}
.ms-dot-hl{background:var(--green);}
.ms-body{font-size:.68rem;text-align:center;line-height:1.4;}
.ms-highlight .ms-year{background:#c87848;}
/* 甘特 */
.gantt-wrap{overflow-x:auto;}
.gantt-head{display:flex;align-items:center;margin-bottom:3px;}
.gantt-label-h{width:160px;font-size:.7rem;font-weight:700;flex-shrink:0;}
.gantt-years-h{flex:1;display:flex;justify-content:space-between;font-size:.7rem;color:var(--gray);}
.gantt-section-title{font-size:.72rem;font-weight:700;color:var(--green);margin:4px 0 3px;}
.gantt-row{display:flex;align-items:center;margin-bottom:3px;}
.gantt-bars{flex:1;position:relative;height:16px;background:#f5f5f5;border-radius:3px;overflow:hidden;}
.gantt-bar{position:absolute;height:100%;border-radius:3px;}
.gb-scan{background:#3fa068;}
.gb-conf{background:#89b4d4;}
.gantt-legend{display:flex;gap:10px;margin-top:6px;font-size:.7rem;}
.gl-scan{color:#3fa068;font-weight:700;}
.gl-conf{color:#89b4d4;font-weight:700;}
/* 框架比較 */
.fw-compare{display:flex;gap:6px;}
.fw-col{flex:1;display:flex;flex-direction:column;border-radius:8px;overflow:hidden;border:1px solid var(--border);}
.fw-head{color:#fff;padding:6px;text-align:center;font-weight:700;font-size:.8rem;}
.fw-row{padding:5px 7px;font-size:.72rem;border-bottom:1px solid #f0f0f0;display:flex;flex-direction:column;gap:1px;}
.fw-k{font-weight:700;color:var(--gray);font-size:.66rem;}
.fw-v{color:#37474f;}
.fw-badge-sm{margin:3px 7px 7px;padding:3px 7px;border-radius:20px;font-size:.66rem;font-weight:700;text-align:center;}
/* 範疇盒子 */
.scope-boxes{display:flex;align-items:stretch;gap:5px;}
.scope-box{flex:1;border-radius:8px;padding:8px;display:flex;flex-direction:column;align-items:center;text-align:center;gap:3px;}
.sb1{background:#ffebee;border:2px solid #ef9a9a;}
.sb2{background:#e8f2f9;border:2px solid #90caf9;}
.sb3{background:#e2f5ec;border:2px solid #b8e4d0;}
.sb-num{font-weight:800;font-size:.78rem;}
.sb1 .sb-num{color:#c62828;}.sb2 .sb-num{color:#89b4d4;}.sb3 .sb-num{color:#2e7a52;}
.sb-name{font-weight:700;font-size:.75rem;}
.sb-emoji{font-size:1.3rem;}
.sb-items{font-size:.68rem;color:#546e7a;line-height:1.4;}
.sb-tag{font-size:.65rem;font-weight:700;padding:2px 6px;border-radius:8px;background:rgba(0,0,0,.06);}
.scope-arrow{display:flex;align-items:center;font-size:1rem;color:var(--gray);}
/* 風險分類 */
.risk-split{display:flex;gap:8px;}
.rs-half{flex:1;border-radius:8px;padding:10px;}
.rs-transition{background:#fdf0e0;border:1.5px solid #ffcc80;}
.rs-physical{background:#fce4ec;border:1.5px solid #f48fb1;}
.rs-title{font-weight:700;font-size:.82rem;margin-bottom:8px;}
.rs-item{display:flex;gap:6px;margin-bottom:6px;align-items:flex-start;font-size:.74rem;}
.rs-icon{font-size:.9rem;flex-shrink:0;}
/* 債券表格 */
.bond-table{width:100%;font-size:.74rem;}
.bt-head,.bt-row{display:flex;}
.bt-c{flex:1;padding:5px 6px;border:1px solid var(--border);text-align:center;}
.bt-head .bt-c{background:#37474f;color:#fff;font-weight:700;}
.bt-key{background:#f5f5f5;font-weight:700;text-align:left;}
.bt-slb{background:#fdf0e0;}
/* 赤道原則 */
.eq-levels{display:flex;flex-direction:column;gap:6px;}
.eq-lv{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;}
.eq-a{background:#ffebee;border-left:4px solid #d04555;}
.eq-b{background:#fdf0e0;border-left:4px solid #c88a50;}
.eq-c{background:#e2f5ec;border-left:4px solid #3fa068;}
.eq-g{font-weight:900;font-size:1.2rem;width:24px;flex-shrink:0;}
.eq-a .eq-g{color:#d04555;}.eq-b .eq-g{color:#c88a50;}.eq-c .eq-g{color:#3fa068;}
.eq-info{font-size:.74rem;line-height:1.5;}
.eq-req{font-size:.66rem;color:var(--gray);}
/* 倡議原則 */
.im-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;}
.im-item{border-radius:8px;padding:10px;display:flex;flex-direction:column;align-items:center;text-align:center;gap:3px;}
.im-pri{background:#e2f5ec;border:1.5px solid #b8e4d0;}
.im-prb{background:#e8f2f9;border:1.5px solid #90caf9;}
.im-psi{background:#fdf0e0;border:1.5px solid #ffcc80;}
.im-ep{background:#ede8f7;border:1.5px solid #ce93d8;}
.im-ico{font-size:1.3rem;}.im-n{font-weight:800;font-size:.95rem;}
.im-f{font-weight:700;font-size:.75rem;}
.im-t{font-size:.7rem;background:rgba(0,0,0,.08);padding:2px 7px;border-radius:8px;font-weight:700;}
.im-d{font-size:.7rem;color:#546e7a;line-height:1.4;}
/* 投資策略 */
.strategy-list{display:flex;flex-direction:column;gap:5px;}
.sl-item{display:flex;align-items:center;gap:8px;padding:7px;border-radius:7px;background:#fafafa;border:1px solid var(--border);}
.sl-n{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:.78rem;flex-shrink:0;}
.sl-name{font-weight:700;font-size:.8rem;}
.sl-desc{font-size:.72rem;color:var(--gray);}
/* SFDR */
.sfdr-list{display:flex;flex-direction:column;gap:7px;}
.sfdr-item{border-radius:8px;padding:9px 11px;}
.sfdr-6{background:#f5f5f5;border-left:4px solid #bdbdbd;}
.sfdr-8{background:#e2f5ec;border-left:4px solid #72c49a;}
.sfdr-9{background:#b8e4d0;border-left:4px solid #2e7a52;}
.sfdr-art{font-weight:800;font-size:.82rem;color:#37474f;}
.sfdr-name{font-weight:700;font-size:.8rem;}
.sfdr-desc{font-size:.72rem;color:#546e7a;line-height:1.4;}
.sfdr-meter{display:flex;align-items:center;gap:7px;margin-top:5px;}
.sfdr-fill{height:7px;border-radius:20px;flex:0 0 auto;}
.sfdr-meter>span{font-size:.68rem;color:var(--gray);}
@media(max-width:768px){
  .charts-grid{grid-template-columns:1fr;}
  .chart-card-wide{grid-column:span 1;}
  .fw-compare{flex-direction:column;}
  .risk-split{flex-direction:column;}
  .scope-boxes{flex-direction:column;}
  .sdg-grid{grid-template-columns:repeat(6,1fr);}
  .milestones{flex-direction:column;}
  .milestones::before{display:none;}
}

/* ── 手機版 mobile-toc-panel 內部樣式 ── */
#mobile-toc-panel .toc-ch{
  font-size:.72rem;font-weight:800;color:var(--gray);letter-spacing:.06em;
  text-transform:uppercase;padding:10px 16px 4px;background:var(--lgray);
}
#mobile-toc-panel .toc-sec{
  padding:12px 20px;font-size:.88rem;border-bottom:1px solid var(--border);
  cursor:pointer;color:var(--text-body);touch-action:manipulation;
}
#mobile-toc-panel .toc-sec:active,
#mobile-toc-panel .toc-sec.active{
  background:var(--ch1-light,#e2f5ec);color:var(--green);font-weight:700;
}
/* ── reader-sec-nav small ── */
.reader-sec-nav-title small{
  display:block;font-size:.72rem;font-weight:400;opacity:.8;margin-top:2px;
}
/* ── 平板版 reader-toc 也要隱藏（用 mobile-toc-btn 取代）── */
@media(max-width:768px){
  .reader-toc{display:none!important;}
}
/* ── 桌面版隱藏 mobile-toc-btn ── */
@media(min-width:769px){
  #mobile-toc-btn{display:none!important;}
  #mobile-toc-panel{display:none!important;}
  .reader-sec-nav{display:none!important;}
  .reader-toc{display:block!important;}
}


/* ── 課文內嵌圖表 CSS（從 tx-body 移出） ── */
.fin-stack{display:flex;flex-direction:column;gap:3px;}
.fin-tier{border-radius:8px;padding:9px 14px;display:flex;align-items:center;justify-content:space-between;}
.fin-tier-name{font-weight:800;font-size:.88rem;}
.fin-tier-desc{font-size:.72rem;text-align:right;}
.ft1{background:#e2f5ec;border:2px solid #b8e4d0;}
.ft1 .fin-tier-name{color:#2e7a52;}
.ft1 .fin-tier-desc{color:#33691e;}
.ft2{background:#b8e4d0;border:2px solid #72c49a;}
.ft2 .fin-tier-name{color:#1b5c42;}
.ft2 .fin-tier-desc{color:#2e7a52;}
.ft3{background:#2e7a52;border:2px solid #2e7a52;}
.ft3 .fin-tier-name{color:#fff;}
.ft3 .fin-tier-desc{color:#b8e4d0;}
.ft4{background:#2e7a52;border:2px solid #1b5c42;}
.ft4 .fin-tier-name{color:#fff;}
.ft4 .fin-tier-desc{color:#b8e4d0;}
.fin-arrows{display:flex;flex-direction:column;align-items:center;gap:0;margin:1px 0;}
.fin-arrows span{font-size:.65rem;color:#aaa;line-height:1;}
.fin-unep{margin-top:10px;background:#fdf0e0;border-left:3px solid #c87848;border-radius:0 8px 8px 0;padding:7px 10px;font-size:.75rem;color:#5d4037;}
.nz-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.nz-box{border-radius:12px;overflow:hidden;}
.nz-head{padding:9px 14px;font-weight:800;font-size:.84rem;color:#fff;text-align:center;}
.nz-body{padding:12px 14px;display:flex;flex-direction:column;gap:6px;}
.nz-row{display:flex;gap:8px;align-items:flex-start;font-size:.76rem;line-height:1.5;}
.nz-icon{font-size:.9rem;flex-shrink:0;}
.nz-trap{font-size:.7rem;color:#b71c1c;background:#ffebee;border-radius:5px;padding:2px 7px;display:inline-block;margin-top:6px;}
.nz-zero .nz-head{background:#1b5c42;}
.nz-zero .nz-body{background:#e2f5ec;}
.nz-neutral .nz-head{background:#89b4d4;}
.nz-neutral .nz-body{background:#e8f2f9;}
.sdg-table{width:100%;border-collapse:collapse;font-size:.76rem;}
.sdg-table th{padding:6px 8px;text-align:left;font-size:.72rem;color:#fff;}
.sdg-table td{padding:6px 8px;border-bottom:1px solid #f0f0f0;vertical-align:top;line-height:1.5;}
.sdg-table tr:last-child td{border-bottom:none;}
.sdg-table tr:nth-child(even) td{background:#fafafa;}
.sdg-num{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;color:#fff;font-weight:800;font-size:.72rem;flex-shrink:0;}
.sdg-tip{color:#b71c1c;font-size:.7rem;}
.sdg-star-row td{background:#fdf4e3 !important;border-left:3px solid #a21942;}
.tl-wrap{position:relative;width:100%;overflow-x:auto;}
.tl-svg{display:block;width:100%;min-width:520px;}
.kp-tbl{width:100%;border-collapse:collapse;font-size:.75rem;}
.kp-tbl th{padding:7px 10px;color:#fff;font-weight:700;font-size:.73rem;}
.kp-tbl td{padding:7px 10px;border-bottom:1px solid #f0f0f0;vertical-align:top;line-height:1.6;}
.kp-tbl tr:last-child td{border-bottom:none;}
.kp-tbl .kp-label{font-weight:700;color:#546e7a;font-size:.72rem;width:90px;}
.kp-trap{font-size:.7rem;color:#b71c1c;background:#ffebee;border-radius:4px;padding:1px 6px;}
.sfdr-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.sfdr-col{border-radius:10px;overflow:hidden;border:2px solid transparent;display:flex;flex-direction:column;}
.sfdr-col-6{border-color:#90a4ae;}
.sfdr-col-8{border-color:#72c49a;}
.sfdr-col-9{border-color:#2e7a52;}
.sfdr-col-head{padding:10px 12px 8px;text-align:center;}
.sfdr-col-6 .sfdr-col-head{background:#eceff1;}
.sfdr-col-8 .sfdr-col-head{background:#b8e4d0;}
.sfdr-col-9 .sfdr-col-head{background:#2e7a52;}
.sfdr-article-num{font-size:1rem;font-weight:900;letter-spacing:.5px;}
.sfdr-col-6 .sfdr-article-num{color:#546e7a;}
.sfdr-col-8 .sfdr-article-num{color:#1b5c42;}
.sfdr-col-9 .sfdr-article-num{color:#fff;}
.sfdr-badge{display:inline-block;margin-top:4px;padding:2px 10px;border-radius:20px;font-size:.72rem;font-weight:700;}
.sfdr-col-6 .sfdr-badge{background:#cfd8dc;color:#37474f;}
.sfdr-col-8 .sfdr-badge{background:#b8e4d0;color:#1b5c42;}
.sfdr-col-9 .sfdr-badge{background:rgba(255,255,255,.25);color:#fff;}
.sfdr-col-body{padding:10px 12px;flex:1;display:flex;flex-direction:column;gap:6px;}
.sfdr-col-6 .sfdr-col-body{background:#fafafa;}
.sfdr-col-8 .sfdr-col-body{background:#f1f8e9;}
.sfdr-col-9 .sfdr-col-body{background:#e2f5ec;}
.sfdr-col-row{font-size:.76rem;line-height:1.5;color:#37474f;}
.sfdr-col-row b{color:#263238;}
.sfdr-esg-bar{height:8px;border-radius:4px;margin-top:8px;}
.sfdr-col-6 .sfdr-esg-bar{background:linear-gradient(to right,#bdbdbd 20%,#e0e0e0 20%);}
.sfdr-col-8 .sfdr-esg-bar{background:linear-gradient(to right,#72c49a 60%,#e0e0e0 60%);}
.sfdr-col-9 .sfdr-esg-bar{background:#2e7a52;}
.sfdr-esg-label{font-size:.68rem;color:var(--gray);margin-top:3px;text-align:right;}
.sfdr-arrow{display:flex;align-items:center;justify-content:center;gap:4px;margin:8px 0 2px;font-size:.7rem;color:var(--gray);}
.sfdr-must{background:#fff9c4;border:1.5px solid #d4a56a;border-radius:8px;padding:7px 10px;font-size:.76rem;color:#5d4037;text-align:center;margin-top:2px;}
@media(max-width:600px){.sfdr-grid{grid-template-columns:1fr;}}
.fw-table{width:100%;border-collapse:collapse;font-size:.76rem;table-layout:auto;}
.fw-table th{padding:8px 10px;text-align:center;color:#fff;font-weight:800;font-size:.78rem;}
.fw-table td{padding:7px 10px;border:1px solid #e0e0e0;vertical-align:top;line-height:1.5;word-break:break-word;}
.fw-table .fw-row-label{background:#eceff1;font-weight:700;color:#37474f;font-size:.73rem;text-align:center;}
.fw-table tr:hover td{background:#fafafa;}
.fw-must{margin-top:10px;background:#fff9c4;border:1.5px solid #d4a56a;border-radius:8px;padding:7px 10px;font-size:.75rem;color:#5d4037;}

/* ══ 回到題目浮動按鈕 ══ */
#return-to-q-btn {
  position: fixed;
  bottom: 80px;
  right: 16px;
  z-index: 9999;
  display: none;
  align-items: center;
  gap: 8px;
  padding: 11px 18px;
  background: linear-gradient(135deg, #1b5c42, #2e7a52);
  color: #fff;
  border: none;
  border-radius: 50px;
  font-size: .88rem;
  font-weight: 800;
  cursor: pointer;
  box-shadow: 0 4px 16px rgba(27,94,32,.45);
  transition: transform .15s, box-shadow .15s;
  white-space: nowrap;
  letter-spacing: .02em;
}
@media(max-width:640px){
  #return-to-q-btn {
    bottom: 72px;
    right: 12px;
    padding: 9px 14px;
    font-size: .82rem;
  }
}
#return-to-q-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(27,94,32,.55);
}
#return-to-q-btn .rq-icon { font-size: 1.1rem; }
#return-to-q-btn .rq-label { font-size: .82rem; opacity: .85; font-weight: 500; }

/* ══ 手機版：inline grid 自動折行 ══ */
@media(max-width:599px){
  /* 視覺化元素內的 grid 強制單欄 */
  [style*="grid-template-columns:1fr 1fr"],
  [style*="grid-template-columns: 1fr 1fr"]{
    grid-template-columns: 1fr !important;
  }
  [style*="grid-template-columns:repeat(3"],
  [style*="grid-template-columns: repeat(3"]{
    grid-template-columns: 1fr 1fr !important;
  }
  [style*="grid-template-columns:repeat(4"],
  [style*="grid-template-columns: repeat(4"]{
    grid-template-columns: 1fr 1fr !important;
  }
  /* 視覺化元素字體在手機稍微放大 */
  .tx-fig-chart-body [style*="font-size:.7"],
  .tx-fig-chart-body [style*="font-size: .7"]{
    font-size: .78rem !important;
  }
  /* 表格在手機縮小字體 */
  .tx-fig-chart-body table td,
  .tx-fig-chart-body table th {
    font-size: .72rem !important;
    padding: 5px 7px !important;
  }
  /* 官方圖表在手機縮小 */
  .tx-fig-wrap { margin: 10px 0 14px !important; }
  .tx-fig-label { font-size: .78rem !important; }
}

/* ══ 手機版題庫UI優化 ══ */
@media(max-width:599px){
  /* 篩選列 */
  .quiz-controls {
    padding: 12px 14px !important;
    gap: 7px !important;
  }
  .quiz-controls label { font-size: .8rem !important; }
  .quiz-controls select { font-size: .82rem !important; padding: 5px 8px !important; }

  /* 題目卡片 */
  .q-card { padding: 16px 14px !important; }
  .q-stem { font-size: .9rem !important; line-height: 1.6 !important; }
  .opt { padding: 11px 12px !important; font-size: .86rem !important; }

  /* 解析區 */
  .exp-box { font-size: .83rem !important; }

  /* 課文連結按鈕 */
  .related-course-btn {
    font-size: .78rem !important;
    padding: 7px 11px !important;
    margin-top: 5px !important;
  }

  /* 導覽按鈕 */
  .btn-prev, .btn-next, .btn-submit {
    padding: 9px 14px !important;
    font-size: .84rem !important;
  }

  /* 進度條區 */
  .q-meta { flex-wrap: wrap !important; gap: 4px !important; }
  .q-tag { font-size: .72rem !important; padding: 2px 7px !important; }

  /* 確認按鈕 */
  .btn-confirm-ans, .btn-change-ans {
    padding: 9px 14px !important;
    font-size: .84rem !important;
  }
}

/* ══ 手機版精華筆記優化 ══ */
@media(max-width:599px){
  /* 卡片 */
  .kc-card { padding: 10px 12px !important; }
  .topic-head { font-size: .85rem !important; }

  /* 永續課文 */
  .tx-p { font-size: .87rem !important; line-height: 1.75 !important; }
  .tx-h2 { font-size: 1rem !important; }
  .tx-h3 { font-size: .92rem !important; }

  /* 官方圖表 */
  .tx-fig-chart-body { padding: 8px !important; }

  /* reader layout 在手機隱藏 TOC */
  .reader-toc { display: none !important; }
  .reader-content { padding: 0 !important; }

  /* 隨堂練習 tb-opt */
  .tb-opt {
    font-size: .84rem !important;
    padding: 10px 12px !important;
  }
}

/* ══ 手機版模擬考試優化 ══ */
@media(max-width:599px){
  /* 計時器和進度 */
  #exam-timer { font-size: 1.3rem !important; }
  #exam-prog-txt { font-size: .78rem !important; }

  /* 考試結果 */
  .result-panel { padding: 20px 14px !important; }
  .rs-box { padding: 12px 10px !important; }
  .rs-num { font-size: 1.6rem !important; }

  /* 交卷後解析每題 */
  #exam-result [style*="border:1px solid"] {
    padding: 10px 12px !important;
    font-size: .82rem !important;
  }
}

/* ── 導覽分類標籤 ── */
.nav-section-label {
  font-size: .68rem;
  font-weight: 700;
  color: #b8afa4;
  text-transform: uppercase;
  letter-spacing: .08em;
  padding: 4px 16px 2px;
  opacity: .7;
}


@media(max-width:599px){
  .tx-progress-bar{ margin:0 -14px 14px; padding:5px 14px 6px; }
  .tx-prog-label{ font-size:.68rem; }
}


/* ── 手機版：tx-toc-back 隱藏 ── */
@media(max-width:599px){
  .tx-toc-back{display:none;}
}

/* ── 桌機版：mobile-toc-btn / panel 隱藏 ── */
@media(min-width:821px){
  #mobile-toc-btn{display:none!important;}
  #mobile-toc-panel{display:none!important;}
  .reader-sec-nav{display:none!important;}
  .reader-toc{display:block!important;}
}


/* ── SVG 圖標通用樣式 ── */
.pod-icon{
  display:inline-flex; align-items:center; justify-content:center;
  width:20px; height:20px; flex-shrink:0;
}
.pod-icon svg{ width:100%; height:100%; display:block; }
.pod-icon-sm{ width:16px; height:16px; }
.pod-icon-lg{ width:28px; height:28px; }

/* 控制按鈕的 skip 標籤 */
.pod-btn-label{
  font-size:.62rem; font-weight:700; color:currentColor;
  line-height:1; opacity:.8;
}
.pod-ctrl-btn{ display:flex; align-items:center; gap:3px; }

/* 封面圖 svg 填滿容器 */
.pod-cover-art svg,
.pod-ep-thumb svg{ width:100%; height:100%; display:block; }

/* 音量圖標 */
.pod-vol-icon{ display:inline-flex; align-items:center; justify-content:center; width:18px; height:18px; }
.pod-vol-icon svg{ width:100%; height:100%; }

/* 播放模式圖標 */
#pod-mode-icon{ display:inline-flex; align-items:center; width:15px; height:15px; }
#pod-mode-icon svg{ width:100%; height:100%; }

/* ══════════════════════════════════════════
   PODCAST 頁面（全新設計）
══════════════════════════════════════════ */

/* ── 頁面佈局 ── */
#page-podcast.active{
  display:flex !important; flex-direction:column;
  overflow:hidden; max-width:unset;
  height:calc(100vh - var(--header-h));
  background:var(--bg);
}
@media(max-width:1299px){
  #page-podcast.active{
    height:calc(100vh - var(--header-h) - var(--bottom-nav-h));
  }
}

/* ── 頂部播放器區（固定顯示）── */
#pod-top{
  flex-shrink:0;
  background:linear-gradient(160deg, #1b4d20 0%, #2e7a52 60%, #2e7a52 100%);
  color:#fff;
  padding:18px 20px 14px;
  position:relative; overflow:hidden;
}
#pod-top::before{
  content:'';
  position:absolute; top:-60px; right:-60px;
  width:200px; height:200px;
  background:rgba(255,255,255,.05); border-radius:50%;
  pointer-events:none;
}
#pod-top::after{
  content:'';
  position:absolute; bottom:-40px; left:30%;
  width:120px; height:120px;
  background:rgba(255,255,255,.04); border-radius:50%;
  pointer-events:none;
}

/* 頂部：封面 + 資訊 + 控制 一列 */
.pod-top-main{
  display:flex; align-items:center; gap:16px;
  position:relative; z-index:1;
}
.pod-cover-art{
  width:56px; height:56px; border-radius:12px;
  display:flex; align-items:center; justify-content:center;
  font-size:1.8rem; flex-shrink:0;
  background:rgba(255,255,255,.15);
  backdrop-filter:blur(4px);
  box-shadow:0 4px 16px rgba(0,0,0,.25);
  transition:transform .2s;
}
#pod-top.has-ep .pod-cover-art{ cursor:pointer; }
#pod-top.has-ep .pod-cover-art:active{ transform:scale(.95); }

.pod-top-info{ flex:1; min-width:0; }
.pod-top-label{
  font-size:.68rem; font-weight:700; letter-spacing:.08em;
  color:rgba(255,255,255,.65); margin-bottom:3px;
  text-transform:uppercase;
}
.pod-top-title{
  font-size:.96rem; font-weight:700; color:#fff;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
  line-height:1.35;
}
.pod-top-sub{
  font-size:.72rem; color:rgba(255,255,255,.6); margin-top:2px;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}

/* 播放控制鈕（右側） */
.pod-top-ctrl{ display:flex; align-items:center; gap:8px; flex-shrink:0; }
.pod-ctrl-btn{
  width:36px; height:36px; border-radius:50%;
  border:none; cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  font-size:.9rem; transition:all .15s;
  background:rgba(255,255,255,.12); color:#fff;
}
.pod-ctrl-btn:hover{ background:rgba(255,255,255,.22); transform:scale(1.05); }
.pod-ctrl-btn.pod-play-main{
  width:44px; height:44px; font-size:1rem;
  background:#fff; color:var(--green);
  box-shadow:0 3px 12px rgba(0,0,0,.25);
}
.pod-ctrl-btn.pod-play-main:hover{ background:#f0faf0; transform:scale(1.08); }
.pod-ctrl-btn.active-mode{ background:rgba(255,255,255,.28); }

/* 進度列 */
.pod-progress-wrap{
  margin-top:12px; position:relative; z-index:1;
}
.pod-prog-bar{
  width:100%; height:4px; background:rgba(255,255,255,.2);
  border-radius:99px; cursor:pointer; position:relative; overflow:hidden;
  transition:height .15s;
}
.pod-prog-bar:hover{ height:7px; }
.pod-prog-fill{
  height:100%;
  background:rgba(255,255,255,.9);
  border-radius:99px; width:0%;
  transition:width .1s linear;
  pointer-events:none;
}
.pod-prog-times{
  display:flex; justify-content:space-between;
  font-size:.65rem; color:rgba(255,255,255,.55);
  margin-top:4px;
}

/* 底部工具列：播放模式 + 倍速 + 音量 */
.pod-top-tools{
  display:flex; align-items:center; gap:8px;
  margin-top:10px; position:relative; z-index:1;
}
.pod-mode-btn{
  background:rgba(255,255,255,.12); color:rgba(255,255,255,.75);
  border:none; border-radius:20px; padding:4px 12px;
  font-size:.72rem; font-weight:700; cursor:pointer;
  transition:all .15s; white-space:nowrap;
  display:flex; align-items:center; gap:4px;
}
.pod-mode-btn:hover{ background:rgba(255,255,255,.2); color:#fff; }
.pod-mode-btn.on{ background:rgba(255,255,255,.28); color:#fff; }

/* 背景播放 toggle */
.pod-bg-wrap{
  margin-left:auto; display:flex; align-items:center; gap:6px;
}
.pod-bg-label{ font-size:.7rem; color:rgba(255,255,255,.65); white-space:nowrap; }
.pod-toggle{
  width:36px; height:20px; border-radius:99px;
  background:rgba(255,255,255,.2); cursor:pointer;
  position:relative; transition:background .2s; border:none;
  flex-shrink:0;
}
.pod-toggle::after{
  content:''; position:absolute; top:3px; left:3px;
  width:14px; height:14px; border-radius:50%;
  background:#fff; transition:transform .2s;
}
.pod-toggle.on{ background:rgba(255,255,255,.5); }
.pod-toggle.on::after{ transform:translateX(16px); }

/* 倍速 */
.pod-speed-wrap-top{ position:relative; }
.pod-speed-btn-top{
  background:rgba(255,255,255,.12); color:rgba(255,255,255,.9);
  border:none; border-radius:20px; padding:4px 12px;
  font-size:.72rem; font-weight:700; cursor:pointer;
  transition:all .15s; min-width:44px; text-align:center;
}
.pod-speed-btn-top:hover{ background:rgba(255,255,255,.22); }
.pod-speed-menu-top{
  position:absolute; bottom:calc(100% + 8px); left:50%;
  transform:translateX(-50%);
  background:#fff; border:1px solid var(--border);
  border-radius:12px; box-shadow:0 4px 20px rgba(0,0,0,.15);
  padding:6px; display:none; flex-direction:column; gap:2px;
  min-width:90px; z-index:300;
}
.pod-speed-menu-top.open{ display:flex; }
.pod-speed-opt{
  padding:7px 14px; border-radius:8px; cursor:pointer;
  font-size:.82rem; font-weight:600; text-align:center;
  transition:background .1s; color:var(--neutral-text);
}
.pod-speed-opt:hover{ background:var(--gp); }
.pod-speed-opt.cur{ color:var(--green); background:var(--gp); }

/* 音量（桌機顯示） */
.pod-vol-wrap{ display:flex; align-items:center; gap:6px; }
.pod-vol-icon{ font-size:.8rem; color:rgba(255,255,255,.65); cursor:pointer; }
.pod-vol-slider{
  width:70px; accent-color:rgba(255,255,255,.8); cursor:pointer;
}
@media(max-width:640px){ .pod-vol-wrap{ display:none; } }

/* ── 集數列表 ── */
.pod-list{ flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; }

.pod-list-header{
  padding:14px 20px 8px;
  display:flex; align-items:center; justify-content:space-between;
}
.pod-list-title{
  font-size:.78rem; font-weight:700; color:var(--gray);
  letter-spacing:.05em; text-transform:uppercase;
}
.pod-list-count{
  font-size:.74rem; color:var(--gray);
  background:var(--lgray); border-radius:20px;
  padding:2px 10px; font-weight:600;
}

.pod-ep{
  display:flex; align-items:center; gap:12px;
  padding:10px 20px;
  cursor:pointer; transition:background .12s;
  position:relative; user-select:none;
}
.pod-ep:not(:last-child){ border-bottom:1px solid var(--border); }
.pod-ep:hover{ background:var(--gp); }
.pod-ep.active{ background:var(--gp); }

/* 序號 / 播放中指示 */
.pod-ep-idx{
  width:28px; text-align:center; flex-shrink:0;
  font-size:.8rem; color:var(--gray); font-weight:500;
  transition:all .15s;
}
.pod-ep.active .pod-ep-idx{ color:var(--green); }

/* 封面圖 */
.pod-ep-thumb{
  width:44px; height:44px; border-radius:8px;
  display:flex; align-items:center; justify-content:center;
  font-size:1.2rem; flex-shrink:0;
  position:relative; overflow:hidden;
  transition:transform .15s;
}
.pod-ep:hover .pod-ep-thumb{ transform:scale(1.04); }
.pod-ep[data-ch="1"] .pod-ep-thumb{ background:linear-gradient(135deg,#b8e4d0,#72c49a); }
.pod-ep[data-ch="2"] .pod-ep-thumb{ background:linear-gradient(135deg,#bbdefb,#89b4d4); }
.pod-ep[data-ch="3"] .pod-ep-thumb{ background:linear-gradient(135deg,#ffe0b2,#ffb74d); }
.pod-ep[data-ch="4"] .pod-ep-thumb{ background:linear-gradient(135deg,#e1bee7,#ba68c8); }
.pod-ep[data-ch="5"] .pod-ep-thumb{ background:linear-gradient(135deg,#cfd8dc,#90a4ae); }

/* 播放中波形動畫 */
.pod-wave{
  display:none; align-items:flex-end; gap:2px;
  position:absolute; inset:0;
  justify-content:center; align-items:center;
  background:rgba(0,0,0,.22); border-radius:8px;
}
.pod-ep.active.playing .pod-wave{ display:flex; }
.pod-wave span{
  width:3px; border-radius:2px; background:#fff;
  animation:pod-wave .9s ease-in-out infinite;
}
.pod-wave span:nth-child(1){ height:10px; animation-delay:0s; }
.pod-wave span:nth-child(2){ height:16px; animation-delay:.15s; }
.pod-wave span:nth-child(3){ height:10px; animation-delay:.3s; }
@keyframes pod-wave{
  0%,100%{ transform:scaleY(1); opacity:.9; }
  50%{ transform:scaleY(.35); opacity:.6; }
}

/* 集數資訊 */
.pod-ep-body{ flex:1; min-width:0; }
.pod-ep-ch{
  font-size:.65rem; font-weight:700; letter-spacing:.06em;
  margin-bottom:2px; opacity:.75;
}
.pod-ep[data-ch="1"] .pod-ep-ch{ color:var(--green-d); }
.pod-ep[data-ch="2"] .pod-ep-ch{ color:var(--blue); }
.pod-ep[data-ch="3"] .pod-ep-ch{ color:var(--orange); }
.pod-ep[data-ch="4"] .pod-ep-ch{ color:var(--purple); }
.pod-ep[data-ch="5"] .pod-ep-ch{ color:var(--neutral-dark); }

.pod-ep-title{
  font-size:.86rem; font-weight:600; color:var(--neutral-text);
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}
.pod-ep.active .pod-ep-title{ color:var(--green); font-weight:700; }
.pod-ep-desc{
  font-size:.72rem; color:var(--gray); margin-top:2px;
  white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}

.pod-empty{
  text-align:center; padding:60px 20px;
  color:var(--gray); font-size:.85rem; line-height:2.2;
}
.pod-empty-icon{ font-size:2.5rem; margin-bottom:8px; }

/* ── 手機版 ── */
@media(max-width:640px){
  #pod-top{ padding:14px 16px 12px; }
  .pod-cover-art{ width:46px; height:46px; font-size:1.4rem; }
  .pod-top-title{ font-size:.88rem; }
  .pod-ep{ padding:10px 16px; gap:10px; }
  .pod-ep-thumb{ width:38px; height:38px; font-size:1rem; }
  .pod-top-tools{ gap:6px; }
}


/* ── UI SVG 圖標通用樣式 ── */
.icon, .b-icon, .nav-icon, .q-icon {
  display:inline-flex; align-items:center; justify-content:center;
  flex-shrink:0;
}
.icon svg, .b-icon svg, .nav-icon svg { display:block; }
.icon{ width:18px; height:18px; }
.icon svg{ width:18px; height:18px; }
.nav-icon{ width:18px; height:18px; }
.nav-icon svg{ width:18px; height:18px; }
.b-icon{ width:22px; height:22px; }
.b-icon svg{ width:22px; height:22px; }
.q-icon{ display:flex; align-items:center; justify-content:center;
  width:44px; height:44px; border-radius:12px; }
.q-icon svg{ width:26px; height:26px; }
/* menu-btn */
#menu-btn{ background:none; border:none; cursor:pointer;
  width:36px; height:36px; padding:6px;
  display:flex; align-items:center; justify-content:center;
  border-radius:8px; color:var(--neutral-text); transition:background .15s; }
#menu-btn:hover{ background:var(--lgray); }
#menu-btn svg{ width:22px; height:22px; }
/* mobile-toc-btn */
#mobile-toc-btn{ color:var(--green); }
#mobile-toc-btn svg{ width:22px; height:22px; }
/* reader-tab icon */
.reader-tab-icon{ display:inline-flex; align-items:center; justify-content:center;
  width:16px; height:16px; margin-right:4px; }
.reader-tab-icon svg{ width:16px; height:16px; }
/* btn icons */
.btn-icon{ display:inline-flex; align-items:center; gap:5px; }
.btn-icon svg{ width:15px; height:15px; flex-shrink:0; }
/* topbar title icon */
#page-title{ display:flex; align-items:center; gap:8px; }
#page-title svg{ width:20px; height:20px; flex-shrink:0; }
/* progress card icons */
.prog-card h3{ display:flex; align-items:center; gap:6px; }
.prog-card h3 svg{ width:18px; height:18px; }
/* return btn icon */
.rq-icon{ display:inline-flex; align-items:center; }
.rq-icon svg{ width:18px; height:18px; }
/* cloud sync icon */
.cloud-icon svg{ width:14px; height:14px; }

/* ══ 漂綠案例折疊卡 ══ */
.tx-acc-wrap{display:flex;flex-direction:column;gap:8px;margin:14px 0}
.tx-acc-item{border:.5px solid #e0e0e0;border-radius:10px;overflow:hidden}
.tx-acc-header{display:flex;align-items:center;gap:10px;padding:11px 14px;cursor:pointer;background:#fff;user-select:none;-webkit-user-select:none}
.tx-acc-header:hover{background:#f7f7f7}
.tx-acc-co{font-size:12px;font-weight:600;padding:2px 9px;border-radius:5px;background:#f0f0f0;color:#555;flex-shrink:0;white-space:nowrap}
.tx-acc-tag{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:2px 9px;border-radius:5px;flex-shrink:0;white-space:nowrap}
.tx-acc-tag svg{flex-shrink:0}
.tx-acc-tag.t-false {background:#FAECE7;color:#712B13}
.tx-acc-tag.t-mismatch{background:#EEEDFE;color:#3C3489}
.tx-acc-tag.t-exag  {background:#FAEEDA;color:#633806}
.tx-acc-tag.t-img   {background:#E6F1FB;color:#0C447C}
.tx-acc-tag.t-hide  {background:#FAECE7;color:#712B13}
.tx-acc-tag.t-opaq  {background:#EAF3DE;color:#27500A}
.tx-acc-tag.t-cmp   {background:#FAEEDA;color:#633806}
.tx-acc-tag.t-cond  {background:#EEEDFE;color:#3C3489}
.tx-acc-tag.t-scope {background:#E1F5EE;color:#085041}
.tx-acc-sum{font-size:12.5px;color:#666;line-height:1.45;flex:1;min-width:0}
.tx-acc-chev{flex-shrink:0;margin-left:4px;display:flex;align-items:center;color:#bbb;transition:transform .22s ease}
.tx-acc-item.open .tx-acc-chev{transform:rotate(180deg)}
.tx-acc-body{max-height:0;overflow:hidden;transition:max-height .28s ease}
.tx-acc-item.open .tx-acc-body{max-height:400px}
.tx-acc-inner{padding:0 14px 13px;display:flex;flex-direction:column;gap:8px;border-top:.5px solid #eee}
.tx-acc-rlabel{font-size:10.5px;font-weight:600;color:#aaa;letter-spacing:.04em;text-transform:uppercase;margin-bottom:3px;display:flex;align-items:center;gap:4px;padding-top:10px}
.tx-acc-claim{font-size:13px;color:#555;line-height:1.65}
.tx-acc-prob{font-size:13px;color:#993C1D;line-height:1.65;padding:8px 11px;background:#FAECE7;border-radius:7px;display:flex;gap:8px;align-items:flex-start}
.tx-acc-prob svg{flex-shrink:0;margin-top:2px}

/* ══ 折疊卡補充 tag 色彩 ══ */
.tx-acc-tag.t-research{background:#EEEDFE;color:#3C3489}
.tx-acc-tag.t-scenario{background:#FAEEDA;color:#633806}
.tx-acc-tag.t-taiwan  {background:#E1F5EE;color:#085041}
.tx-acc-tag.t-energy  {background:#EAF3DE;color:#27500A}
.tx-acc-tag.t-coast   {background:#E6F1FB;color:#0C447C}
.tx-acc-tag.t-nature  {background:#EAF3DE;color:#27500A}
.tx-acc-tag.t-infra   {background:#F1EFE8;color:#444441}
.tx-acc-tag.t-insure  {background:#E1F5EE;color:#085041}
.tx-acc-tag.t-health  {background:#FAECE7;color:#993C1D}
.tx-acc-tag.t-farm    {background:#EAF3DE;color:#27500A}
.tx-acc-tag.t-water   {background:#E6F1FB;color:#0C447C}
.tx-acc-tag.t-mobile  {background:#EEEDFE;color:#3C3489}
.tx-acc-tag.t-twcase  {background:#E1F5EE;color:#085041}
.tx-acc-tag.t-bond    {background:#EEEDFE;color:#3C3489}
.tx-acc-tag.t-card    {background:#E6F1FB;color:#0C447C}
.tx-acc-tag.t-risk    {background:#FAEEDA;color:#633806}
.tx-acc-tag.t-eco     {background:#EAF3DE;color:#27500A}
.tx-acc-detail{font-size:13px;color:#444;line-height:1.75;padding:10px 0 2px}/* ── SunDown Studio footer ── */

#sidebar{padding-bottom:calc(var(--bottom-nav-h) + env(safe-area-inset-bottom,0px));}}

/* ── Topbar auth ── */
#topbar-auth{display:flex;align-items:center;gap:8px;flex-shrink:0;}
#tb-login-btn{display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:8px;border:1.5px solid var(--border);background:#fff;cursor:pointer;font-size:.78rem;font-weight:600;color:#444;font-family:var(--font);transition:background .15s,border-color .15s;}
#tb-login-btn:hover{background:var(--lgray);border-color:#c5bfb5;}
#tb-user-wrap{position:relative;display:none;}
#tb-user{display:flex;align-items:center;gap:7px;cursor:pointer;padding:4px 8px;border-radius:8px;transition:background .15s;user-select:none;}
#tb-user:hover{background:var(--lgray);}
#tb-avatar{width:26px;height:26px;border-radius:50%;object-fit:cover;border:1.5px solid var(--border);background:var(--gp);}
#tb-avatar-fallback{width:26px;height:26px;border-radius:50%;background:var(--green);display:flex;align-items:center;justify-content:center;font-size:.7rem;font-weight:700;color:#fff;flex-shrink:0;}
#tb-name{font-size:.78rem;font-weight:600;color:#2a221a;max-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
#tb-chevron{font-size:.6rem;color:var(--gray);transition:transform .15s;flex-shrink:0;}
#tb-user-wrap.open #tb-chevron{transform:rotate(180deg);}
/* Dropdown 選單 */
#tb-dropdown{
  display:none;position:absolute;top:calc(100% + 8px);right:0;
  background:#fff;border:1px solid var(--border);border-radius:12px;
  box-shadow:0 4px 20px rgba(0,0,0,.12);min-width:200px;z-index:500;
  overflow:hidden;animation:dropFadeIn .15s ease;
}
@keyframes dropFadeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
#tb-user-wrap.open #tb-dropdown{display:block;}
.tb-drop-info{padding:14px 16px;border-bottom:1px solid var(--border);}
.tb-drop-name{font-size:.85rem;font-weight:700;color:#1a2e1a;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tb-drop-email{font-size:.72rem;color:var(--gray);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tb-drop-btn{display:flex;align-items:center;gap:8px;width:100%;padding:11px 16px;border:none;background:none;font-family:var(--font);font-size:.82rem;cursor:pointer;color:#263238;transition:background .12s;text-align:left;}
.tb-drop-btn:hover{background:var(--lgray);}
.tb-drop-btn.danger{color:var(--red);}
.tb-drop-btn.danger:hover{background:var(--rp);}
@media(max-width:640px){#tb-name,#tb-chevron{display:none;}#tb-login-btn span.tb-login-text{display:none;}#tb-dropdown{right:-8px;}}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js">

</script>

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-4CTZGQMDVW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-4CTZGQMDVW');
    window._ga4 = function(eventName, params) {
      if(typeof gtag === 'function') gtag('event', eventName, params || {});
    };
  </script>

  <!-- Firebase SDK -->
  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
    import { getAuth, GoogleAuthProvider, signInWithPopup, signOut, onAuthStateChanged }
      from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
    import { getDatabase, ref, set, get, push, onValue }
      from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

    const firebaseConfig = {
      apiKey: "AIzaSyAzY_dPwuap8_SCDhAvEJ2d_H_pETKp_M8",
      authDomain: "esg-learning-and-practice.firebaseapp.com",
      databaseURL: "https://esg-learning-and-practice-default-rtdb.asia-southeast1.firebasedatabase.app",
      projectId: "esg-learning-and-practice",
      storageBucket: "esg-learning-and-practice.firebasestorage.app",
      messagingSenderId: "640671358038",
      appId: "1:640671358038:web:d71c2ec7f4c28b02396ff7"
    };

    const app      = initializeApp(firebaseConfig);
    const auth     = getAuth(app);
    const db       = getDatabase(app);
    const provider = new GoogleAuthProvider();

    window._fbUser = null;

    // ── 匿名訪客 ID（localStorage 持久化，跨頁面追蹤）──
    if (!localStorage.getItem('_anon_id')) {
      localStorage.setItem('_anon_id', crypto.randomUUID());
    }
    window._anonId = localStorage.getItem('_anon_id');

    // ── Analytics 埋點核心函數 ──────────────────────────
    window._logEvent = function(eventName, params) {
      try {
        const uid = window._fbUser ? window._fbUser.uid : ('anon_' + window._anonId);
        const payload = {
          event: eventName,
          uid:   uid,
          ts:    Date.now(),
          date:  new Date().toLocaleString('zh-TW', {timeZone:'Asia/Taipei'}),
          ...(params || {})
        };
        push(ref(db, 'analytics/events'), payload).catch(()=>{});
        window._ga4 && window._ga4(eventName, { uid, ...(params || {}) });
      } catch(e) {}
    };

    window.fbSignIn = async function() {
      try {
        await signInWithPopup(auth, provider);
      } catch(e) {
        console.error('登入失敗', e);
        showToast('登入失敗，請再試一次');
      }
    };

    window.fbSignOut = async function() {
      window._logEvent('logout', { email: window._fbUser?.email || '' });
      await signOut(auth);
      showToast('已登出');
    };

    onAuthStateChanged(auth, async user => {
      window._fbUser = user;
      _updateAuthUI(user);
      if(user) {
        window._logEvent('login', { email: user.email || '', displayName: user.displayName || '' });
        // 寫入 profile（供管理後台顯示）
        set(ref(db, 'users/' + user.uid + '/profile'), {
          email:       user.email       || '',
          displayName: user.displayName || ''
        }).catch(()=>{});
        await _syncFromFirebase(user.uid);
        if(typeof renderProgress === 'function' && document.getElementById('page-progress')?.classList.contains('active')) {
          renderProgress();
        }
        if(typeof renderHome === 'function') renderHome();
      }
    });

    window._syncFromFirebase = async function(uid) {
      try {
        const snap = await get(ref(db, 'users/' + uid + '/progress'));
        if(snap.exists()) {
          const data = snap.val();
          localStorage.setItem(STORE_KEY, typeof data === 'string' ? data : JSON.stringify(data));
        }
      } catch(e) { console.warn('Firebase 讀取失敗，使用本地資料', e); }
    };

    window._saveToFirebase = async function(data) {
      if(!window._fbUser) return;
      try {
        await set(ref(db, 'users/' + window._fbUser.uid + '/progress'), JSON.stringify(data));
      } catch(e) { console.warn('Firebase 寫入失敗', e); }
    };
  </script>

