  { ch:'3', icon:`<svg viewBox="0 0 44 44" fill="none"><defs><linearGradient id="pod-g3" x1="0" y1="0" x2="44" y2="44"><stop stop-color="#ffb74d"/><stop offset="1" stop-color="#c87848"/></linearGradient></defs><rect width="44" height="44" rx="10" fill="url(#pod-g3)"/><path d="M22 11 L25.5 18 L33.5 19 L28 24.5 L29.5 33 L22 29 L14.5 33 L16 24.5 L10.5 19 L18.5 18 Z" fill="white" opacity=".85"/></svg>`, cover:`<svg viewBox="0 0 60 60" fill="none"><defs><linearGradient id="pod-c3" x1="0" y1="0" x2="60" y2="60"><stop stop-color="#ffb74d"/><stop offset="1" stop-color="#c87848"/></linearGradient></defs><rect width="60" height="60" rx="14" fill="url(#pod-c3)"/><path d="M30 14 L34.5 23.5 L45 25 L37.5 32 L39.5 44 L30 39 L20.5 44 L22.5 32 L15 25 L25.5 23.5 Z" fill="white" opacity=".85"/></svg>`, label:'第三章 · 永續風險與治理' },
  { ch:'4', icon:`<svg viewBox="0 0 44 44" fill="none"><defs><linearGradient id="pod-g4" x1="0" y1="0" x2="44" y2="44"><stop stop-color="#ce93d8"/><stop offset="1" stop-color="#8872b8"/></linearGradient></defs><rect width="44" height="44" rx="10" fill="url(#pod-g4)"/><circle cx="22" cy="22" r="11" stroke="white" stroke-width="2" fill="none" opacity=".6"/><line x1="22" y1="12" x2="22" y2="14" stroke="white" stroke-width="2.5" stroke-linecap="round"/><line x1="22" y1="30" x2="22" y2="32" stroke="white" stroke-width="2.5" stroke-linecap="round"/><text x="22" y="27" text-anchor="middle" font-size="14" font-weight="800" fill="white" font-family="sans-serif">$</text></svg>`, cover:`<svg viewBox="0 0 60 60" fill="none"><defs><linearGradient id="pod-c4" x1="0" y1="0" x2="60" y2="60"><stop stop-color="#ce93d8"/><stop offset="1" stop-color="#8872b8"/></linearGradient></defs><rect width="60" height="60" rx="14" fill="url(#pod-c4)"/><circle cx="30" cy="30" r="16" stroke="white" stroke-width="2.5" fill="none" opacity=".6"/><line x1="30" y1="15" x2="30" y2="18" stroke="white" stroke-width="3" stroke-linecap="round"/><line x1="30" y1="42" x2="30" y2="45" stroke="white" stroke-width="3" stroke-linecap="round"/><text x="30" y="37" text-anchor="middle" font-size="18" font-weight="800" fill="white" font-family="sans-serif">$</text></svg>`, label:'第四章 · 永續金融' },
  { ch:'5', icon:`<svg viewBox="0 0 44 44" fill="none"><defs><linearGradient id="pod-g5" x1="0" y1="0" x2="44" y2="44"><stop stop-color="#90a4ae"/><stop offset="1" stop-color="#37474f"/></linearGradient></defs><rect width="44" height="44" rx="10" fill="url(#pod-g5)"/><circle cx="22" cy="19" r="8" stroke="white" stroke-width="2" fill="none" opacity=".75"/><path d="M16 29 L22 35 L28 29" stroke="white" stroke-width="2" stroke-linecap="round" fill="none" opacity=".8"/><line x1="22" y1="27" x2="22" y2="35" stroke="white" stroke-width="2" stroke-linecap="round" opacity=".6"/><circle cx="22" cy="19" r="3.5" fill="white" opacity=".5"/></svg>`, cover:`<svg viewBox="0 0 60 60" fill="none"><defs><linearGradient id="pod-c5" x1="0" y1="0" x2="60" y2="60"><stop stop-color="#90a4ae"/><stop offset="1" stop-color="#37474f"/></linearGradient></defs><rect width="60" height="60" rx="14" fill="url(#pod-c5)"/><circle cx="30" cy="26" r="11" stroke="white" stroke-width="2.5" fill="none" opacity=".75"/><path d="M22 40 L30 48 L38 40" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none" opacity=".8"/><line x1="30" y1="37" x2="30" y2="48" stroke="white" stroke-width="2.5" stroke-linecap="round" opacity=".6"/><circle cx="30" cy="26" r="5" fill="white" opacity=".5"/></svg>`, label:'精華總複習' },
];

// 播放模式：sequence=接續, single=單曲, shuffle=隨機, loop=循環
const POD_MODES = [
  { id:'sequence', icon:`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="5 12 19 12"/><polyline points="15 8 20 12 15 16"/></svg>`,    label:'接續' },
  { id:'single',   icon:`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 01-4 4H3"/><circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/></svg>`, label:'單曲' },
  { id:'shuffle',  icon:`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>`,label:'隨機' },
  { id:'loop',     icon:`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>`,   label:'循環' },
];

const POD_KEY   = 'susdev_pod_v2';
let _podAudio   = null;
let _podCurIdx  = -1;
let _podPlaying = false;
let _podModeI   = 0;        // 播放模式 index
let _podBg      = true;     // 背景播放（切頁繼續播）
let _podInited  = false;
let _podMuted   = false;
let _podVolume  = 1;
let _podShuffleOrder = [];   // 隨機順序緩存

function _podNormalizeUrl(url){
  if(!url) return url;
  const gd = url.match(/drive\.google\.com\/file\/d\/([^\/]+)/);
  if(gd) return 'https://drive.google.com/uc?export=download&id='+gd[1];
  if(url.includes('dropbox.com')) return url.replace('dl=0','dl=1');
  return url;
}
function _podLoadState(){
  try{ return JSON.parse(localStorage.getItem(POD_KEY)||'{}'); }catch(e){ return {}; }
}
function _podSaveState(p){
  try{
    const s=_podLoadState(); Object.assign(s,p);
    localStorage.setItem(POD_KEY,JSON.stringify(s));
  }catch(e){}
}

function initPodcast(){
  renderPodList();
  if(_podInited) return;
  _podInited = true;
  _podAudio = document.getElementById('pod-audio');
  if(!_podAudio) return;
  _podAudio.addEventListener('timeupdate', _podOnTime);
  _podAudio.addEventListener('loadedmetadata', _podOnMeta);
  _podAudio.addEventListener('ended', _podOnEnd);
  _podAudio.addEventListener('play',  ()=>_podSyncUI(true));
  _podAudio.addEventListener('pause', ()=>_podSyncUI(false));
  // 恢復設定
  const st = _podLoadState();
  if(typeof st.mode === 'number') _podModeI = st.mode;
  if(typeof st.bg   === 'boolean') _podBg   = st.bg;
  if(typeof st.vol  === 'number') _podVolume = st.vol;
  _podApplyMode();
  _podApplyBg();
  if(_podVolume !== 1){ _podAudio.volume=_podVolume; const el=document.getElementById('pod-vol'); if(el) el.value=_podVolume; }
  // 恢復上次集數
  if(st.idx >= 0 && st.idx < PODCAST_DATA.length){
    _podLoadEp(st.idx, false);
    if(st.time > 0) _podAudio.currentTime = st.time;
  }
}

function renderPodList(){
  const ep_list = document.getElementById('pod-ep-list');
  if(!ep_list) return;
  const count = document.getElementById('pod-count');
  if(count) count.textContent = PODCAST_DATA.length + ' 集';
  if(!PODCAST_DATA.length){
    ep_list.innerHTML = '<div class="pod-empty"><div class="pod-empty-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#8872b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>尚未加入集數<br><small>請在 PODCAST_DATA 中加入集數</small></div>';
    return;
  }
  ep_list.innerHTML = PODCAST_DATA.map((ep,i)=>{
    const info = POD_CH_MAP[i] || { ch:String(i+1), icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>', label:'EP'+(i+1) };
    const isActive = i === _podCurIdx;
    return `<div class="pod-ep${isActive?' active':''}" data-ch="${info.ch}" onclick="podEpClick(${i})">
      <div class="pod-ep-idx">${i+1}</div>
      <div class="pod-ep-thumb">
        ${info.icon}
        <div class="pod-wave"><span></span><span></span><span></span></div>
      </div>
      <div class="pod-ep-body">
        <div class="pod-ep-ch">${info.label}</div>
        <div class="pod-ep-title">${ep.title}</div>
        <div class="pod-ep-desc">${ep.desc||''}</div>
      </div>
    </div>`;
  }).join('');
}

function podEpClick(idx){
  if(idx===_podCurIdx && _podAudio){ podToggle(); return; }
  _podLoadEp(idx, true);
}

function _podLoadEp(idx, autoplay){
  const ep = PODCAST_DATA[idx];
  if(!ep) return;
  if(!_podAudio) _podAudio = document.getElementById('pod-audio');
  if(!_podAudio) return;
  _podCurIdx = idx;
  _podAudio.src = _podNormalizeUrl(ep.url);
  _podAudio.load();
  _podAudio.volume = _podVolume;
  _podAudio.muted  = _podMuted;
  // 更新頂部資訊
  const info = POD_CH_MAP[idx] || { ch:String(idx+1), icon:`<svg viewBox="0 0 60 60" fill="none"><defs><linearGradient id="pod-cd" x1="0" y1="0" x2="60" y2="60"><stop stop-color="#b8e4d0"/><stop offset="1" stop-color="#2e7a52"/></linearGradient></defs><rect width="60" height="60" rx="14" fill="url(#pod-cd)"/><path d="M22 38 L22 22 L40 30 Z" fill="white" opacity=".85"/></svg>`, cover:`<svg viewBox="0 0 60 60" fill="none"><defs><linearGradient id="pod-cd" x1="0" y1="0" x2="60" y2="60"><stop stop-color="#b8e4d0"/><stop offset="1" stop-color="#2e7a52"/></linearGradient></defs><rect width="60" height="60" rx="14" fill="url(#pod-cd)"/><path d="M22 38 L22 22 L40 30 Z" fill="white" opacity=".85"/></svg>`, label:'EP'+(idx+1) };
  // 封面用 innerHTML（SVG）
  const coverEl = document.getElementById('pod-cover');
  if(coverEl) coverEl.innerHTML = info.cover || info.icon;
  _podSetEl('pod-top-label', info.label);
  _podSetEl('pod-top-title', ep.title);
  _podSetEl('pod-top-sub',   ep.desc||'');
  document.getElementById('pod-top')?.classList.add('has-ep');
  if(autoplay) _podAudio.play().catch(()=>showToast('音訊無法播放，請確認連結有效'));
  renderPodList();
  _podSaveState({idx, time:0});
}

function _podSetEl(id, txt, asText=false){
  const el = document.getElementById(id);
  if(!el) return;
  if(asText) el.textContent = txt;
  else el.textContent = txt;
}

// ── 播放控制 ──
function podToggle(){
  if(!_podAudio||_podCurIdx<0) return;
  if(_podPlaying) _podAudio.pause();
  else _podAudio.play().catch(()=>showToast('音訊無法播放，請確認連結有效'));
}
function podSkip(sec){
  if(!_podAudio) return;
  _podAudio.currentTime = Math.max(0, Math.min(_podAudio.duration||0, _podAudio.currentTime+sec));
}
function podSeekBar(e){
  if(!_podAudio||!_podAudio.duration) return;
  const bar = document.getElementById('pod-bar');
  if(!bar) return;
  const r = bar.getBoundingClientRect();
  _podAudio.currentTime = Math.max(0,Math.min(1,(e.clientX-r.left)/r.width))*_podAudio.duration;
}

// ── 播放模式 ──
function podCycleMode(){
  _podModeI = (_podModeI+1) % POD_MODES.length;
  _podApplyMode();
  _podSaveState({mode:_podModeI});
  showToast('播放模式：' + POD_MODES[_podModeI].label);
}
function _podApplyMode(){
  const m = POD_MODES[_podModeI];
  const mi = document.getElementById('pod-mode-icon');
  if(mi) mi.innerHTML = m.icon;
  _podSetEl('pod-mode-txt', m.label);
}
function _podNextEp(){
  const mode = POD_MODES[_podModeI].id;
  const n = PODCAST_DATA.length;
  if(mode === 'single') return _podCurIdx;
  if(mode === 'loop')   return (_podCurIdx+1) % n;
  if(mode === 'shuffle'){
    // 產生不重複隨機序列
    if(!_podShuffleOrder.length || _podShuffleOrder[_podShuffleOrder.length-1]===_podCurIdx){
      _podShuffleOrder = [...Array(n).keys()].filter(i=>i!==_podCurIdx).sort(()=>Math.random()-.5);
    }
    return _podShuffleOrder.shift();
  }
  // sequence
  const next = _podCurIdx+1;
  return next < n ? next : -1;
}

// ── 倍速 ──
function podToggleSpeed(){
  document.getElementById('pod-spm')?.classList.toggle('open');
}
function podSetSpeed(speed){
  if(_podAudio) _podAudio.playbackRate = speed;
  const btn = document.getElementById('pod-spd');
  if(btn) btn.textContent = speed+'x';
  document.querySelectorAll('.pod-speed-opt').forEach(el=>{
    el.classList.toggle('cur', parseFloat(el.textContent)===speed);
  });
  document.getElementById('pod-spm')?.classList.remove('open');
}
document.addEventListener('click', e=>{
  if(!e.target.closest('#pod-sw')){
    document.getElementById('pod-spm')?.classList.remove('open');
  }
});

// ── 音量 ──
function podSetVol(v){
  _podVolume = parseFloat(v);
  if(_podAudio) _podAudio.volume = _podVolume;
  _podMuted = (_podVolume === 0);
  const icon = document.getElementById('pod-vol-icon');
  if(icon) icon.innerHTML = _podVolume===0 ? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>` : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 010 7.07"/><path d="M19.07 4.93a10 10 0 010 14.14"/></svg>`;
  _podSaveState({vol:_podVolume});
}
function podMuteToggle(){
  if(!_podAudio) return;
  _podMuted = !_podMuted;
  _podAudio.muted = _podMuted;
  const icon = document.getElementById('pod-vol-icon');
  if(icon) icon.innerHTML = _podMuted ? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>` : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 010 7.07"/><path d="M19.07 4.93a10 10 0 010 14.14"/></svg>`;
}

// ── 背景播放 ──
function podToggleBg(){
  _podBg = !_podBg;
  _podApplyBg();
  _podSaveState({bg:_podBg});
  showToast(_podBg ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> 背景播放已開啟' : '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#546e7a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg> 切換頁面時將暫停播放');
}
function _podApplyBg(){
  const btn = document.getElementById('pod-bg-btn');
  if(btn) btn.classList.toggle('on', _podBg);
}

// goPage 時依 _podBg 決定是否暫停
function _podHandlePageChange(isLeavingPodcast){
  if(!_podAudio||!_podPlaying) return;
  if(isLeavingPodcast && !_podBg) _podAudio.pause();
}

// ── UI 同步 ──
function _podSyncUI(playing){
  _podPlaying = playing;
  const btn = document.getElementById('pod-play-btn');
  if(btn) btn.innerHTML = playing
    ? `<span class="pod-icon"><svg viewBox="0 0 24 24" fill="none"><rect x="7" y="7" width="3" height="10" rx="1.5" fill="currentColor"/><rect x="14" y="7" width="3" height="10" rx="1.5" fill="currentColor"/></svg></span>`
    : `<span class="pod-icon"><svg viewBox="0 0 24 24" fill="none"><polygon points="9,7 19,12 9,17" fill="currentColor"/></svg></span>`;
  // 列表波形動畫
  document.querySelectorAll('.pod-ep').forEach((el,i)=>{
    el.classList.toggle('active', i===_podCurIdx);
    el.classList.toggle('playing', i===_podCurIdx && playing);
  });
}
function _podOnTime(){
  if(!_podAudio||!_podAudio.duration) return;
  const pct = _podAudio.currentTime/_podAudio.duration*100;
  const fill = document.getElementById('pod-fill');
  if(fill) fill.style.width = pct.toFixed(2)+'%';
  _podSetEl('pod-cur', _podFmt(_podAudio.currentTime));
  if(Math.floor(_podAudio.currentTime)%5===0)
    _podSaveState({idx:_podCurIdx, time:_podAudio.currentTime});
}
function _podOnMeta(){
  if(_podAudio) _podSetEl('pod-dur', _podFmt(_podAudio.duration));
}
function _podOnEnd(){
  const next = _podNextEp();
  if(next >= 0) _podLoadEp(next, true);
  else _podSyncUI(false);
}
function _podFmt(sec){
  if(!isFinite(sec)) return '0:00';
  const m=Math.floor(sec/60), s=Math.floor(sec%60);
  return m+':'+(s<10?'0':'')+s;
}


// ════════════════════════════════════════════════
function renderHome(){
  const p       = loadProgress();
  const total   = p.history.reduce((s, h) => s + h.total,   0);
  const correct = p.history.reduce((s, h) => s + h.correct, 0);
  const sessions = p.history.length;
  const pct = total ? Math.round(correct / total * 100) : 0;

  document.getElementById('home-stats').innerHTML = `
    <div class="stat-card"><div class="stat-num">${sessions}</div><div class="stat-label">練習次數</div></div>
    <div class="stat-card"><div class="stat-num">${total}</div><div class="stat-label">作答題數</div></div>
    <div class="stat-card"><div class="stat-num" style="color:var(--color-success)">${correct}</div><div class="stat-label">答對題數</div></div>
    <div class="stat-card"><div class="stat-num" style="color:${pct>=PASS_PCT?'var(--color-success)':'var(--color-danger)'}">${pct}%</div><div class="stat-label">整體正確率</div></div>`;

  // ── 學習建議順序（永遠顯示）──
  const PHASES = [
    {
      phase: '第一階段', sub: '建立基礎概念', color: '#89b4d4', bg: '#e8f2f9', border: '#89b4d4',
      icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
      steps: [
        { pg: PAGES.READER,   icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>', label: '精華筆記',   desc: '5章重點，快速掌握考試核心' },
        { pg: PAGES.TEXTBOOK2,'icon': '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>', label: '永續課文',   desc: '深入閱讀原文，鞏固理解' },
      ]
    },
    {
      phase: '第二階段', sub: '強化記憶', color: '#8872b8', bg: '#ede8f7', border: '#7a64a8',
      icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>',
      steps: [
        { pg: PAGES.NOTES,    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>', label: '考點筆記',   desc: '高頻考點整理，含常見錯誤' },
        { pg: PAGES.TEXTBOOK, icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>', label: '永續題庫',   desc: '課本練習題，搭配解析' },
      ]
    },
    {
      phase: '第三階段', sub: '實戰練習', color: '#1b5c42', bg: '#e2f5ec', border: '#2e7a52',
      icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>',
      steps: [
        { pg: PAGES.QUIZ,     icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>', label: '歷屆題庫',   desc: '1040題真實考古題，即時解析' },
        { pg: PAGES.EXAM,     icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>', label: '模擬考試',   desc: '90分鐘限時，80題模擬正式考試' },
      ]
    },
  ];

  const phasesHtml = PHASES.map(ph => `
    <div style="flex:1;min-width:180px;border:1.5px solid ${ph.border};border-radius:12px;overflow:hidden;">
      <div style="background:${ph.color};color:#fff;padding:8px 14px;font-weight:800;font-size:.85rem;display:flex;align-items:center;gap:6px;">
        <span>${ph.icon}</span>
        <div>
          <div>${ph.phase}</div>
          <div style="font-size:.72rem;font-weight:500;opacity:.9;">${ph.sub}</div>
        </div>
      </div>
      <div style="background:${ph.bg};padding:8px 10px;display:flex;flex-direction:column;gap:7px;">
        ${ph.steps.map((st,si) => `
          <div onclick="goPage('${st.pg}')" style="background:#fff;border-radius:8px;padding:8px 12px;
            cursor:pointer;display:flex;align-items:center;gap:10px;
            border:1px solid ${ph.border};transition:box-shadow .15s;"
            onmouseover="this.style.boxShadow='0 2px 8px rgba(0,0,0,.12)'"
            onmouseout="this.style.boxShadow='none'">
            <span style="font-size:1.3rem;flex-shrink:0;">${st.icon}</span>
            <div>
              <div style="font-weight:700;font-size:.85rem;color:${ph.color};">${st.label}</div>
              <div style="font-size:.75rem;color:#555;line-height:1.4;">${st.desc}</div>
            </div>
          </div>`).join('')}
      </div>
    </div>`).join(`
    <div style="display:flex;align-items:center;color:#aaa;font-size:1.3rem;padding:0 4px;">›</div>`);

  const lastDate  = p.history[0]?.date || '';
  const isToday   = lastDate === new Date().toLocaleDateString('zh-TW');
  const statusHtml = sessions === 0
    ? `<div style="background:#fdf4e3;border:1.5px solid #ffc107;border-radius:10px;padding:10px 16px;
        font-size:.85rem;color:#7d600a;display:flex;align-items:center;gap:8px;margin-bottom:14px;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> 歡迎！按照以下順序學習，效果最好。</div>`
    : isToday
      ? `<div style="background:#e2f5ec;border:1.5px solid #3fa068;border-radius:10px;padding:10px 16px;
          font-size:.85rem;color:#1b5c42;display:flex;align-items:center;gap:8px;margin-bottom:14px;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> 今天已練習過，繼續保持！整體正確率 <strong>${pct}%</strong></div>`
      : `<div style="background:#e8f2f9;border:1.5px solid #2196f3;border-radius:10px;padding:10px 16px;
          font-size:.85rem;color:#5a8ab8;display:flex;align-items:center;gap:8px;margin-bottom:14px;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> 上次練習：${_safeText(lastDate)}，今天繼續加油！</div>`;

  const guideEl = document.getElementById('home-guide');
  if(guideEl) guideEl.innerHTML = `
    <div style="background:var(--card);border-radius:var(--radius);box-shadow:var(--shadow);
      padding:18px 20px;margin-bottom:16px;">
      <div style="font-weight:800;font-size:.95rem;color:var(--green);margin-bottom:12px;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#4a9480" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>️ 建議學習順序
      </div>
      ${statusHtml}
      <div style="display:flex;gap:10px;align-items:stretch;flex-wrap:wrap;">
        ${phasesHtml}
      </div>
    </div>`;
}

// ════════════════════════════════════════════════
//  READER
// ════════════════════════════════════════════════
let _readerInit = false;

function initReader(){
  if(_readerInit) return;
  _readerInit = true;
  const tocHtml = CHAPTERS.flatMap((ch, ci) => [
    `<div class="toc-ch">${_safeText(ch.title)}</div>`,
    ...ch.sections.map((sec, si) =>
      `<div class="toc-sec" data-ci="${ci}" data-si="${si}" onclick="showSection(${ci},${si})">${_safeText(sec.title)}</div>`)
  ]).join('');
  document.getElementById('reader-toc').innerHTML = tocHtml;
  document.getElementById('mobile-toc-panel').innerHTML = tocHtml;
  showSection(0, 0);

}


let _returnToReader = null; // 記錄從哪個精華筆記節跳過來

function goToQuestion(examCode, qText) {
  // 記錄來源：從 reader-body 的 h3 取得 ci/si
  const h3 = document.querySelector('#reader-body h3[data-ci]');
  if(h3) {
    _returnToReader = { ci: parseInt(h3.dataset.ci), si: parseInt(h3.dataset.si) };
  }

  // 找到對應題目
  const target = Q.find(q => q.e === examCode && q.s.startsWith(qText.substring(0, 20)));
  if(!target) { showToast('找不到對應題目'); return; }
  // 切換到歷屆題庫
  goPage('quiz');
  // 設定 qFiltered 為單題
  qFiltered = [target];
  qCurrent = 0; qAnswers = {}; qCorrect = 0; qWrong = 0;
  document.getElementById('quiz-prog-wrap').style.display = 'block';
  updateQuizStat();
  renderQuizQ();
  // 顯示返回浮動條
  _showReturnBar();
  // 提示
  showToast('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg> 來自精華筆記的考題');
}

function _showReturnBar() {
  if(!_returnToReader) return;
  const ci = _returnToReader.ci, si = _returnToReader.si;
  const secTitle = CHAPTERS[ci]?.sections[si]?.title || '精華筆記';
  const chTitle  = CHAPTERS[ci]?.title || '';
  // 移除舊的
  document.getElementById('_returnBar')?.remove();
  const bar = document.createElement('div');
  bar.id = '_returnBar';
  bar.innerHTML = `<span style="opacity:.75;font-size:.78em;white-space:nowrap">↩ 回到筆記</span><span style="font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:.82em">${secTitle}</span>`;
  bar.style.cssText = [
    'position:fixed','top:64px','right:12px',
    'background:linear-gradient(135deg,#1b5c42,#2e7a52)',
    'color:#fff','padding:7px 12px 7px 11px',
    'border-radius:22px','box-shadow:0 3px 14px rgba(0,0,0,.22)',
    'font-size:.8rem','cursor:pointer','z-index:9999',
    'display:flex','align-items:center','gap:6px',
    'max-width:52vw','overflow:hidden',
    'animation:_slideDown .3s ease'
  ].join(';');
  // 左側箭頭圖示
  const arrow = document.createElement('span');
  arrow.innerHTML = '←';
  arrow.style.cssText = 'font-size:1.1em;font-weight:900;flex-shrink:0';
  bar.prepend(arrow);
  // 關閉按鈕
  const close = document.createElement('span');
  close.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
  close.style.cssText = 'margin-left:10px;opacity:.6;font-size:.8em;flex-shrink:0';
  close.onclick = (e) => { e.stopPropagation(); bar.remove(); _returnToReader = null; };
  bar.appendChild(close);
  // 點擊返回
  bar.onclick = () => {
    goPage('reader');
    showSection(ci, si);
    bar.remove();
    _returnToReader = null;
  };
  document.body.appendChild(bar);
  // 10秒後自動淡出（但不消失，只是提示）
  setTimeout(() => { if(bar.parentNode) bar.style.opacity = '0.85'; }, 10000);
}

// 離開 quiz 頁面時清除返回條
function _clearReturnBar() {
  document.getElementById('_returnBar')?.remove();
}

// ── 章節 HTML 懶載入快取 ──
const _chapterCache = {};
function _loadChapterHtml(ci) {
  return new Promise((resolve) => {
    if (_chapterCache[ci]) { resolve(_chapterCache[ci]); return; }
    const s = document.createElement('script');
    s.src = `chapters/ch${ci + 1}.js`;
    s.onload = () => resolve(_chapterCache[ci]);
    s.onerror = () => { console.error('Failed to load ch' + (ci+1) + '.js'); resolve([]); };
    document.head.appendChild(s);
  });
}

async function showSection(ci, si){
  const sec = CHAPTERS[ci].sections[si];

  // 懶載入章節 HTML
  const readerBody = document.getElementById('reader-body');
  readerBody.innerHTML = '<div style="text-align:center;padding:60px 0;color:#999;">載入中…</div>';

  const htmlArr = await _loadChapterHtml(ci);
  const secHtml = htmlArr[si] || '';

  // 建立線性索引（展平所有節）
  const linearMap = [];
  CHAPTERS.forEach((ch,c) => ch.sections.forEach((_,s) => linearMap.push({ci:c,si:s})));
  const curIdx = linearMap.findIndex(l => l.ci===ci && l.si===si);
  const prev = curIdx > 0 ? linearMap[curIdx-1] : null;
  const next = curIdx < linearMap.length-1 ? linearMap[curIdx+1] : null;
  const chTitle = CHAPTERS[ci].title;

  // 手機版節導航列（768px 以下顯示）
  const isMobile = window.innerWidth <= 768;
  const navHtml = isMobile ? `
    <div class="reader-sec-nav">
      <button class="reader-sec-nav-btn" ${prev ? `onclick="showSection(${prev.ci},${prev.si})"` : 'disabled'}>‹</button>
      <div class="reader-sec-nav-title">${_safeText(chTitle)}<br><small>${_safeText(sec.title)}</small></div>
      <button class="reader-sec-nav-btn" ${next ? `onclick="showSection(${next.ci},${next.si})"` : 'disabled'}>›</button>
    </div>` : '';

  readerBody.innerHTML =
    navHtml +
    `<h3 data-ci="${ci}" data-si="${si}">${_safeText(sec.title)}</h3>` +
    secHtml;

  document.querySelectorAll('.toc-sec').forEach(el => {
    el.classList.toggle('active', el.dataset.ci == ci && el.dataset.si == si);
  });
  document.querySelector(`.toc-sec[data-ci="${ci}"][data-si="${si}"]`)
    ?.scrollIntoView({block:'nearest', behavior:'smooth'});
  document.getElementById('mobile-toc-panel').classList.remove('show');
  const sideCtx = document.getElementById('sidebar-reading-ctx');
  if(sideCtx){ sideCtx.textContent = sec.title; sideCtx.style.display = 'block'; }

  // 渲染章節後觸發圖表初始化
  setTimeout(_initSectionCharts, 100);
  // 捲回頂部
  const body = document.getElementById('reader-body');
  if(body) body.scrollTop = 0;
  window.scrollTo(0, 0);
}

function _initSectionCharts(){
  // 綠色金融行動方案演進圖
  const gfCtx = document.getElementById('chart-gf');
  if(gfCtx && !gfCtx._chartInited){
    gfCtx._chartInited = true;
    if(typeof Chart !== 'undefined'){
      new Chart(gfCtx, {
        type: 'bar',
        data: {
          labels: ['1.0\n環境面向','2.0\nESG面向','3.0\n淨零轉型','4.0\n轉型金融'],
          datasets:[{
            label:'推動面向數',
            data:[3,4,5,6],
            backgroundColor:['#b8e4d0','#72c49a','#3fa068','#2e7a52'],
            borderRadius:6,
          }]
        },
        options:{
          responsive:true,
          plugins:{
            legend:{display:false},
            title:{display:true,text:'綠色金融行動方案演進（推動面向數量）',font:{size:12}}
          },
          scales:{y:{beginAtZero:true,max:8,ticks:{stepSize:1}}}
        }
      });
    }
  }
}

function toggleMobileToc(){
  const panel = document.getElementById('mobile-toc-panel');
  // 確保有 TOC 內容
  if(!panel.innerHTML.trim()){
    panel.innerHTML = document.getElementById('reader-toc').innerHTML;
  }
  panel.classList.toggle('show');
}

function switchReaderTab(tab){
  document.querySelectorAll('.reader-tab').forEach(t => t.classList.remove('active'));
  document.querySelector(`.reader-tab[onclick*="${tab}"]`).classList.add('active');
  document.getElementById('reader-read-view').style.display     = tab === 'read'     ? '' : 'none';
  document.getElementById('reader-practice-view').style.display = tab === 'practice' ? '' : 'none';
  document.getElementById('mobile-toc-btn').style.display       = tab === 'read'     ? '' : 'none';
  if(tab === 'practice') initReaderPractice();
}

let _rqInit = false;
function initReaderPractice(){
  if(_rqInit) return;
  _rqInit = true;
  const chapters = [...new Set(READER_Q.map(q => q.chapter))];
  const sel = document.getElementById('rq-chapter-filter');
  chapters.forEach(ch => { sel.innerHTML += `<option value="${ch}">${_safeText(ch)}</option>`; });
  document.getElementById('rq-badge').textContent = READER_Q.length + '題';
  updateRqSections();
}

// 快取：分組 READER_Q
const _rqByChapter = {};
function _getRqPool(ch){
  if(ch === FILTER_ALL) return READER_Q;
  return (_rqByChapter[ch] ??= READER_Q.filter(q => q.chapter === ch));
}

function updateRqSections(){
  const ch   = document.getElementById('rq-chapter-filter').value;
  const pool = _getRqPool(ch);
  const secs = [...new Set(pool.map(q => q.section))];
  const sel  = document.getElementById('rq-section-filter');
  sel.innerHTML = '<option value="all">全部小節</option>';
  secs.forEach(s => { sel.innerHTML += `<option value="${_safeText(s)}">${_safeText(s)}</option>`; });
  document.getElementById('rq-stat').textContent = `可選 ${pool.length} 題`;
}

let rqFiltered=[], rqCurrent=0, rqAnswers={}, rqCorrect=0, rqWrong=0, rqPending=null;

function startReaderQuiz(){
  const ch = document.getElementById('rq-chapter-filter').value;
  const sc = document.getElementById('rq-section-filter').value;
  let pool = [..._getRqPool(ch)];
  if(sc !== FILTER_ALL) pool = pool.filter(q => q.section === sc);
  if(!pool.length){ showToast('此篩選條件沒有題目'); return; }
  rqFiltered = shuffle(pool);
  rqCurrent = 0; rqAnswers = {}; rqCorrect = 0; rqWrong = 0; rqPending = null;
  document.getElementById('rq-prog-wrap').style.display = 'block';
  updateRqStat();
  renderRq();
}

function resetReaderQuiz(){
  rqFiltered=[]; rqCurrent=0; rqAnswers={}; rqCorrect=0; rqWrong=0; rqPending=null;
  document.getElementById('rq-prog-wrap').style.display = 'none';
  document.getElementById('rq-area').innerHTML = '<p style="text-align:center;color:var(--gray);padding:40px;font-size:.9rem;">選擇章節後按「開始練習」進行隨堂測驗</p>';
  document.getElementById('rq-stat').textContent = '';
  updateRqSections();
}

function updateRqStat(){
  const done  = Object.keys(rqAnswers).length;
  const total = rqFiltered.length;
  const pct   = total ? Math.round(done / total * 100) : 0;
  document.getElementById('rq-prog').style.width      = pct + '%';
  document.getElementById('rq-prog-txt').textContent  = `${done} / ${total} 題`;
  document.getElementById('rq-score-txt').textContent = `答對 ${rqCorrect} 答錯 ${rqWrong}`;
}

function renderRq(){
  if(!rqFiltered.length) return;
  if(rqCurrent >= rqFiltered.length){ showRqResult(); return; }
  const q        = rqFiltered[rqCurrent];
  const answered = rqAnswers[rqCurrent] !== undefined;
  document.getElementById('rq-area').innerHTML = _questionCardHtml({
    q, current: rqCurrent, total: rqFiltered.length,
    answered, userAnswer: rqAnswers[rqCurrent],
    tagLabel: '隨堂練習', tagStyle: 'border-left-color:var(--teal)',
    onSelect: 'rqSelect', onPrev: 'rqPrev', onNext: 'rqNext', onSubmit: 'showRqResult'
  });
  updateRqStat();
}

function rqSelect(idx){
  if(rqAnswers[rqCurrent] !== undefined) return;
  rqPending = idx;
  renderRq();
}
function rqConfirm(){
  if(rqPending === null || rqAnswers[rqCurrent] !== undefined) return;
  rqAnswers[rqCurrent] = rqPending;
  if(rqPending === rqFiltered[rqCurrent].a) rqCorrect++; else rqWrong++;
  rqPending = null;
  renderRq();
}
function rqNext(){ if(rqAnswers[rqCurrent]===undefined){showToast('請先確認答案');return;} if(rqCurrent<rqFiltered.length-1){rqCurrent++;rqPending=null;renderRq();} }
function rqPrev(){ if(rqCurrent>0){rqCurrent--;rqPending=null;renderRq();} }

function showRqResult(){
  const total   = rqFiltered.length;
  const done    = Object.keys(rqAnswers).length;
  const pct     = total ? Math.round(rqCorrect / total * 100) : 0;
  const p = loadProgress();
  // 累計章節弱點統計
  const _rqChStats = {}, _rqSecStats = {};
  rqFiltered.forEach((q, i) => {
    const ch  = _E_TO_CH[q.chapter] || _E_TO_CH[q.e] || 'other';
    const sec = q.section || 'other';
    const hit = rqAnswers[i] === q.a;
    if(!_rqChStats[ch])  _rqChStats[ch]  = {correct:0, total:0};
    if(!_rqSecStats[sec]) _rqSecStats[sec] = {correct:0, total:0, ch};
    _rqChStats[ch].total++;   if(hit) _rqChStats[ch].correct++;
    _rqSecStats[sec].total++; if(hit) _rqSecStats[sec].correct++;
  });
  p.history.unshift({date:new Date().toLocaleDateString('zh-TW'),type:'隨堂',total,correct:rqCorrect,pct,chStats:_rqChStats,secStats:_rqSecStats});
  if(!p.chStats) p.chStats = {};
  Object.entries(_rqChStats).forEach(([ch,s]) => {
    if(!p.chStats[ch]) p.chStats[ch] = {correct:0, total:0};
    p.chStats[ch].correct += s.correct;
    p.chStats[ch].total   += s.total;
  });
  if(!p.secStats) p.secStats = {};
  Object.entries(_rqSecStats).forEach(([sec,s]) => {
    if(!p.secStats[sec]) p.secStats[sec] = {correct:0,total:0,ch:s.ch};
    p.secStats[sec].correct += s.correct;
    p.secStats[sec].total   += s.total;
  });
  saveProgress(p);
  document.getElementById('rq-area').innerHTML = _resultPanelHtml({
    pct, correct: rqCorrect, wrong: rqWrong, skipped: total-done,
    title: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><rect x="18" y="3" width="4" height="18"/><rect x="10" y="8" width="4" height="13"/><rect x="2" y="13" width="4" height="8"/></svg> 隨堂練習成績',
    actions: `<button style="background:var(--teal);color:#fff;" onclick="startReaderQuiz()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg> 重新練習</button>
              <button style="background:var(--lgray);color:var(--gray);" onclick="switchReaderTab('read')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg> 回到課文</button>`
  });
  document.getElementById('rq-prog-wrap').style.display = 'none';
}

// ════════════════════════════════════════════════
//  NOTES
// ════════════════════════════════════════════════
let _notesInit = false;

// 快取：分組 CONCEPTS（使用 ??= nullish coalescing assignment）
const _conceptsByChapter = {};
function _getConceptsPool(ch){
  if(ch === FILTER_ALL) return CONCEPTS;
  return (_conceptsByChapter[ch] ??= CONCEPTS.filter(c => c.chapter === ch));
}

function initNotes(){
  if(_notesInit) return;
  _notesInit = true;
  const chapters = [...new Set(CONCEPTS.map(c => c.chapter))];
  let fHtml = `<span class="chip active" data-ch="all" onclick="filterNotes(this)">全部 <b style="font-size:.7rem;opacity:.8">${CONCEPTS.length}</b></span>`;
  chapters.forEach(ch => {
    const cnt = _getConceptsPool(ch).length;
    fHtml += `<span class="chip" data-ch="${ch}" onclick="filterNotes(this)">${_safeText(ch)} <b style="font-size:.7rem;opacity:.8">${cnt}</b></span>`;
  });
  fHtml += '<span class="chip" data-ch="必考" onclick="filterBadge(this)" style="border-color:#d4a56a;color:#856404"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg> 必考</span>';
  document.getElementById('notes-filters').innerHTML = fHtml;
  renderNoteCards(FILTER_ALL);
  // 初始化考點頁內嵌圖表
  if(typeof Chart !== 'undefined'){
    _initChartsPage('chart-gfa-concept');
  } else {
    const _waitChartCo = setInterval(() => {
      if(typeof Chart !== 'undefined'){ clearInterval(_waitChartCo); _initChartsPage('chart-gfa-concept'); }
    }, 100);
  }
}

function _conceptCardHtml(c){
  const preview = (()=>{
    const m = (c.content||'').match(/class="kc-def[^"]*">([^]*?)<\/div>/);
    if(!m) return '';
    const txt = m[1].replace(/<[^>]+>/g,'').replace(/\s+/g,' ').trim();
    return txt.slice(0,60) + (txt.length>60?'…':'');
  })();
  // 讀取瀏覽狀態
  let _isViewed = false;
  try{
    const _viewed = JSON.parse(localStorage.getItem(CONCEPTS_VIEWED_KEY) || '[]');
    _isViewed = _viewed.includes(c.topic);
  }catch{}
  return `<div class="concept-card" onclick="toggleCard(this)">
    <div class="cc-stripe"></div>
    <div class="cc-main">
      <div class="concept-card-head">
        <span class="ch-tag">${_safeText(c.chapter)}</span>
        ${c.badge ? `<span class="badge badge-${c.badge}">${_safeText(c.badge)}</span>` : ''}
        <h4>${_safeText(c.topic)}</h4>
        <span class="cc-viewed-check" style="display:${_isViewed?'inline-flex':'none'};align-items:center;margin-left:4px;flex-shrink:0;color:#2e7a52;" title="已瀏覽"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
        <span class="expand-icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;transition:transform .2s;"><polyline points="9 18 15 12 9 6"/></svg></span>
      </div>
      ${preview ? `<div class="cc-preview">${preview}</div>` : ''}
      <div class="concept-card-body">${c.content || '（內容見課文）'}</div>
    </div>
  </div>`;
}

function filterBadge(el){
  document.querySelectorAll('#notes-filters .chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('notes-cards').innerHTML =
    CONCEPTS.filter(c => c.badge === '必考').map(_conceptCardHtml).join('');
}

function filterNotes(el){
  document.querySelectorAll('#notes-filters .chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  renderNoteCards(el.dataset.ch);
}

function renderNoteCards(ch){
  document.getElementById('notes-cards').innerHTML =
    _getConceptsPool(ch).map(_conceptCardHtml).join('');
}

function toggleCard(el){
  el.classList.toggle('expanded');
  // 記錄已瀏覽（以 topic 為 key）
  if(el.classList.contains('expanded')){
    const topic = el.querySelector('h4')?.textContent?.trim();
    if(topic){
      try{
        const viewed = JSON.parse(localStorage.getItem(CONCEPTS_VIEWED_KEY) || '[]');
        if(!viewed.includes(topic)){ viewed.push(topic); localStorage.setItem(CONCEPTS_VIEWED_KEY, JSON.stringify(viewed)); }
        // 更新勾勾顯示
        const ckEl = el.querySelector('.cc-viewed-check');
        if(ckEl) ckEl.style.display = 'inline-flex';
      }catch{}
    }
  }
}

// ════════════════════════════════════════════════
//  QUIZ
// ════════════════════════════════════════════════
let qFiltered=[], qCurrent=0, qAnswers={}, qCorrect=0, qWrong=0;

function startQuiz(){
  const ef  = document.getElementById('quiz-exam-filter').value;
  const cnt = parseInt(document.getElementById('quiz-count').value, 10);
  const ord = document.getElementById('quiz-order').value;
  if(isNaN(cnt) || cnt < 1){ showToast('請輸入有效題數'); return; }
  let pool = ef === FILTER_ALL ? Q : Q.filter(q => q.e === ef);
  if(ord === 'rand') pool = shuffle(pool);
  qFiltered = pool.slice(0, Math.min(cnt, pool.length));
  qCurrent = 0; qAnswers = {}; qCorrect = 0; qWrong = 0;
  document.getElementById('quiz-prog-wrap').style.display = 'block';
  updateQuizStat();
  renderQuizQ();
}

function resetQuiz(){
  qFiltered=[]; qCurrent=0; qAnswers={}; qCorrect=0; qWrong=0;
  document.getElementById('quiz-prog-wrap').style.display = 'none';
  document.getElementById('quiz-area').innerHTML = '<p style="text-align:center;color:var(--gray);padding:40px;font-size:.9rem;">選擇設定後按「開始練習」</p>';
  document.getElementById('quiz-stat').textContent = '';
}

function updateQuizStat(){
  const done  = Object.keys(qAnswers).length;
  const total = qFiltered.length;
  const pct   = total ? Math.round(done / total * 100) : 0;
  document.getElementById('quiz-prog').style.width      = pct + '%';
  document.getElementById('quiz-prog-txt').textContent  = `${done} / ${total} 題`;
  document.getElementById('quiz-score-txt').textContent = `答對 ${qCorrect} 答錯 ${qWrong}`;
  document.getElementById('quiz-stat').textContent      = `共 ${total} 題`;
}

function renderQuizQ(){
  if(!qFiltered.length) return;
  if(qCurrent >= qFiltered.length){ showQuizResult(); return; }
  const q        = qFiltered[qCurrent];
  const answered = qAnswers[qCurrent] !== undefined;
  document.getElementById('quiz-area').innerHTML = _questionCardHtml({
    q, current: qCurrent, total: qFiltered.length,
    answered, userAnswer: qAnswers[qCurrent],
    tagLabel: '永續發展',
    onSelect: 'quizSelect', onPrev: 'quizPrev', onNext: 'quizNext', onSubmit: 'showQuizResult'
  });
  updateQuizStat();
}

let qPending = null; // 考古題暫選

function quizSelect(idx){
  if(qAnswers[qCurrent] !== undefined) return; // 已確認
  qPending = idx;
  renderQuizQ(); // 顯示暫選 + 確認按鈕
}
function quizConfirm(){
  if(qPending === null || qAnswers[qCurrent] !== undefined) return;
  qAnswers[qCurrent] = qPending;
  if(qPending === qFiltered[qCurrent].a) qCorrect++; else qWrong++;
  qPending = null;
  updateQuizStat();
  renderQuizQ();
}
function quizNext(){ if(qAnswers[qCurrent]===undefined){showToast('請先選擇答案');return;} if(qCurrent<qFiltered.length-1){qCurrent++;renderQuizQ();} }
function quizPrev(){ if(qCurrent>0){qCurrent--;renderQuizQ();} }

function showQuizResult(){
  const total = qFiltered.length;
  const done  = Object.keys(qAnswers).length;
  const pct   = total ? Math.round(qCorrect / total * 100) : 0;
  const p = loadProgress();
  // 各章節答題統計
  const _chStats = {}, _secStats = {};
  qFiltered.forEach((q,i) => {
    const ch  = _qCh(q);
    const sec = q.section || 'other';
    const hit = qAnswers[i] === q.a;
    if(!_chStats[ch])  _chStats[ch]  = {correct:0, total:0};
    if(!_secStats[sec]) _secStats[sec] = {correct:0, total:0, ch};
    _chStats[ch].total++;   if(hit) _chStats[ch].correct++;
    _secStats[sec].total++; if(hit) _secStats[sec].correct++;
  });
  p.history.unshift({date:new Date().toLocaleDateString('zh-TW'),type:'練習',total,correct:qCorrect,pct,chStats:_chStats,secStats:_secStats});
  // 累計各章節總統計
  if(!p.chStats) p.chStats = {};
  Object.entries(_chStats).forEach(([ch,s]) => {
    if(!p.chStats[ch]) p.chStats[ch] = {correct:0,total:0};
    p.chStats[ch].correct += s.correct;
    p.chStats[ch].total   += s.total;
  });
  if(!p.secStats) p.secStats = {};
  Object.entries(_secStats).forEach(([sec,s]) => {
    if(!p.secStats[sec]) p.secStats[sec] = {correct:0,total:0,ch:s.ch};
    p.secStats[sec].correct += s.correct;
    p.secStats[sec].total   += s.total;
  });
  saveProgress(p);
  document.getElementById('quiz-area').innerHTML = _resultPanelHtml({
    pct, correct: qCorrect, wrong: qWrong, skipped: total-done,
    title: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><rect x="18" y="3" width="4" height="18"/><rect x="10" y="8" width="4" height="13"/><rect x="2" y="13" width="4" height="8"/></svg> 成績報告',
    actions: `<button style="background:var(--color-success);color:#fff;" onclick="startQuiz()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg> 重新練習</button>
              <button style="background:var(--lgray);color:var(--gray);" onclick="reviewWrongQ()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> 複習錯題</button>`
  });
  document.getElementById('quiz-prog-wrap').style.display = 'none';
}

function reviewWrongQ(){
  const wq = qFiltered.filter((_, i) => qAnswers[i]!==undefined && qAnswers[i]!==qFiltered[i].a);
  if(!wq.length){ showToast('沒有答錯的題目！<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M5.8 11.3L2 22l10.7-3.79"/><path d="M4 3h.01"/><path d="M22 8h.01"/><path d="M15 2h.01"/><path d="M22 20h.01"/><path d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12v0c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10"/><path d="m22 13-.82-.33c-.86-.34-1.82.2-1.98 1.11v0c-.19 1.07-1.1 1.86-2.2 1.86H17"/><path d="m11 2 1.27 2.89A2 2 0 0 0 14.12 6M5 6l-1 4"/></svg>'); return; }
  qFiltered=wq; qCurrent=0; qAnswers={}; qCorrect=0; qWrong=0;
  document.getElementById('quiz-prog-wrap').style.display = 'block';
  updateQuizStat();
  renderQuizQ();
}

// ════════════════════════════════════════════════
//  EXAM
// ════════════════════════════════════════════════
let examQ=[], examCur=0, examAns={}, examTimer=null, examSecs=0;

/* ── 解析題目所屬章節 (相容 Q 和 RQ 兩種欄位格式) ── */
function _qCh(q){
  if(q.ch) return q.ch;
  const e  = q.e       || '';
  const ch = q.chapter || '';
  const src = e + ' ' + ch;
  if(/第一章/i.test(src)) return 'ch1';
  if(/第二章/i.test(src)) return 'ch2';
  if(/第三章/i.test(src)) return 'ch3';
  if(/第四章/i.test(src)) return 'ch4';
  return 'other';
}

/* ── 歷屆考試官方章節分布（取自13年次平均，第三章最少） ── */
const OFFICIAL_DIST = { ch1:0.270, ch2:0.325, ch3:0.145, ch4:0.260 };

function startExam(){
  const cnt = parseInt(document.getElementById('exam-count').value, 10);
  if(isNaN(cnt) || cnt < 1){ showToast('請輸入有效題數'); return; }
  examSecs = Math.round(cnt * EXAM_SECS_PER_Q);

  /* ── 合併三個題庫並去重 ──────────────────────────────────────────
       1. Q           歷屆題庫  1040題  (e='113-1'等年次，有 ch 欄位)
       2. TEXTBOOK_Q  永續題庫  1336題  (e='官方第X章')
       3. READER_Q    隨堂練習   621題  (chapter='第X章...')
       去重 key = 完整題幹 q.s；優先順序 Q > TEXTBOOK_Q > READER_Q   ── */
  const _seen = new Set();
  const fullPool = [];
  [...Q, ...TEXTBOOK_Q, ...READER_Q].forEach(q => {
    const key = (q.s || '').trim();
    if(key && !_seen.has(key)){
      _seen.add(key);
      fullPool.push(q);
    }
  });

  /* ── 依官方比例計算各章出題數 ── */
  const chs = ['ch1','ch2','ch3','ch4'];
  const targets = {};
  let assigned = 0;
  chs.forEach((ch, i) => {
    targets[ch] = (i < chs.length - 1)
      ? Math.round(cnt * OFFICIAL_DIST[ch])
      : cnt - assigned;
    assigned += targets[ch];
  });
  /* 微調：確保總數等於 cnt */
  const diff = cnt - chs.reduce((s,c) => s + targets[c], 0);
  if(diff !== 0) targets['ch2'] += diff;

  /* ── 依章節分桶並隨機取樣 ── */
  const pool = {};
  chs.forEach(ch => pool[ch] = []);
  fullPool.forEach(q => {
    const ch = _qCh(q);
    if(pool[ch]) pool[ch].push(q);
  });

  examQ = [];
  chs.forEach(ch => {
    const picked = shuffle([...pool[ch]]).slice(0, targets[ch]);
    examQ.push(...picked);
  });
  examQ = shuffle(examQ);  /* 最後再打亂，混合各章順序 */
  examCur=0; examAns={}; _examSubmitted=false;
  document.getElementById('exam-setup').style.display   = 'none';
  document.getElementById('exam-running').style.display = 'block';
  document.getElementById('exam-result').style.display  = 'none';
  document.getElementById('exam-q-count').textContent   = '(' + examQ.length + ' 題)';
  startTimer();
  renderExamQ();
  // ── 考試開始埋點 ──
  window._logEvent && window._logEvent('exam_start', { question_count: examQ.length });
}

function startTimer(){
  if(examTimer) clearInterval(examTimer);
  examTimer = setInterval(() => {
    examSecs--;
    const el = document.getElementById('exam-timer');
    if(!el){ clearInterval(examTimer); return; }
    const m = Math.floor(examSecs / 60), s = examSecs % 60;
    el.textContent  = m + ':' + (s < 10 ? '0' : '') + s;
    el.className    = 'timer-display' + (examSecs < 300 ? ' warn' : '') + (examSecs < 60 ? ' critical' : '');
    if(examSecs <= 0){ clearInterval(examTimer); submitExam(); }
  }, 1000);
}

function renderExamQ(){
  const q        = examQ[examCur];
  const ua       = examAns[examCur];   /* undefined = 尚未作答 */
  const L        = ['A','B','C','D'];
  const answered = Object.keys(examAns).length;
  document.getElementById('exam-prog').style.width         = (answered / examQ.length * 100) + '%';
  document.getElementById('exam-prog-txt').textContent     = `第 ${examCur+1} 題 / 共 ${examQ.length} 題`;
  document.getElementById('exam-answered-txt').textContent = `已作答 ${answered} 題`;
  document.getElementById('exam-pos-txt').textContent      = (examCur+1) + ' / ' + examQ.length;
  document.getElementById('exam-area').innerHTML = `
    <div class="q-card" style="border-left-color:var(--blue);">
      <div class="q-meta">
        <span class="q-tag tag-blue">第 ${examCur+1} 題</span>
        ${ua !== undefined
          ? `<span style="margin-left:8px;font-size:.73rem;color:#5a7a5a;background:#eef6ee;border-radius:4px;padding:2px 8px;vertical-align:middle;">
               ✓ 已選 ${L[ua]}，可點選其他選項修改
             </span>`
          : '<span style="margin-left:8px;font-size:.73rem;color:#999;vertical-align:middle;">尚未作答</span>'
        }
      </div>
      <div class="q-stem">${_safeText(q.s)}</div>
      <div class="options">
        ${q.o.map((opt, i) => {
          /* 選項始終可點擊（交卷前），選中的顯示藍框 */
          const cls = 'opt' + (i === ua ? ' answered-sel' : '');
          return `<div class="${cls}" onclick="examSelect(${i})"><span class="letter">${L[i]}</span><span>${_safeText(opt)}</span></div>`;
        }).join('')}
      </div>
    </div>
    <div style="text-align:center;padding:8px 0 2px;font-size:.78rem;color:#bbb;">
      解析將於交卷後顯示
    </div>`;
}

let _examPending = null;
function examSelect(idx){
  /* 交卷後鎖定，否則任意時間可更改 */
  if(_examSubmitted) return;
  examAns[examCur] = idx;
  _examPending = null;
  renderExamQ();
}
function examConfirm(){ /* 保留空函數避免殘留 onclick 報錯 */ }
function examNext(){ if(examCur<examQ.length-1){examCur++;renderExamQ();} }
function examPrev(){ if(examCur>0){examCur--;renderExamQ();} }

function submitExam(){
  if(_examSubmitted) return; _examSubmitted=true;
  clearInterval(examTimer);
  const total   = examQ.length;
  const correct = examQ.reduce((s,q,i) => s + (examAns[i]===q.a ? 1 : 0), 0);
  const pct     = Math.round(correct / total * 100);
  const passed  = pct >= PASS_PCT;
  const p       = loadProgress();
  const _eChStats = {}, _eSecStats = {};
  examQ.forEach((q,i) => {
    const ch  = _qCh(q);
    const sec = q.section || 'other';
    const hit = examAns[i] === q.a;
    if(!_eChStats[ch])   _eChStats[ch]   = {correct:0, total:0};
    if(!_eSecStats[sec]) _eSecStats[sec] = {correct:0, total:0, ch};
    _eChStats[ch].total++;    if(hit) _eChStats[ch].correct++;
    _eSecStats[sec].total++;  if(hit) _eSecStats[sec].correct++;
  });
  if(!p.chStats) p.chStats = {};
  Object.entries(_eChStats).forEach(([ch,s]) => {
    if(!p.chStats[ch]) p.chStats[ch] = {correct:0,total:0};
    p.chStats[ch].correct += s.correct;
    p.chStats[ch].total   += s.total;
  });
  if(!p.secStats) p.secStats = {};
  Object.entries(_eSecStats).forEach(([sec,s]) => {
    if(!p.secStats[sec]) p.secStats[sec] = {correct:0,total:0,ch:s.ch};
    p.secStats[sec].correct += s.correct;
    p.secStats[sec].total   += s.total;
  });
  p.history.unshift({date:new Date().toLocaleDateString('zh-TW'),type:'模擬考試',total,correct,pct,passed,chStats:_eChStats,secStats:_eSecStats});
  saveProgress(p);
  // ── 考試結束埋點 ──
  window._logEvent && window._logEvent('exam_submit', {
    total, correct, pct, passed,
    skipped: total - Object.keys(examAns).length
  });
  const L          = ['A','B','C','D'];
  const wrongItems = examQ.map((q, i) => {
    const ua = examAns[i];
    const isCorrect = ua === q.a;
    const statusIcon = isCorrect ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>' : (ua !== undefined ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' : '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#e0e0e0" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><rect x="2" y="2" width="20" height="20" rx="2" fill="#e0e0e0" stroke="none"/></svg>');
    const statusColor = isCorrect ? 'var(--color-success)' : 'var(--color-danger)';
    return `<div style="border:1px solid ${isCorrect?'#b8e4d0':'var(--border)'};border-radius:8px;padding:12px 14px;margin-bottom:8px;font-size:.83rem;background:${isCorrect?'#eef8f3':'#fff'}">
      <div style="font-weight:600;margin-bottom:6px;color:${statusColor};">${statusIcon} Q${i+1}. ${_safeText(q.s.slice(0, 80))}…</div>
      ${ua !== undefined
        ? `<div style="color:${statusColor};">${isCorrect?'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg>':'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>'} 你的答案：${L[ua]}. ${_safeText(q.o[ua])}</div>`
        : '<div style="color:var(--gray)">（未作答）</div>'}
      ${!isCorrect ? `<div style="color:var(--color-success)"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/></svg> 正確答案：${L[q.a]}. ${_safeText(q.o[q.a])}</div>` : ''}
      ${q.x ? `<div style="margin-top:6px;font-size:.8rem;color:#37474f;">【解析】${_safeTextNL(q.x)}</div>` : ''}
      ${_relatedCourseBtn(q)}${typeof _textbookBtn==='function'?_textbookBtn(q):''}
    </div>`;
  }).join('');
  const ringColor = passed ? 'var(--gl)' : 'var(--color-danger)';
  const passLabel = passed ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> 通過！' : `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> 未通過（${PASS_PCT}分合格）`;
  document.getElementById('exam-running').style.display = 'none';
  document.getElementById('exam-result').style.display  = 'block';
  document.getElementById('exam-result').innerHTML = `
    <div class="result-panel">
      <h2><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> 考試成績單</h2>
      ${_scoreRingHtml(pct, ringColor)}
      <p style="font-size:1.2rem;font-weight:700;color:${ringColor};">${passLabel}</p>
      <div class="result-stats">
        <div class="rs-box rs-correct"><div class="rs-num">${correct}</div>答對</div>
        <div class="rs-box rs-wrong"><div class="rs-num">${Object.keys(examAns).length-correct}</div>答錯</div>
        <div class="rs-box rs-skip"><div class="rs-num">${total-Object.keys(examAns).length}</div>未作答</div>
      </div>
      <div class="result-actions">
        <button type="button" style="background:var(--color-success);color:#fff;" onclick="restartExam()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg> 再考一次</button>
        <button type="button" style="background:var(--lgray);color:var(--gray);" onclick="goPage('${PAGES.QUIZ}')"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg> 歷屆題庫</button>
      </div>
      <div style="margin-top:20px;text-align:left;">
      <h4 style="margin-bottom:10px;color:var(--gray);"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg> 所有題目解析</h4>
      ${wrongItems}</div>
    </div>`;
}

function restartExam(){
  clearInterval(examTimer);
  document.getElementById('exam-result').style.display = 'none';
  document.getElementById('exam-setup').style.display  = 'block';
  renderExamHistory();
}

function renderExamHistory(){
  const p     = loadProgress();
  const exams = p.history.filter(h => h.type === '模擬考試');
  const el    = document.getElementById('exam-history-summary');
  if(!el) return;
  if(!exams.length){
    el.innerHTML = '<p style="color:var(--gray);font-size:.84rem;text-align:center;padding:12px;">尚無考試紀錄，開始第一次模擬吧！</p>';
    return;
  }
  const best      = Math.max(...exams.map(e => e.pct));
  const last      = exams[0];
  const passCount = exams.filter(e => e.pct >= PASS_PCT).length;
  el.innerHTML = `<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
    <div style="background:var(--gp);border-radius:10px;padding:12px;text-align:center;">
      <div style="font-size:1.4rem;font-weight:800;color:var(--color-success)">${best}%</div>
      <div style="font-size:.75rem;color:var(--gray);margin-top:2px;">歷史最高</div>
    </div>
    <div style="background:${last.pct>=PASS_PCT?'var(--gp)':'var(--rp)'};border-radius:10px;padding:12px;text-align:center;">
      <div style="font-size:1.4rem;font-weight:800;color:${last.pct>=PASS_PCT?'var(--color-success)':'var(--color-danger)'}">${last.pct}%</div>
      <div style="font-size:.75rem;color:var(--gray);margin-top:2px;">上次成績</div>
    </div>
    <div style="background:var(--bp);border-radius:10px;padding:12px;text-align:center;">
      <div style="font-size:1.4rem;font-weight:800;color:var(--blue)">${passCount}/${exams.length}</div>
      <div style="font-size:.75rem;color:var(--gray);margin-top:2px;">通過次數</div>
    </div>
  </div>`;
}

// ════════════════════════════════════════════════
//  PROGRESS
// ════════════════════════════════════════════════
function renderProgress(){
  const p       = loadProgress();
  const total   = p.history.reduce((s,h) => s + h.total,   0);
  const correct = p.history.reduce((s,h) => s + h.correct, 0);
  const wrong   = total - correct;
  const pct     = total ? Math.round(correct / total * 100) : 0;
  // ── 各來源分類統計 ──
  const _byType = (type) => p.history.filter(h => h.type === type);
  const _quiz    = _byType('練習');
  const _exam    = _byType('模擬考試');
  const _tb      = _byType('永續題庫');
  const _rq      = _byType('隨堂');
  const sessions      = p.history.length;
  const examSessions  = _exam.length;
  const passCount     = _exam.filter(h => h.pct >= PASS_PCT).length; // 只算模擬考試及格

  // ── 甜甜圈 ──
  const r = pct / 100;
  const offset = SVG_CIRCUMFERENCE * (1 - r);
  document.getElementById('donut-overall').innerHTML = `
    <svg viewBox="0 0 100 100" style="width:140px;height:140px;transform:rotate(-90deg)">
      <circle fill="none" stroke="var(--lgray)" stroke-width="12" cx="50" cy="50" r="${SVG_RADIUS}" stroke-dasharray="${SVG_CIRCUMFERENCE}"/>
      <circle fill="none" stroke="${pct>=PASS_PCT?'var(--gl)':'#d45060'}" stroke-width="12" cx="50" cy="50" r="${SVG_RADIUS}"
        stroke-dasharray="${SVG_CIRCUMFERENCE}" stroke-dashoffset="${offset.toFixed(1)}" stroke-linecap="round"/>
    </svg>
    <div class="donut-label" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
      <span style="font-size:1.5rem;font-weight:900;color:${pct>=PASS_PCT?'var(--color-success)':'#d04555'}">${pct}%</span>
      <span style="font-size:.72rem;color:var(--gray);margin-top:2px;">${correct}/${total} 題</span>
    </div>`;
  document.getElementById('overall-desc').textContent =
    total ? `全題庫累計 ${sessions} 次，作答 ${total} 題` : '尚無練習紀錄';
  // 說明文字：混合來源
  const _overallSubEl = document.getElementById('overall-desc-sub');
  if(_overallSubEl) _overallSubEl.textContent = total ? '含歷屆練習、模擬考試、官方題庫、隨堂練習' : '';

  // ── 統計卡片列（各來源分拆）──
  const statsEl = document.getElementById('prog-stats-row');
  const _typeTotal  = t => t.reduce((s,h)=>s+h.total,0);
  const _typeCorrect= t => t.reduce((s,h)=>s+h.correct,0);
  const _typePct    = t => { const tot=_typeTotal(t); return tot?Math.round(_typeCorrect(t)/tot*100):'-'; };
  if(statsEl) statsEl.innerHTML = `
    <div style="width:100%;display:grid;grid-template-columns:repeat(4,1fr);gap:8px;">
      ${[
        { label:'歷屆練習', data:_quiz,  color:'#89b4d4', bg:'#e8f2f9', tag:'練習' },
        { label:'模擬考試', data:_exam,  color:'#8872b8', bg:'#ede8f7', tag:'模擬' },
        { label:'官方題庫', data:_tb,    color:'#4a9480', bg:'#e0f2f1', tag:'官題' },
        { label:'隨堂練習', data:_rq,    color:'#c87848', bg:'#fdf0e0', tag:'隨堂' },
      ].map(s => {
        const tot = _typeTotal(s.data), cor = _typeCorrect(s.data);
        const pctVal = s.data.length ? _typePct(s.data) : '-';
        return `<div style="background:${s.bg};border-radius:12px;padding:10px 12px;
          display:flex;flex-direction:column;gap:3px;border:1.5px solid ${s.color}33;">
          <div style="font-size:.68rem;font-weight:700;color:${s.color};letter-spacing:.5px;">${s.label}</div>
          <div style="font-size:1.1rem;font-weight:900;color:${s.color};">${pctVal}${pctVal!=='-'?'%':''}</div>
          <div style="font-size:.7rem;color:#666;">${cor}/${tot} 題・${s.data.length} 次</div>
        </div>`;
      }).join('')}
    </div>
    <div style="width:100%;display:flex;gap:10px;flex-wrap:wrap;margin-top:4px;">
      <div style="flex:1;min-width:120px;background:#f8f8f8;border-radius:10px;padding:10px 14px;
        display:flex;align-items:center;justify-content:space-between;border:1px solid #eee;">
        <span style="font-size:.78rem;color:#555;">模擬考及格</span>
        <span style="font-size:1rem;font-weight:800;color:${passCount>0?'#2e7a52':'#999'};">
          ${passCount} / ${examSessions} 次</span>
      </div>
      <div style="flex:1;min-width:120px;background:#f8f8f8;border-radius:10px;padding:10px 14px;
        display:flex;align-items:center;justify-content:space-between;border:1px solid #eee;">
        <span style="font-size:.78rem;color:#555;">全部作答</span>
        <span style="font-size:1rem;font-weight:800;color:#333;">${total} 題</span>
      </div>
    </div>`;

  // ── 練習紀錄 ──
  const _TYPE_COLOR = {
    '練習':   {bg:'#e8f2f9',color:'#89b4d4'},
    '模擬考試':{bg:'#ede8f7',color:'#8872b8'},
    '永續題庫':{bg:'#e0f2f1',color:'#4a9480'},
    '隨堂':   {bg:'#fdf0e0',color:'#c87848'},
  };
  const _CH_LABELS = {ch1:'第一章 永續基本概念',ch2:'第二章 永續資訊揭露',ch3:'第三章 永續風險管理與治理',ch4:'第四章 永續金融'};
  const _CH_ORDER  = ['ch1','ch2','ch3','ch4'];
  const _SEC_ORDER = [
    '第一節 永續介紹與發展目標','第二節 國內永續發展政策','第三節 國際永續發展政策',
    '第一節 國際永續資訊公開規範','第二節 國內永續資訊公開規範','第三節 第三方確信',
    '第一節 整體 ESG 風險概述','第二節 環境風險','第三節 社會風險','第四節 治理風險',
    '第一節 永續評比與指數','第二節 永續投資','第三節 永續融資','第四節 永續授信','第五節 永續保險','第六節 永續金融應注意的漂綠問題',
  ];
  const _SEC_TO_CH = {
    '第一節 永續介紹與發展目標':'ch1','第二節 國內永續發展政策':'ch1','第三節 國際永續發展政策':'ch1',
    '第一節 國際永續資訊公開規範':'ch2','第二節 國內永續資訊公開規範':'ch2','第三節 第三方確信':'ch2',
    '第一節 整體 ESG 風險概述':'ch3','第二節 環境風險':'ch3','第三節 社會風險':'ch3','第四節 治理風險':'ch3',
    '第一節 永續評比與指數':'ch4','第二節 永續投資':'ch4','第三節 永續融資':'ch4','第四節 永續授信':'ch4','第五節 永續保險':'ch4','第六節 永續金融應注意的漂綠問題':'ch4',
  };

  // 展開狀態（用 index 追蹤）
  if(!window._histExpanded) window._histExpanded = {};

  const _renderHistoryDetail = (h) => {
    const cs = h.chStats || {}, ss = h.secStats || {};
    const hasDetail = Object.keys(cs).length > 0;
    if(!hasDetail) return '<p style="color:var(--gray);font-size:.78rem;padding:8px 0;">此筆無章節明細</p>';

    return _CH_ORDER.map(ch => {
      const c = cs[ch];
      if(!c || !c.total) return '';
      const chPct  = Math.round(c.correct/c.total*100);
      const chColor= chPct>=80?'#2e7a52':chPct>=PASS_PCT?'#c8906a':'#d04555';

      // 該章的節次
      const secRows = _SEC_ORDER
        .filter(sec => _SEC_TO_CH[sec] === ch)
        .map(sec => {
          const sv = ss[sec];
          if(!sv || !sv.total) return '';
          const sPct   = Math.round(sv.correct/sv.total*100);
          const sColor = sPct>=80?'#2e7a52':sPct>=PASS_PCT?'#c8906a':'#d04555';
          return `<div style="display:flex;align-items:center;gap:6px;padding:3px 0 3px 12px;border-left:2px solid #eee;">
            <span style="font-size:.72rem;color:#666;flex:1;">${sec}</span>
            <div style="width:60px;height:5px;background:#f0f0f0;border-radius:99px;overflow:hidden;flex-shrink:0;">
              <div style="height:100%;width:${sPct}%;background:${sColor};border-radius:99px;"></div>
            </div>
            <span style="font-size:.7rem;font-weight:700;color:${sColor};width:40px;text-align:right;">${sPct}%</span>
            <span style="font-size:.68rem;color:#aaa;width:36px;text-align:right;">${sv.correct}/${sv.total}</span>
          </div>`;
        }).join('');

      return `<div style="margin-bottom:8px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
          <span style="font-size:.75rem;font-weight:700;color:${chColor};flex:1;">${_CH_LABELS[ch]||ch}</span>
          <div style="width:80px;height:7px;background:#f0f0f0;border-radius:99px;overflow:hidden;flex-shrink:0;">
            <div style="height:100%;width:${chPct}%;background:${chColor};border-radius:99px;"></div>
          </div>
          <span style="font-size:.75rem;font-weight:800;color:${chColor};width:40px;text-align:right;">${chPct}%</span>
          <span style="font-size:.68rem;color:#aaa;width:36px;text-align:right;">${c.correct}/${c.total}</span>
        </div>
        ${secRows}
      </div>`;
    }).join('');
  };

  if(!window._histShowAll) window._histShowAll = false;
  const _histLimit = window._histShowAll ? p.history.length : 20;
  const _histListEl = document.getElementById('history-list');
  _histListEl.innerHTML = p.history.length
    ? p.history.slice(0, _histLimit).map((h, i) => {
        const tc      = _TYPE_COLOR[h.type] || {bg:'#f5f5f5',color:'#999'};
        const _hKey   = `${h.date}_${h.type}_${h.total}`;
        const isOpen  = !!window._histExpanded[_hKey];
        const hasDetail = h.chStats && Object.keys(h.chStats).length > 0;
        return `
        <div style="border-radius:8px;margin-bottom:4px;border:1px solid #f0f0f0;overflow:hidden;">
          <div style="display:flex;align-items:center;gap:8px;padding:8px 10px;
            background:${i%2===0?'#fafafa':'#fff'};
            cursor:${hasDetail?'pointer':'default'};"
            onclick="(()=>{if(!${hasDetail})return;window._histExpanded['${_hKey}']=!window._histExpanded['${_hKey}'];renderProgress();})()">
            <span style="font-size:.75rem;color:var(--gray);flex-shrink:0;width:56px;">${_safeText(h.date)}</span>
            <span style="font-size:.7rem;font-weight:700;padding:2px 7px;border-radius:20px;
              background:${tc.bg};color:${tc.color};flex-shrink:0;">${_safeText(h.type)}</span>
            <span style="font-size:.78rem;color:#555;flex:1;">${h.correct}/${h.total} 題</span>
            <span style="font-size:.75rem;font-weight:800;padding:2px 10px;border-radius:20px;
              background:${h.pct>=PASS_PCT?'#e2f5ec':'#ffebee'};
              color:${h.pct>=PASS_PCT?'#2e7a52':'#c62828'};">${h.pct}%</span>
            ${hasDetail?`<span style="font-size:.7rem;color:#aaa;flex-shrink:0;">${isOpen?'▲':'▼'}</span>`:''}
          </div>
          ${isOpen ? `<div style="padding:10px 12px;background:#fdfdfd;border-top:1px solid #f0f0f0;">
            ${_renderHistoryDetail(h)}
          </div>` : ''}
        </div>`;
      }).join('')
    : '<p style="color:var(--gray);text-align:center;padding:24px;font-size:.85rem;">尚無練習紀錄</p>';
  // 顯示更多 / 收起
  if(p.history.length > 20) {
    const _moreBtn = document.createElement('div');
    _moreBtn.style.cssText = 'text-align:center;margin-top:8px;';
    _moreBtn.innerHTML = `<button onclick="window._histShowAll=!window._histShowAll;renderProgress();"
      style="font-size:.75rem;padding:5px 18px;border-radius:20px;border:1px solid #ddd;
      background:#fff;color:#666;cursor:pointer;">
      ${window._histShowAll ? `▲ 收起（共 ${p.history.length} 筆）` : `▼ 顯示全部 ${p.history.length} 筆`}
    </button>`;
    _histListEl.appendChild(_moreBtn);
  }


  // ── 趨勢折線圖（可切換來源）──
  const trendEl = document.getElementById('prog-trend-chart');
  const trendNote = document.getElementById('prog-trend-note');
  // 注入趨勢圖 tab 切換（只做一次）
  if(trendEl && !trendEl.dataset.tabsInited) {
    trendEl.dataset.tabsInited = '1';
    const tabWrap = document.createElement('div');
    tabWrap.id = 'trend-tabs';
    tabWrap.style.cssText = 'display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;';
    [['all','全部'],['練習','歷屆練習'],['模擬考試','模擬考試'],['永續題庫','官方題庫'],['隨堂','隨堂練習']].forEach(([val,label])=>{
      const btn = document.createElement('button');
      btn.dataset.trendType = val;
      btn.textContent = label;
      // 計算該 type 的筆數
      const cnt = val === 'all' ? p.history.length : p.history.filter(h=>h.type===val).length;
      if(cnt > 0) btn.textContent = `${label} (${cnt})`;
      btn.style.cssText = `font-size:.72rem;padding:3px 10px;border-radius:20px;border:1.5px solid #ddd;
        background:${val==='all'?'#333':'#fff'};color:${val==='all'?'#fff':'#666'};cursor:pointer;`;
      btn.onclick = () => {
        document.querySelectorAll('#trend-tabs button').forEach(b=>{
          b.style.background='#fff'; b.style.color='#666'; b.style.borderColor='#ddd';
        });
        btn.style.background='#333'; btn.style.color='#fff'; btn.style.borderColor='#333';
        window._trendType = val;
        renderProgress();
      };
      tabWrap.appendChild(btn);
    });
    trendEl.parentNode.insertBefore(tabWrap, trendEl);
  }
  // 恢復 tab 視覺狀態，並更新筆數
  const _activeTrendType = window._trendType || 'all';
  document.querySelectorAll('#trend-tabs button').forEach(b => {
    const active = b.dataset.trendType === _activeTrendType;
    b.style.background = active ? '#333' : '#fff';
    b.style.color      = active ? '#fff' : '#666';
    b.style.borderColor= active ? '#333' : '#ddd';
    // 更新筆數標籤
    const _tval = b.dataset.trendType;
    const _tLabelMap = {all:'全部',練習:'歷屆練習',模擬考試:'模擬考試',永續題庫:'官方題庫',隨堂:'隨堂練習'};
    const _cnt = _tval === 'all' ? p.history.length : p.history.filter(h=>h.type===_tval).length;
    b.textContent = _cnt > 0 ? `${_tLabelMap[_tval]||_tval} (${_cnt})` : (_tLabelMap[_tval]||_tval);
  });
  if(trendEl){
    const allPts = p.history.slice().reverse();
    const pts = (_activeTrendType === 'all'
      ? allPts
      : allPts.filter(h => h.type === _activeTrendType)
    ).slice(-20);
    const typeLabel = _activeTrendType === 'all' ? '全部來源' : _activeTrendType === '永續題庫' ? '官方題庫' : _activeTrendType === '隨堂' ? '隨堂練習' : _activeTrendType;

    if(pts.length < 2){
      trendEl.innerHTML = '<p style="color:var(--gray);text-align:center;padding:40px 0;font-size:.85rem;">至少需要 2 次練習才能顯示趨勢</p>';
    } else if(_activeTrendType === '模擬考試') {
      // ── 模擬考試：章節分拆多條折線 ──
      const W=trendEl.offsetWidth||600, H=180, pad={t:16,b:28,l:36,r:60};
      const CH_COLORS_TREND = {ch1:'#89b4d4',ch2:'#8872b8',ch3:'#c87848',ch4:'#4a9480'};
      const CH_SHORT = {ch1:'第一章',ch2:'第二章',ch3:'第三章',ch4:'第四章'};

      // 收集各章的資料點（有 chStats 才算）
      const chSeries = {ch1:[],ch2:[],ch3:[],ch4:[]};
      pts.forEach((h, xi) => {
        if(!h.chStats) return;
        _CH_ORDER.forEach(ch => {
          const s = h.chStats[ch];
          if(s && s.total > 0) {
            chSeries[ch].push({xi, pct: Math.round(s.correct/s.total*100), date:h.date, correct:s.correct, total:s.total});
          }
        });
      });

      const allVals = [PASS_PCT, ...Object.values(chSeries).flat().map(d=>d.pct)];
      const minV = Math.max(0, Math.min(...allVals)-10);
      const maxV = Math.min(100, Math.max(...allVals)+10);
      const xScale = xi => pad.l + (xi/(pts.length-1))*(W-pad.l-pad.r);
      const yScale = v  => H-pad.b - (v-minV)/(maxV-minV)*(H-pad.t-pad.b);

      // Y 軸刻度
      const yTicks = [minV, Math.round((minV+maxV)/2), maxV].map(v=>`
        <line x1="${pad.l}" y1="${yScale(v).toFixed(1)}" x2="${W-pad.r}" y2="${yScale(v).toFixed(1)}" stroke="#f0f0f0" stroke-width="1"/>
        <text x="${pad.l-4}" y="${(yScale(v)+4).toFixed(1)}" text-anchor="end" font-size="9" fill="#aaa">${Math.round(v)}%</text>`).join('');

      // 及格線
      const passY = yScale(PASS_PCT).toFixed(1);
      const passLine = (PASS_PCT>=minV&&PASS_PCT<=maxV)
        ? `<line x1="${pad.l}" y1="${passY}" x2="${W-pad.r}" y2="${passY}" stroke="#888" stroke-width="1" stroke-dasharray="4,3" opacity=".4"/>
           <text x="${W-pad.r+2}" y="${(parseFloat(passY)+4).toFixed(1)}" font-size="8" fill="#888">及格</text>` : '';

      // X 軸日期標籤（最多顯示 5 個）
      const xLabels = pts.map((h, xi) => {
        if(pts.length <= 5 || xi === 0 || xi === pts.length-1 || xi % Math.ceil(pts.length/4) === 0) {
          return `<text x="${xScale(xi).toFixed(1)}" y="${H-pad.b+12}" text-anchor="middle" font-size="8" fill="#aaa">${h.date.slice(5)}</text>`;
        }
        return '';
      }).join('');

      // 各章折線 + 資料點
      const lines = _CH_ORDER.map(ch => {
        const series = chSeries[ch];
        if(series.length < 1) return '';
        const color = CH_COLORS_TREND[ch];
        const polyline = series.length >= 2
          ? `<polyline points="${series.map(d=>`${xScale(d.xi).toFixed(1)},${yScale(d.pct).toFixed(1)}`).join(' ')}"
              fill="none" stroke="${color}" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" stroke-dasharray="${ch==='ch3'?'5,3':ch==='ch4'?'none':'none'}"/>`
          : '';
        const dots = series.map(d => {
          const x=xScale(d.xi).toFixed(1), y=yScale(d.pct).toFixed(1);
          return `<circle cx="${x}" cy="${y}" r="4" fill="${color}" stroke="#fff" stroke-width="1.5">
            <title>${d.date} ${CH_SHORT[ch]}: ${d.pct}% (${d.correct}/${d.total})</title></circle>`;
        }).join('');
        return polyline + dots;
      }).join('');

      // 圖例（右側）
      const legend = _CH_ORDER.map((ch, li) => {
        const series = chSeries[ch];
        if(!series.length) return '';
        const lastPct = series[series.length-1].pct;
        const color = CH_COLORS_TREND[ch];
        return `<text x="${W-pad.r+6}" y="${pad.t + li*18}" font-size="9" fill="${color}" font-weight="600">
          ${CH_SHORT[ch]} ${lastPct}%</text>`;
      }).join('');

      trendEl.style.height = H + 'px';
      trendEl.innerHTML = `<svg width="100%" height="${H}" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none" style="overflow:visible;">
        ${yTicks}${passLine}${xLabels}${lines}${legend}
      </svg>`;
      if(trendNote) trendNote.textContent = `最近 ${pts.length} 次模擬考試・各章節正確率趨勢`;

    } else {
      // ── 其他來源：原有單條總正確率折線 ──
      const W=trendEl.offsetWidth||600, H=140, pad={t:16,b:28,l:36,r:16};
      trendEl.style.height = H + 'px';
      const vals = pts.map(h=>h.pct);
      const minV = Math.max(0,Math.min(...vals)-10), maxV = Math.min(100,Math.max(...vals)+10);
      const xScale = i => pad.l + (i/(pts.length-1))*(W-pad.l-pad.r);
      const yScale = v => H-pad.b - (v-minV)/(maxV-minV)*(H-pad.t-pad.b);
      const linePts = pts.map((h,i)=>`${xScale(i).toFixed(1)},${yScale(h.pct).toFixed(1)}`).join(' ');
      const fillPts = `${pad.l},${H-pad.b} ` + linePts + ` ${xScale(pts.length-1).toFixed(1)},${H-pad.b}`;
      const yTicks = [minV, Math.round((minV+maxV)/2), maxV].map(v=>`
        <line x1="${pad.l}" y1="${yScale(v).toFixed(1)}" x2="${W-pad.r}" y2="${yScale(v).toFixed(1)}" stroke="#f0f0f0" stroke-width="1"/>
        <text x="${pad.l-4}" y="${(yScale(v)+4).toFixed(1)}" text-anchor="end" font-size="9" fill="#aaa">${Math.round(v)}%</text>`).join('');
      const dots = pts.map((h,i)=>{
        const x=xScale(i).toFixed(1), y=yScale(h.pct).toFixed(1);
        const color = h.pct>=PASS_PCT?'#2e7a52':'#d04555';
        return `<circle cx="${x}" cy="${y}" r="4" fill="${color}" stroke="#fff" stroke-width="1.5">
          <title>${h.date} ${h.type}: ${h.pct}%</title></circle>`;
      }).join('');
      const passY = yScale(PASS_PCT).toFixed(1);
      const passLine = (PASS_PCT>=minV&&PASS_PCT<=maxV)
        ? `<line x1="${pad.l}" y1="${passY}" x2="${W-pad.r}" y2="${passY}" stroke="#2e7a52" stroke-width="1" stroke-dasharray="4,3" opacity=".5"/>
           <text x="${W-pad.r+2}" y="${(parseFloat(passY)+4).toFixed(1)}" font-size="8" fill="#2e7a52">及格</text>` : '';
      trendEl.innerHTML = `<svg width="100%" height="${H}" viewBox="0 0 ${W} ${H}" preserveAspectRatio="none" style="overflow:visible;">
        <defs><linearGradient id="tg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#2e7a52" stop-opacity=".2"/><stop offset="100%" stop-color="#2e7a52" stop-opacity="0"/></linearGradient></defs>
        ${yTicks}${passLine}
        <polygon points="${fillPts}" fill="url(#tg)"/>
        <polyline points="${linePts}" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
        ${dots}
      </svg>`;
      if(trendNote) trendNote.textContent = `最近 ${pts.length} 筆・${typeLabel}`;
    }
  }

  // ══ ★ 考點卡片進度 ══
  const conProgEl = document.getElementById('prog-concepts');
  if(conProgEl){
    let _viewed = [];
    try{ _viewed = JSON.parse(localStorage.getItem(CONCEPTS_VIEWED_KEY) || '[]'); }catch{}
    const total_c = CONCEPTS.length;
    const viewed_c = CONCEPTS.filter(c => _viewed.includes(c.topic)).length;
    const pct_c = Math.round(viewed_c / total_c * 100);
    const bar_c = pct_c >= 80 ? '#2e7a52' : pct_c >= 50 ? '#c8906a' : '#89b4d4';
    // 各章分布
    const CH_LIST = ['第一章','第二章','第三章','第四章'];
    const chRows = CH_LIST.map(ch => {
      const total_ch = CONCEPTS.filter(c => c.chapter === ch).length;
      const viewed_ch = CONCEPTS.filter(c => c.chapter === ch && _viewed.includes(c.topic)).length;
      if(!total_ch) return '';
      const pct_ch = Math.round(viewed_ch / total_ch * 100);
      const col_ch = pct_ch >= 80 ? '#2e7a52' : pct_ch >= 50 ? '#c8906a' : '#89b4d4';
      return `<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
        <span style="font-size:.75rem;color:#555;width:60px;flex-shrink:0;">${ch}</span>
        <div style="flex:1;height:7px;background:#f0f0f0;border-radius:99px;overflow:hidden;">
          <div style="height:100%;width:${pct_ch}%;background:${col_ch};border-radius:99px;transition:width .4s;"></div>
        </div>
        <span style="font-size:.72rem;font-weight:700;color:${col_ch};width:32px;text-align:right;">${pct_ch}%</span>
        <span style="font-size:.68rem;color:#aaa;width:40px;text-align:right;">${viewed_ch}/${total_ch}</span>
      </div>`;
    }).join('');
    conProgEl.innerHTML = `
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
        <div style="flex:1;">
          <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
            <span style="font-size:.8rem;font-weight:600;color:#333;">已瀏覽 ${viewed_c} / ${total_c} 張</span>
            <span style="font-size:.8rem;font-weight:800;color:${bar_c};">${pct_c}%</span>
          </div>
          <div style="height:10px;background:#f0f0f0;border-radius:99px;overflow:hidden;">
            <div style="height:100%;width:${pct_c}%;background:${bar_c};border-radius:99px;transition:width .4s;"></div>
          </div>
        </div>
      </div>
      ${chRows}
      ${viewed_c === 0 ? '<p style="font-size:.78rem;color:var(--gray);margin-top:4px;">前往考點頁展開卡片即可記錄瀏覽進度</p>' : ''}`;
  }


  // ══ ② 章節弱點分析 ══
  // _calcChStats/_calcSecStats 提升至外層，備考建議也需要用
  const _calcChStats = (typeFilter) => {
    const result = {};
    p.history.forEach(h => {
      if(typeFilter !== 'all' && h.type !== typeFilter) return;
      if(!h.chStats) return;
      Object.entries(h.chStats).forEach(([ch, s]) => {
        // 正規化 key：若不是 ch1~ch4，嘗試用 _E_TO_CH 轉換
        const normalKey = ['ch1','ch2','ch3','ch4'].includes(ch) ? ch : (_E_TO_CH[ch] || null);
        if(!normalKey) return; // 排除 'other' 及無法識別的 key
        if(!result[normalKey]) result[normalKey] = {correct:0, total:0};
        result[normalKey].correct += s.correct;
        result[normalKey].total   += s.total;
      });
    });
    return result;
  };
  const _calcSecStatsOuter = (typeFilter) => {
    const result = {};
    p.history.forEach(h => {
      if(typeFilter !== 'all' && h.type !== typeFilter) return;
      if(!h.secStats) return;
      Object.entries(h.secStats).forEach(([sec, s]) => {
        if(sec === 'other') return; // 排除無法識別的節次
        if(!result[sec]) result[sec] = {correct:0, total:0, ch: s.ch};
        result[sec].correct += s.correct;
        result[sec].total   += s.total;
      });
    });
    return result;
  };
  const chEl = document.getElementById('prog-ch-analysis');
  if(chEl){
    // 來源篩選狀態
    if(!window._chAnalysisType) window._chAnalysisType = 'all';

    // 注入篩選 chip（只做一次）
    if(!document.getElementById('ch-analysis-tabs')) {
      const chipWrap = document.createElement('div');
      chipWrap.id = 'ch-analysis-tabs';
      chipWrap.style.cssText = 'display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;';
      [['all','全部來源'],['練習','歷屆練習'],['模擬考試','模擬考試'],['永續題庫','官方題庫'],['隨堂','隨堂練習']].forEach(([val,label])=>{
        const chip = document.createElement('span');
        chip.dataset.chType = val;
        chip.style.cssText = `font-size:.7rem;padding:2px 10px;border-radius:20px;border:1.5px solid #ddd;
          background:${val==='all'?'#333':'#fff'};color:${val==='all'?'#fff':'#666'};cursor:pointer;`;
        chip.onclick = ()=>{
        if(window._chAnalysisType !== val){
          // 切換來源時重置節次展開狀態
          ['ch1','ch2','ch3','ch4'].forEach(ch => { window[`_chExpanded_${ch}`] = false; });
        }
        window._chAnalysisType=val; renderProgress();
      };
        chipWrap.appendChild(chip);
      });
      chEl.parentNode.insertBefore(chipWrap, chEl);
    }

    // 更新 chip 狀態與筆數
    const _actChType = window._chAnalysisType || 'all';
    document.querySelectorAll('#ch-analysis-tabs span').forEach(c => {
      const active = c.dataset.chType === _actChType;
      c.style.background = active ? '#333' : '#fff';
      c.style.color = active ? '#fff' : '#666';
      c.style.borderColor = active ? '#333' : '#ddd';
      const _cv = c.dataset.chType;
      const _cLabelMap = {all:'全部來源',練習:'歷屆練習',模擬考試:'模擬考試',永續題庫:'官方題庫',隨堂:'隨堂練習'};
      const _cCnt = _cv === 'all' ? p.history.length : p.history.filter(h=>h.type===_cv).length;
      c.textContent = _cCnt > 0 ? `${_cLabelMap[_cv]||_cv} (${_cCnt})` : (_cLabelMap[_cv]||_cv);
    });

    // 從 history 快照重新計算該來源的 chStats
    // _calcChStats 已提升至外層
    const chStats = _calcChStats(_actChType);
    const CH_LABELS = {ch1:'第一章 永續基本概念',ch2:'第二章 永續資訊揭露',ch3:'第三章 永續風險管理與治理',ch4:'第四章 永續金融'};
    const chOrder = ['ch1','ch2','ch3','ch4'];
    const hasData = chOrder.some(ch=>chStats[ch]&&chStats[ch].total>0);
    if(!hasData){
      chEl.innerHTML = '<p style="color:var(--gray);text-align:center;padding:20px;font-size:.85rem;">此來源尚無章節答題紀錄</p>';
    } else {
      chEl.innerHTML = chOrder.map(ch => {
        const s = chStats[ch] || {correct:0,total:0};
        if(!s.total) return '';
        const pct = Math.round(s.correct/s.total*100);
        const isWeak = pct < PASS_PCT;
        const bar_color = pct>=80?'#2e7a52':pct>=PASS_PCT?'#c8906a':'#d04555';

        // 計算該來源該章的節次統計
        const _calcSecStatsForCh = (typeFilter, ch) => {
          const result = {};
          p.history.forEach(h => {
            if(typeFilter !== 'all' && h.type !== typeFilter) return;
            if(!h.secStats) return;
            Object.entries(h.secStats).forEach(([sec, sv]) => {
              if((sv.ch || _SEC_TO_CH[sec]) !== ch) return;
              if(!result[sec]) result[sec] = {correct:0, total:0};
              result[sec].correct += sv.correct;
              result[sec].total   += sv.total;
            });
          });
          return result;
        };
        const secData = _calcSecStatsForCh(_actChType, ch);
        const secRows = _SEC_ORDER
          .filter(sec => _SEC_TO_CH[sec] === ch && secData[sec]?.total > 0)
          .map(sec => {
            const sv = secData[sec];
            const sPct = Math.round(sv.correct/sv.total*100);
            const sCol = sPct>=80?'#2e7a52':sPct>=PASS_PCT?'#c8906a':'#d04555';
            return `<div style="display:flex;align-items:center;gap:6px;padding:4px 0 4px 10px;border-left:2px solid #eee;">
              <span style="font-size:.72rem;color:#666;flex:1;">${sec}</span>
              <div style="width:60px;height:5px;background:#f0f0f0;border-radius:99px;overflow:hidden;flex-shrink:0;">
                <div style="height:100%;width:${sPct}%;background:${sCol};border-radius:99px;"></div>
              </div>
              <span style="font-size:.7rem;font-weight:700;color:${sCol};width:36px;text-align:right;">${sPct}%</span>
              <span style="font-size:.68rem;color:#aaa;width:36px;text-align:right;">${sv.correct}/${sv.total}</span>
            </div>`;
          }).join('');

        const expandKey = `_chExpanded_${ch}`;
        const isExpanded = !!window[expandKey];
        const hasSecData = secRows.length > 0;

        return `<div style="margin-bottom:12px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
            <span style="font-size:.82rem;font-weight:600;color:${isWeak?'#c62828':'#333'};">
              ${isWeak?'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg> ':'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> '}${CH_LABELS[ch]||ch}
            </span>
            <div style="display:flex;align-items:center;gap:8px;">
              <span style="font-size:.8rem;font-weight:800;color:${bar_color};">${pct}% (${s.correct}/${s.total})</span>
              ${hasSecData ? `<span onclick="window['${expandKey}']=!window['${expandKey}'];renderProgress();"
                style="font-size:.68rem;color:#aaa;cursor:pointer;padding:1px 6px;border:1px solid #e0e0e0;border-radius:10px;">${isExpanded?'▲收':('▼節')}</span>` : ''}
            </div>
          </div>
          <div style="height:10px;background:#f0f0f0;border-radius:99px;overflow:hidden;">
            <div style="height:100%;width:${pct}%;background:${bar_color};border-radius:99px;transition:width .4s;"></div>
          </div>
          ${isExpanded && hasSecData ? `<div style="margin-top:6px;">${secRows}</div>` : ''}
        </div>`;
      }).join('');
    }
  }

// ══ ★ 備考建議 ══
  const adviceEl = document.getElementById('prog-advice');
  if(adviceEl){
    // _calcChStats/_calcSecStatsOuter 已提升至外層
    const _advChStats  = _calcChStats('all');
    const _advSecStats = _calcSecStatsOuter('all');
    const _CH_LABELS_A = {ch1:'第一章',ch2:'第二章',ch3:'第三章',ch4:'第四章'};

    // 找最弱章（至少10題）
    const weakChs = ['ch1','ch2','ch3','ch4']
      .filter(ch => _advChStats[ch]?.total >= 10)
      .sort((a,b) => {
        const pa = Math.round(_advChStats[a].correct/_advChStats[a].total*100);
        const pb = Math.round(_advChStats[b].correct/_advChStats[b].total*100);
        return pa - pb;
      });

    // 找最弱節（至少3題）
    const weakSecs = Object.entries(_advSecStats)
      .filter(([,s]) => s.total >= 3)
      .sort((a,b) => {
        const pa = Math.round(a[1].correct/a[1].total*100);
        const pb = Math.round(b[1].correct/b[1].total*100);
        return pa - pb;
      });

    // 考點卡片未看完（不論有無答題資料都要顯示）
    let _viewedA = [];
    try{ _viewedA = JSON.parse(localStorage.getItem(CONCEPTS_VIEWED_KEY) || '[]'); }catch{}
    const unviewedCnt = CONCEPTS.length - CONCEPTS.filter(c => _viewedA.includes(c.topic)).length;

    if(weakChs.length === 0 && weakSecs.length === 0){
      // 沒有足夠答題資料，只顯示考點卡片提示（如果有的話）
      if(unviewedCnt > 0){
        adviceEl.innerHTML = `<div style="background:#e8f2f9;border-left:3px solid #42a5f5;border-radius:0 8px 8px 0;padding:10px 14px;margin-bottom:8px;">
          <div style="font-size:.8rem;font-weight:600;color:#333;margin-bottom:2px;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#89b4d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg> 尚有 ${unviewedCnt} 張考點卡片未瀏覽</div>
          <div style="font-size:.74rem;color:#666;">前往考點頁逐一展開複習</div>
        </div>
        <p style="color:var(--gray);font-size:.78rem;margin-top:6px;">完成更多練習後將自動產生章節建議</p>`;
      } else {
        adviceEl.innerHTML = '<p style="color:var(--gray);font-size:.82rem;padding:8px 0;">完成更多練習後將自動產生個人化備考建議</p>';
      }
    } else {
      const tips = [];

      // 最弱章建議
      const weakestCh = weakChs.length > 0 ? weakChs[0] : null;
      if(weakestCh){
        const wpct = Math.round(_advChStats[weakestCh].correct/_advChStats[weakestCh].total*100);
        tips.push({
          level: wpct < PASS_PCT ? 'urgent' : 'normal',
          text: `${_CH_LABELS_A[weakestCh]}正確率僅 ${wpct}%，建議優先加強`,
          action: `多做${_CH_LABELS_A[weakestCh]}題目，或複習對應考點卡片`,
        });
      }

      // 最弱節建議（前3名，排除最弱章內的節次，避免重複）
      weakSecs
        .filter(([sec, s]) => !weakestCh || s.ch !== weakestCh)
        .slice(0, 3)
        .forEach(([sec, s]) => {
          const spct = Math.round(s.correct/s.total*100);
          if(spct < 70){
            tips.push({
              level: spct < PASS_PCT ? 'urgent' : 'normal',
              text: `「${sec}」答對率 ${spct}%（${s.correct}/${s.total} 題）`,
              action: '建議重點複習此節考點',
            });
          }
        });

      // 考點卡片未看完提示
      if(unviewedCnt > 0){
        tips.push({
          level: 'info',
          text: `尚有 ${unviewedCnt} 張考點卡片未瀏覽`,
          action: '前往考點頁逐一展開複習',
        });
      }

      const tipColors = {urgent:{bg:'#ffebee',border:'#d45060',icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#d45060" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>'}, normal:{bg:'#fdf4e3',border:'#ffc107',icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>'}, info:{bg:'#e8f2f9',border:'#42a5f5',icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#89b4d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>'}};
      adviceEl.innerHTML = tips.length
        ? tips.map(t => {
            const tc = tipColors[t.level];
            return `<div style="background:${tc.bg};border-left:3px solid ${tc.border};border-radius:0 8px 8px 0;
              padding:10px 14px;margin-bottom:8px;">
              <div style="font-size:.8rem;font-weight:600;color:#333;margin-bottom:2px;">${tc.icon} ${t.text}</div>
              <div style="font-size:.74rem;color:#666;">${t.action}</div>
            </div>`;
          }).join('')
        : '<p style="color:var(--gray);font-size:.82rem;padding:8px 0;">目前各章節表現良好，繼續保持！</p>';
    }
  }

// ══ ③ 成就徽章 ══
  const badgesEl = document.getElementById('prog-badges');
  if(badgesEl){
    const BADGES = [
      { id:'first',    icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M5.8 11.3L2 22l10.7-3.79"/><path d="M4 3h.01"/><path d="M22 8h.01"/><path d="M15 2h.01"/><path d="M22 20h.01"/><path d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12v0c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10"/><path d="m22 13-.82-.33c-.86-.34-1.82.2-1.98 1.11v0c-.19 1.07-1.1 1.86-2.2 1.86H17"/><path d="m11 2 1.27 2.89A2 2 0 0 0 14.12 6M5 6l-1 4"/></svg>', name:'初試啼聲',   desc:'完成第一次練習（任一題庫）',      check:()=>sessions>=1 },
      { id:'ten',      icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/></svg>', name:'十戰老將',   desc:'各題庫累計練習 10 次',            check:()=>sessions>=10 },
      { id:'hundred',  icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polyline points="20 6 9 17 4 12"/><circle cx="12" cy="12" r="10"/></svg>', name:'百題勇士',   desc:'累計作答 100 題（含所有來源）',   check:()=>total>=100 },
      { id:'thousand', icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#d4a56a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg>', name:'千題達人',   desc:'累計作答 1000 題（含所有來源）',  check:()=>total>=1000 },
      { id:'pass',     icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>', name:'初次及格',   desc:'第一次模擬考試及格',              check:()=>_exam.some(h=>h.pct>=PASS_PCT) },
      { id:'streak3',  icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>', name:'連勝三場',   desc:'模擬考試連續 3 次及格',           check:()=>{ const r=_exam.slice(0,3); return r.length>=3&&r.every(h=>h.pct>=PASS_PCT); } },
      { id:'perfect',  icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="#d4a56a" stroke="none" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>', name:'完美表現',   desc:'模擬考試正確率達 90%',            check:()=>_exam.some(h=>h.pct>=90) },
      { id:'allch',    icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#89b4d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>', name:'全章制霸',   desc:'四章均有答題紀錄（任一來源）',    check:()=>['ch1','ch2','ch3','ch4'].every(ch=>(p.chStats||{})[ch]?.total>0) },
      { id:'improve',  icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>', name:'持續進步',   desc:'模擬考試最近 3 次正確率逐次上升', check:()=>{ const r=_exam.slice(0,3); return r.length>=3&&r[0].pct>r[1].pct&&r[1].pct>r[2].pct; } },
      { id:'expert',   icon:'<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#8872b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>', name:'永續達人',   desc:'模擬考試正確率達 85%',            check:()=>_exam.some(h=>h.pct>=85) },
    ];
    badgesEl.innerHTML = BADGES.map(b => {
      const unlocked = b.check();
      return `<div style="display:flex;flex-direction:column;align-items:center;gap:4px;
        padding:12px 10px;border-radius:12px;min-width:80px;text-align:center;
        background:${unlocked?'#e2f5ec':'#f5f5f5'};
        border:2px solid ${unlocked?'#3fa068':'#e0e0e0'};
        opacity:${unlocked?'1':'.45'};transition:all .2s;"
        title="${b.desc}">
        <span style="font-size:1.6rem;filter:${unlocked?'none':'grayscale(1)'};">${b.icon}</span>
        <span style="font-size:.72rem;font-weight:700;color:${unlocked?'#1b5c42':'#999'};">${b.name}</span>
        <span style="font-size:.64rem;color:${unlocked?'#3fa068':'#bbb'};">${unlocked?'已解鎖':'???'}</span>
      </div>`;
    }).join('');
  }
  // ══ 歷屆考題章節占比分析 ══
  const examAnaEl = document.getElementById('prog-exam-analysis');
  if(examAnaEl){
    const CH_LABELS = {ch1:'第一章 永續基本概念',ch2:'第二章 永續資訊揭露',ch3:'第三章 風險管理',ch4:'第四章 永續金融'};
    const CH_COLORS = {ch1:'#89b4d4',ch2:'#8872b8',ch3:'#c87848',ch4:'#4a9480'};
    const CH_BG    = {ch1:'#e8f2f9',ch2:'#ede8f7',ch3:'#fdf0e0',ch4:'#e0f2f1'};

    // 彙整各年次資料
    const examMap = {};
    Q.forEach(q => {
      if(!examMap[q.e]) examMap[q.e] = {ch1:0,ch2:0,ch3:0,ch4:0,total:0};
      examMap[q.e][q.ch] = (examMap[q.e][q.ch]||0) + 1;
      examMap[q.e].total++;
    });
    const exams = Object.keys(examMap).sort();
    const chs = ['ch1','ch2','ch3','ch4'];

    // 整體統計
    const overall = {ch1:0,ch2:0,ch3:0,ch4:0,total:Q.length};
    Q.forEach(q=>{ if(overall[q.ch]!==undefined) overall[q.ch]++; });

    // ① 整體占比卡片
    const overallHtml = `
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px;">
        ${chs.map(ch => {
          const n = overall[ch], pct = Math.round(n/overall.total*100);
          return `<div style="background:${CH_BG[ch]};border:1.5px solid ${CH_COLORS[ch]}44;
            border-radius:10px;padding:10px 8px;text-align:center;">
            <div style="font-size:.78rem;color:${CH_COLORS[ch]};font-weight:700;margin-bottom:4px;">${CH_LABELS[ch].split(' ')[0]}</div>
            <div style="font-size:1.3rem;font-weight:900;color:${CH_COLORS[ch]};">${pct}%</div>
            <div style="font-size:.7rem;color:#666;margin-top:2px;">${n} 題</div>
          </div>`;
        }).join('')}
      </div>
      <div style="font-size:.75rem;color:var(--gray);margin-bottom:14px;padding:8px 12px;
        background:#fdf4e3;border-radius:8px;border-left:3px solid #ffc107;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg> <strong>規律：</strong>第二章最多（約 30-36%），第三章最少（約 9-16%）。備考時建議以出題量為優先。
      </div>`;

    // ② 各年次堆疊橫條圖（%數 + 題數雙行）
    const rowsHtml = exams.map(e => {
      const r = examMap[e];
      const bar = chs.map(ch => {
        const n = r[ch]||0;
        const pct = n/r.total*100;
        if(!n) return '';
        const wide = true; // 全部都顯示
        return `<div style="width:${pct.toFixed(1)}%;background:${CH_COLORS[ch]};
          display:flex;flex-direction:column;align-items:center;justify-content:center;
          overflow:hidden;flex-shrink:0;gap:1px;"
          title="${CH_LABELS[ch]}: ${n}題 (${pct.toFixed(0)}%)">
          ${wide ? `<span style="font-size:.7rem;color:#fff;font-weight:800;line-height:1;">${pct.toFixed(0)}%</span>
                    <span style="font-size:.62rem;color:rgba(255,255,255,.82);line-height:1;">${n}題</span>` : ''}
        </div>`;
      }).join('');
      return `<div style="display:flex;align-items:center;gap:8px;margin-bottom:7px;">
        <span style="font-size:.75rem;color:#555;width:68px;flex-shrink:0;text-align:right;font-weight:600;">${e}</span>
        <div style="flex:1;height:36px;display:flex;border-radius:7px;overflow:hidden;
          border:1px solid #ddd;box-shadow:0 1px 3px rgba(0,0,0,.07);">
          ${bar}
        </div>
      </div>`;
    }).join('');

    // ③ 圖例
    const legendHtml = `<div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:12px;">
      ${chs.map(ch=>`<div style="display:flex;align-items:center;gap:4px;">
        <div style="width:12px;height:12px;border-radius:3px;background:${CH_COLORS[ch]};flex-shrink:0;"></div>
        <span style="font-size:.72rem;color:#555;">${CH_LABELS[ch]}</span>
      </div>`).join('')}
    </div>`;

    // ④ 開合狀態（預設收合，列表較長）
    if(window._yearDistOpen === undefined) window._yearDistOpen = false;
    const isOpen = window._yearDistOpen;

    // ── 左側精緻表格圖示 SVG ──
    const tableIconSvg = `<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#4a6fa5" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
      <rect x="2.5" y="2.5" width="19" height="19" rx="3.5"/>
      <line x1="2.5" y1="8.5" x2="21.5" y2="8.5"/>
      <line x1="2.5" y1="15.5" x2="21.5" y2="15.5"/>
      <line x1="8.5" y1="8.5" x2="8.5" y2="21.5"/>
    </svg>`;

    // ── 右側 chevron 圖示（帶圓底板）──
    // 展開時箭頭朝上（表示可收合），收合時箭頭朝下（表示可展開）
    const chevronIconSvg = `<svg id="year-dist-chevron" viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg"
      style="flex-shrink:0;transition:transform .35s cubic-bezier(.4,0,.2,1);transform:rotate(${isOpen?'0':'180deg'});">
      <circle cx="12" cy="12" r="10" fill="#4a6fa5" fill-opacity=".1" stroke="#4a6fa5" stroke-opacity=".4" stroke-width="1.4"/>
      <polyline points="7.5 13.5 12 8.5 16.5 13.5" stroke="#4a6fa5" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`;

    // ── Toggle 點擊處理（不 re-render，用 DOM 直接動畫）──
    const toggleFn = `(function(){
      window._yearDistOpen = !window._yearDistOpen;
      const open = window._yearDistOpen;
      const body = document.getElementById('year-dist-body');
      const chevron = document.getElementById('year-dist-chevron');
      const hdr = document.getElementById('year-dist-hdr');
      const lbl = document.getElementById('year-dist-lbl');
      if(body){
        if(open){
          body.style.maxHeight = body.scrollHeight + 200 + 'px';
          body.style.opacity = '1';
          body.style.pointerEvents = '';
        } else {
          body.style.maxHeight = '0px';
          body.style.opacity = '0';
          body.style.pointerEvents = 'none';
        }
      }
      if(chevron) chevron.style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)';
      if(hdr){
        hdr.style.borderRadius = open ? '10px 10px 0 0' : '10px';
        hdr.style.background = open ? '#eef3fb' : '#f7f8fa';
        hdr.style.borderColor = open ? '#b8cde8' : '#dde3ec';
      }
      if(lbl) lbl.textContent = open ? '收合' : '展開';
    })()`;

    const yearDistHeaderHtml = `
      <div id="year-dist-hdr" onclick="${toggleFn}"
        style="display:flex;align-items:center;justify-content:space-between;
          cursor:pointer;padding:11px 15px;
          background:${isOpen?'#eef3fb':'#f7f8fa'};
          border-radius:${isOpen?'10px 10px 0 0':'10px'};
          border:1.5px solid ${isOpen?'#b8cde8':'#dde3ec'};
          transition:background .2s,border-radius .2s,border-color .2s;
          user-select:none;-webkit-user-select:none;">
        <div style="display:flex;align-items:center;gap:8px;">
          ${tableIconSvg}
          <span style="font-size:.84rem;font-weight:700;color:#2d4a6e;letter-spacing:.01em;">各年次章節分布</span>
          <span style="font-size:.68rem;color:#5878a8;background:#dce8f6;padding:2px 8px;border-radius:10px;font-weight:600;line-height:1.4;">${exams.length} 個年次</span>
        </div>
        <div style="display:flex;align-items:center;gap:6px;">
          <span id="year-dist-lbl" style="font-size:.68rem;color:#7a90b0;font-weight:500;">${isOpen?'收合':'展開'}</span>
          ${chevronIconSvg}
        </div>
      </div>`;

    // body 用 max-height 動畫（CSS transition），預設收合
    const yearDistBodyHtml = `
      <div id="year-dist-body"
        style="border:1.5px solid #b8cde8;border-top:none;border-radius:0 0 10px 10px;
          background:#fff;overflow:hidden;
          max-height:${isOpen?'3000px':'0px'};
          opacity:${isOpen?'1':'0'};
          pointer-events:${isOpen?'':'none'};
          transition:max-height .42s cubic-bezier(.4,0,.2,1), opacity .3s ease;">
        <div style="padding:14px 14px 10px;">
          ${rowsHtml}
          ${legendHtml}
        </div>
      </div>`;

    examAnaEl.innerHTML = overallHtml + yearDistHeaderHtml + yearDistBodyHtml;
  }

}

function clearProgress(){
  if(confirm('確定要清除所有練習紀錄嗎？')){
    try{ localStorage.removeItem(STORE_KEY); }catch(e){}
    renderProgress();
    showToast('進度已清除');
  }
}

// ════════════════════════════════════════════════
//  TEXTBOOK QUIZ
// ════════════════════════════════════════════════
let tbQuestions=[], tbIdx=0, tbCorrect=0, tbAnswered=[];

function _getTbPool(){
  const filter = document.getElementById('tb-chapter-filter').value;
  return filter === FILTER_ALL ? [...TEXTBOOK_Q] : TEXTBOOK_Q.filter(q => q.e === filter);
}

function initTextbook(){
  document.getElementById('tb-count-label').textContent = `共 ${_getTbPool().length} 題`;
}

function startTextbook(){
  const order = document.getElementById('tb-order').value;
  let pool    = _getTbPool();
  if(order === 'rand') pool = shuffle(pool);
  tbQuestions = pool;
  tbIdx=0; tbCorrect=0;
  tbAnswered = new Array(pool.length).fill(null);
  document.getElementById('tb-quiz-area').style.display = 'block';
  document.getElementById('tb-result').style.display    = 'none';
  renderTbQ();
}

function renderTbQ(){
  if(!tbQuestions.length) return;
  const q       = tbQuestions[tbIdx];
  const total   = tbQuestions.length;
  const pct     = Math.round(tbIdx / total * 100);
  document.getElementById('tb-prog-text').textContent  = `第 ${tbIdx+1} / ${total} 題`;
  document.getElementById('tb-score-text').textContent = `答對 ${tbCorrect} 題`;
  document.getElementById('tb-prog-bar').style.width   = pct + '%';
  const _depBanner = document.getElementById('tb-dep-banner');
  if(_depBanner) _depBanner.style.display = q.deprecated ? 'flex' : 'none';
  // 題目使用 textContent 防 XSS
  document.getElementById('tb-stem').textContent = q.s;
  const answered = tbAnswered[tbIdx];
  const labels   = ['(1)','(2)','(3)','(4)'];
  document.getElementById('tb-opts').innerHTML = q.o.map((opt, i) => {
    let cls = 'tb-opt';
    if(answered !== null){
      if(i === q.a)           cls += ' correct';
      else if(i === answered) cls += ' wrong';
    } else if(tbPending === i){
      cls += ' pending'; // 暫選狀態
    }
    return `<button type="button" class="${cls}" ${answered!==null?'disabled':''} onclick="tbAnswer(${i})">${labels[i]} ${_safeText(opt)}</button>`;
  }).join('');
  // 確認按鈕區
  const confirmArea = document.getElementById('tb-confirm-area');
  if(confirmArea){
    if(answered === null && tbPending !== null){
      confirmArea.innerHTML =
        `<div class="confirm-row">
          <button type="button" class="btn-confirm-ans" onclick="tbConfirm()"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> 確認答案</button>
          <button type="button" class="btn-change-ans"  onclick="tbClearPending()">↩ 重新選擇</button>
        </div>`;
    } else {
      confirmArea.innerHTML = '';
    }
  }
  const expEl = document.getElementById('tb-explanation');
  expEl.className = 'tb-explanation' + (answered !== null ? ' show' : '');
  if(answered !== null){
    const tbCorrectFlag = (answered === q.a);
    let tbExpHtml = '';
    if(!tbCorrectFlag){
      tbExpHtml += `<div style="color:var(--color-danger);margin-bottom:4px;"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c62828" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> 你的答案：${labels[answered]} ${_safeText(q.o[answered])}</div>`;
    }
    tbExpHtml += `<b style="color:var(--color-success)"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#2e7a52" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> 正確答案：</b>${labels[q.a]} ${_safeText(q.o[q.a])}`;
    tbExpHtml += q.x ? `<br><b>【解析】</b>${_safeTextNL(q.x)}` : '';
    tbExpHtml += _relatedCourseBtn(q);
    tbExpHtml += typeof _textbookBtn==='function' ? _textbookBtn(q) : '';

    expEl.innerHTML = tbExpHtml;
  } else {
    expEl.innerHTML = '';
  }
  document.getElementById('tb-prev-btn').style.display = tbIdx > 0 ? '' : 'none';
  const nextBtn = document.getElementById('tb-next-btn');
  nextBtn.style.display = answered !== null ? '' : 'none';
  nextBtn.textContent   = tbIdx < tbQuestions.length-1 ? '下一題 →' : '查看結果';
}

let tbPending = null; // 暫選答案（尚未確認）

function tbAnswer(i){
  if(tbAnswered[tbIdx] !== null) return; // 已確認，不能改
  tbPending = i;
  renderTbQ(); // 重渲染顯示暫選狀態 + 確認按鈕
}
function tbConfirm(){
  if(tbPending === null || tbAnswered[tbIdx] !== null) return;
  tbAnswered[tbIdx] = tbPending;
  if(tbPending === tbQuestions[tbIdx].a && !tbQuestions[tbIdx].deprecated) tbCorrect++;
  tbPending = null;
  renderTbQ();
}
function tbClearPending(){
  tbPending = null;
  renderTbQ();
}
function tbNext(){ if(tbIdx < tbQuestions.length-1){ tbIdx++; renderTbQ(); } else showTbResult(); }
function tbPrev(){ if(tbIdx > 0){ tbIdx--; renderTbQ(); } }

function showTbResult(){
  document.getElementById('tb-quiz-area').style.display = 'none';
  document.getElementById('tb-result').style.display    = 'block';
  const _activeQs = tbQuestions.filter(q => !q.deprecated);
  const total   = _activeQs.length;
  const pct     = total > 0 ? Math.round(tbCorrect / total * 100) : 0;
  const skipped = tbAnswered.filter((a,i) => a === null && !tbQuestions[i].deprecated).length;
  const wrong   = total - tbCorrect - skipped;
  document.getElementById('tb-final-score').textContent = pct + '%';
  document.getElementById('tb-final-title').innerHTML =
    pct >= PASS_PCT ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M5.8 11.3L2 22l10.7-3.79"/><path d="M4 3h.01"/><path d="M22 8h.01"/><path d="M15 2h.01"/><path d="M22 20h.01"/><path d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12v0c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10"/><path d="m22 13-.82-.33c-.86-.34-1.82.2-1.98 1.11v0c-.19 1.07-1.1 1.86-2.2 1.86H17"/><path d="m11 2 1.27 2.89A2 2 0 0 0 14.12 6M5 6l-1 4"/></svg> 表現優秀！' : pct >= 60 ? '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg> 繼續加油！' : '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="#c88a50" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg> 多練幾次！';
  document.getElementById('tb-stat-correct').textContent = tbCorrect;
  document.getElementById('tb-stat-wrong').textContent   = wrong;
  const skipEl = document.getElementById('tb-stat-skip');
  if(skipEl) skipEl.textContent = skipped;
  document.getElementById('tb-stat-total').textContent = total;
  const _depNote = document.getElementById('tb-dep-note');
  if(_depNote){ const _d=tbQuestions.filter(q=>q.deprecated).length; _depNote.style.display=_d>0?'block':'none'; _depNote.textContent=`※ 共 ${_d} 題已停用（114年官方勘誤），已排除於統計之外。`; }
  const p = loadProgress();
  // 累計章節弱點統計
  const _tbChStats = {}, _tbSecStats = {};
  tbQuestions.forEach((q, i) => {
    if(q.deprecated) return;
    const ch  = _E_TO_CH[q.e] || _E_TO_CH[q.chapter] || 'other';
    const sec = q.section || 'other';
    const hit = tbAnswered[i] === q.a;
    if(!_tbChStats[ch])  _tbChStats[ch]  = {correct:0, total:0};
    if(!_tbSecStats[sec]) _tbSecStats[sec] = {correct:0, total:0, ch};
    _tbChStats[ch].total++;   if(hit) _tbChStats[ch].correct++;
    _tbSecStats[sec].total++; if(hit) _tbSecStats[sec].correct++;
  });
  p.history.unshift({date:new Date().toLocaleDateString('zh-TW'),type:'永續題庫',total,correct:tbCorrect,pct,chStats:_tbChStats,secStats:_tbSecStats});
  if(!p.chStats) p.chStats = {};
  Object.entries(_tbChStats).forEach(([ch,s]) => {
    if(!p.chStats[ch]) p.chStats[ch] = {correct:0, total:0};
    p.chStats[ch].correct += s.correct;
    p.chStats[ch].total   += s.total;
  });
  if(!p.secStats) p.secStats = {};
  Object.entries(_tbSecStats).forEach(([sec,s]) => {
    if(!p.secStats[sec]) p.secStats[sec] = {correct:0,total:0,ch:s.ch};
    p.secStats[sec].correct += s.correct;
    p.secStats[sec].total   += s.total;
  });
  saveProgress(p);
}

