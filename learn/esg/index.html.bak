// -- textbook2 functions --
var SECTION_ANCHOR = {
  '第一節 永續介紹與發展目標': 'ch1-s1',
  '第二節 永續發展目標': 'ch1-s2',
  '第三節 國內永續發展政策': 'ch1-s3',
  '第四節 國際永續發展政策': 'ch1-s4'
};

let _txLoaded = [false, false, false, false];
// ── TX_CHAPTERS 懶載入管理 ──────────────────────────────────
const _txChapterCache = {};
function _loadTxChapter(ci) {
  return new Promise((resolve) => {
    if (_txChapterCache[ci] !== undefined) { resolve(_txChapterCache[ci]); return; }
    const s = document.createElement('script');
    s.src = `textbook/ch${ci + 1}.js`;
    s.onload = () => resolve(_txChapterCache[ci]);
    s.onerror = () => { console.error('Failed to load textbook/ch' + (ci+1) + '.js'); resolve(''); };
    document.head.appendChild(s);
  });
}

// ── 清理課文段落標籤（主題/內容、風險類別/說明 等多餘標籤）──
function _cleanTxLabels(container) {
  const paras = Array.from(container.querySelectorAll('p.tx-p'));
  for (let i = 0; i < paras.length; i++) {
    const p = paras[i];
    if (!p.parentNode) continue;
    const fc = p.firstElementChild;
    // 只處理第一個子元素是 <strong> 的段落
    if (!fc || fc.tagName !== 'STRONG') continue;
    // 計算 strong 標籤後冒號之後的實際內文長度
    const fullText = p.textContent;
    const afterColon = fullText.slice(fc.textContent.length).replace(/^[\uff1a:\s]+/, '');
    if (afterColon.length < 35) {
      // 獨立標籤段落（內文極短）→ 移除，並剝除下一段的標籤前綴
      const nextP = paras[i + 1];
      p.remove();
      if (nextP && nextP.parentNode) {
        nextP.innerHTML = nextP.innerHTML.replace(/^<strong[^>]*>[^<]*<\/strong>[\uff1a:]\s*/i, '');
      }
    } else {
      // 有實質內文 → 將 strong 標籤加上 pill 樣式
      fc.classList.add('tx-p-label');
    }
  }
}

async function _txEnsureChapter(ci) {
  if(_txLoaded[ci]) return;
  _txLoaded[ci] = true;
  const container = document.getElementById('tx-lazy-content');
  if(!container) return;
  const html = await _loadTxChapter(ci);
  const div = document.createElement('div');
  div.id = 'tx-ch-' + (ci+1);
  div.innerHTML = html || '';
  _cleanTxLabels(div); // 清理多餘段落標籤
  container.appendChild(div);
  // 重新初始化這章的 Chart
  setTimeout(_initSectionCharts, 50);
}

async function _txLoadAll() {
  for(let i=0;i<4;i++) await _txEnsureChapter(i);
}

// 覆寫 txScrollTo 確保目標章節已載入
const _origTxScrollTo = null;
function txScrollTo(anchor) {
  // 載入對應章節（前面章節全部先載入以確保錨點佔位）
  const ci = anchor.startsWith('ch1') ? 0
           : anchor.startsWith('ch2') ? 1
           : anchor.startsWith('ch3') ? 2
           : anchor.startsWith('ch4') ? 3 : -1;
  if(ci >= 0) {
    for(let i=0; i<=ci; i++) _txEnsureChapter(i);
  }
  // 雙層 rAF：確保 browser layout 完成後再計算位置
  requestAnimationFrame(function(){
    requestAnimationFrame(function(){
    const el   = document.getElementById(anchor);
    const body = document.getElementById('tx-body');
    if(el && body) {
      const off = el.getBoundingClientRect().top - body.getBoundingClientRect().top + body.scrollTop;
      body.scrollTo({top: Math.max(0, off - 16), behavior: 'smooth'});
    } else if(el) {
      el.scrollIntoView({behavior:'smooth', block:'start'});
    }
    // TOC active 狀態
    document.querySelectorAll('.tx-toc-item,.tx-toc-sub').forEach(n => n.classList.remove('tx-active'));
    const activeLink = document.querySelector(`.tx-toc-item[onclick*="${anchor}"],.tx-toc-sub[onclick*="${anchor}"]`);
    if(activeLink) activeLink.classList.add('tx-active');
    // 手機版：點擊後收起 TOC
    if(window.innerWidth <= 768) document.getElementById('tx-toc')?.classList.remove('toc-open');
    });
  });
}

function toggleTxToc(){
  if(window.innerWidth > 768) return;
  document.getElementById('tx-toc').classList.toggle('toc-open');
}
function goTextbook(anchor){
  goPage('textbook2');
  if(anchor) setTimeout(function(){txScrollTo(anchor);}, 120);
}
function _textbookBtn(q){
  if(!q||!q.section)return '';
  var anc=(SECTION_ANCHOR[q.section])||'ch1-s1';
  return '<button type="button" class="related-course-btn" '
    + 'style="background:#e2f5ec;color:#2e7a52;border-color:#b8e4d0;margin-top:4px;" '
    + 'onclick="_captureAndGo(function(){goTextbook(\'' + anc + '\')})"'
    + '><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;flex-shrink:0;" ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg> 查看永續課文</button>';
}







// P2: resize 自動關閉 sidebar
window.addEventListener('resize', function(){
  if(window.innerWidth > 1024 && document.getElementById('sidebar').classList.contains('open')){
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('overlay').classList.remove('show');
  }
});

// 完整課文捲動進度條 + 章節 pill 高亮
document.getElementById('tx-body') && document.getElementById('tx-body').addEventListener('scroll', function(){
  var el   = this;
  var prog = document.getElementById('tx-prog');
  var lbl  = document.getElementById('tx-prog-pct');
  if(!prog) return;
  var pct = Math.min(100, el.scrollTop / (el.scrollHeight - el.clientHeight) * 100);
  prog.style.width = pct.toFixed(1) + '%';
  if(lbl) lbl.textContent = Math.round(pct) + '%';

  // 判斷目前在哪一章（找最近的章首標題）
  var chapterEls = el.querySelectorAll('[id^="tx-ch-"]');
  var activeIdx = 0;
  chapterEls.forEach(function(ch, i){
    if(ch.getBoundingClientRect().top <= el.getBoundingClientRect().top + 60) activeIdx = i;
  });
  document.querySelectorAll('.tx-ch-pill').forEach(function(p, i){
    p.classList.toggle('active', i === activeIdx);
  });
});

// 回到頂部按鈕顯示控制
document.getElementById('tx-body') && document.getElementById('tx-body').addEventListener('scroll', function(){
  var btn = document.getElementById('tx-back-top');
  if(btn) btn.classList.toggle('visible', this.scrollTop > 300);
});

// ── Firebase 登入狀態 UI 更新 ──────────────────────────────
function _updateAuthUI(user) {
  const tbLogin    = document.getElementById('tb-login-btn');
  const tbWrap     = document.getElementById('tb-user-wrap');
  const tbAvatar   = document.getElementById('tb-avatar');
  const tbFallback = document.getElementById('tb-avatar-fallback');
  const tbName     = document.getElementById('tb-name');
  const tbDropName  = document.getElementById('tb-drop-name');
  const tbDropEmail = document.getElementById('tb-drop-email');
  if(user) {
    if(tbLogin) tbLogin.style.display = 'none';
    if(tbWrap)  tbWrap.style.display  = 'block';
    if(tbAvatar && user.photoURL){ tbAvatar.src = user.photoURL; tbAvatar.style.display='block'; }
    const initials = (user.displayName||user.email||'U').charAt(0).toUpperCase();
    if(tbFallback)  tbFallback.textContent = initials;
    if(tbName)      tbName.textContent     = user.displayName || user.email || '';
    if(tbDropName)  tbDropName.textContent  = user.displayName || '未設定名稱';
    if(tbDropEmail) tbDropEmail.textContent = user.email || '';
  } else {
    if(tbLogin) tbLogin.style.display = 'flex';
    if(tbWrap)  tbWrap.style.display  = 'none';
    closeUserDropdown();
  }
}

function toggleUserDropdown() {
  const wrap = document.getElementById('tb-user-wrap');
  if(wrap) wrap.classList.toggle('open');
}
function closeUserDropdown() {
  const wrap = document.getElementById('tb-user-wrap');
  if(wrap) wrap.classList.remove('open');
}
// 點選單外部自動關閉
document.addEventListener('click', function(e) {
  const wrap = document.getElementById('tb-user-wrap');
  if(wrap && !wrap.contains(e.target)) closeUserDropdown();
});



function togTxAcc(id){
  var el=document.getElementById(id);
  var isOpen=el.classList.contains('open');
  document.querySelectorAll('.tx-acc-item').forEach(function(i){i.classList.remove('open');});
  if(!isOpen) el.classList.add('open');
}

// ── 背景預熱永續課文（頁面載入後 3 秒靜默完成，之後點入課文頁是瞬間）──
(function _txPrewarm(){
  const run = () => {
    // 分幀預載入，絕不阻塞首頁渲染
    requestAnimationFrame(()=>{
      _txEnsureChapter(0);
      requestAnimationFrame(()=>{
        _txEnsureChapter(1);
        requestAnimationFrame(()=>{
          _txEnsureChapter(2);
          requestAnimationFrame(()=>{ _txEnsureChapter(3); });
        });
      });
    });
  };
  // 等首頁渲染穩定後再預熱（用 requestIdleCallback 最優雅；不支援則 setTimeout 3s）
  if(window.requestIdleCallback){
    requestIdleCallback(run, {timeout: 5000});
  } else {
    setTimeout(run, 3000);
  }
})();
</script>

